---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BreadcrumbHero from '../../components/BreadcrumbHero.astro';
import BlogCta from '../../components/BlogCta.astro';
import DetailPageShell from '../../components/DetailPageShell.astro';
import DetailRfqStrip from '../../components/DetailRfqStrip.astro';
import FunnelPageView from '../../components/FunnelPageView.astro';
import SubpageLinks from '../../components/SubpageLinks.astro';
import { features } from '../../data/features';
import { materials } from '../../data/materials';
import { products } from '../../data/products';
import { services } from '../../data/services';
import { breadcrumbSchema, site } from '../../data/site';
import '../../styles/resource-page.css';

export function getStaticPaths() {
  return features.map((f) => ({ params: { slug: f.slug }, props: { feature: f } }));
}

const { feature } = Astro.props;
const pageUrl = `${site.url}/features/${feature.slug}/`;
const quoteHref = `/contact/?source=feature-${feature.slug}`;
const productSlugs = feature.productSlugs as readonly string[];
const linkedProducts = products.filter((p) => productSlugs.includes(p.slug));

const featureCapabilityMap: Record<string, string[]> = {
  'hardened-parts': ['grinding', 'edm'],
  'precision-ground-parts': ['grinding'],
  'threaded-parts': ['cnc-turning', 'cnc-milling'],
  'lightweight-parts': ['5-axis-machining'],
  'high-precision-parts': ['5-axis-machining', 'grinding', 'edm'],
  'quick-turn-samples': ['cnc-milling', 'cnc-turning'],
  'no-moq-small-batch': ['cnc-milling', 'cnc-turning'],
};
const featureMaterialMap: Record<string, string[]> = {
  'hardened-parts': ['tool-steels', 'carbon-steel'],
  'precision-ground-parts': ['tool-steels', 'stainless-steel'],
  'threaded-parts': ['stainless-steel'],
  'corrosion-resistant-parts': ['stainless-steel', 'titanium', 'nickel-alloys'],
  'lightweight-parts': ['aluminum', 'magnesium', 'titanium'],
  'high-precision-parts': ['tool-steels'],
  'quick-turn-samples': ['aluminum'],
  'no-moq-small-batch': ['aluminum'],
};
const relatedCapabilities = (featureCapabilityMap[feature.slug] ?? [])
  .map((slug) => services.find((s) => s.slug === slug))
  .filter((s): s is (typeof services)[number] => Boolean(s))
  .map((s) => ({ href: `/capabilities/${s.slug}/`, title: s.title, summary: s.summary }));
const relatedMaterials = (featureMaterialMap[feature.slug] ?? [])
  .map((slug) => materials.find((m) => m.slug === slug))
  .filter((m): m is (typeof materials)[number] => Boolean(m))
  .map((m) => ({ href: `/materials/${m.slug}/`, title: m.title, summary: m.summary }));
---

<BaseLayout
  title={feature.seoTitle}
  description={feature.summary}
  currentPath="/features"
  jsonLd={breadcrumbSchema([
    { name: 'Home', url: site.url },
    { name: 'Parts by Feature', url: `${site.url}/features/` },
    { name: feature.title, url: pageUrl },
  ])}
>
  <FunnelPageView stage="selection" label={`feature-${feature.slug}`} />
  <BreadcrumbHero
    title={feature.h1Title}
    trail={[
      { label: 'Home', href: '/' },
      { label: 'Features', href: '/features/' },
      { label: feature.title },
    ]}
    variant={['1', '2', '3', '5'][linkedProducts.length % 4] as '1' | '2' | '3' | '5'}
  />

  <DetailPageShell intro={feature.summary}>
    <div class="resource-meta">
      <span><strong>{linkedProducts.length}</strong> linked part types</span>
      <span>Free <strong>parts verification</strong></span>
      <span><strong>No MOQ</strong></span>
    </div>

    <DetailRfqStrip
      quoteHref={quoteHref}
      title={`Quote ${feature.title.toLowerCase()}`}
      text="Send your part number with feature callouts — hardness, finish, precision level, or sample urgency — for a quote within 24 hours."
    />

    <div set:html={feature.content.partOne} />
    <div set:html={feature.content.partTwo} />
    {linkedProducts.length > 0 && (
      <>
        <h2 id="linked-products">Products with this feature</h2>
        <div class="hub-grid">
          {linkedProducts.map((p) => (
            <a href={`/products/${p.slug}/`} class="hub-card">
              <span class="hub-card-title">{p.title}</span>
              <span class="hub-card-summary">{p.summary.slice(0, 100)}…</span>
            </a>
          ))}
        </div>
      </>
    )}

    <SubpageLinks title="Processes for this feature" items={relatedCapabilities} />
    <SubpageLinks title="Materials for this feature" items={relatedMaterials} />

    <p class="resource-note detail-page-back">
      <a href="/features/">All features</a>
      ·
      <a href="/compare/">Process comparisons</a>
      ·
      <a href="/case-studies/">Case studies</a>
      ·
      <a href={quoteHref}>Request a quote</a>
    </p>
    <aside slot="sidebar" class="service-sidebar">
      <div class="service-sidebar-block">
        <div class="service-sidebar-title-block"><h3 class="service-sidebar-title">Parts by Feature</h3></div>
        <div class="service-sidebar-list">
          {features.map((f) => (
            <a href={`/features/${f.slug}/`} class:list={['service-sidebar-link', { active: f.slug === feature.slug }]}>
              <div class="service-sidebar-link-shape"></div><span class="service-sidebar-link-text">{f.title}</span>
            </a>
          ))}
        </div>
      </div>
    </aside>
  </DetailPageShell>

  <BlogCta
    stage="selection"
    topic={feature.slug}
    title={`Quote parts with ${feature.title.toLowerCase()}`}
    text="Send your part number with feature requirements — we confirm part fit in the quotation response."
    primaryLabel="Request a Quote"
    primaryHref={quoteHref}
    primaryEvent={`feature_${feature.slug}_rfq`}
    secondaryLabel="Tolerance guide"
    secondaryHref="/resources/cnc-tolerance-guide/"
    secondaryEvent="feature_tolerance_guide"
  />
</BaseLayout>
