---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BreadcrumbHero from '../../components/BreadcrumbHero.astro';
import BlogCta from '../../components/BlogCta.astro';
import CaseStudyBeforeAfter from '../../components/CaseStudyBeforeAfter.astro';
import CaseStudyCard from '../../components/CaseStudyCard.astro';
import CaseStudyClientProfile from '../../components/CaseStudyClientProfile.astro';
import CaseStudyCustomerQuote from '../../components/CaseStudyCustomerQuote.astro';
import CaseStudyMetaFooter from '../../components/CaseStudyMetaFooter.astro';
import CaseStudyNarrativeBanner from '../../components/CaseStudyNarrativeBanner.astro';
import CaseStudyTrustLinks from '../../components/CaseStudyTrustLinks.astro';
import DetailPageShell from '../../components/DetailPageShell.astro';
import DetailRfqStrip from '../../components/DetailRfqStrip.astro';
import FunnelPageView from '../../components/FunnelPageView.astro';
import RelatedComparisons from '../../components/RelatedComparisons.astro';
import { authors } from '../../data/blog';
import { getComparisonsForCaseStudy } from '../../data/funnel-links';
import { getCaseStudyProofContext } from '../../data/industry-proof';
import { caseStudies } from '../../data/case-studies';
import { breadcrumbSchema, caseStudySchema, site } from '../../data/site';
import '../../styles/resource-page.css';

export function getStaticPaths() {
  return caseStudies.map((study) => ({ params: { slug: study.slug }, props: { study } }));
}

const { study } = Astro.props;
const pageUrl = `${site.url}/case-studies/${study.slug}/`;
const quoteHref = `/contact/?source=case-study-${study.slug}`;
const relatedComparisons = getComparisonsForCaseStudy(study.slug, 6);
const proofContext = getCaseStudyProofContext(study.slug);
const author = authors[study.documentedBy];
const authorUrl = `${site.url}/blog/author/${author.slug}/`;

const related = caseStudies
  .filter((item) => item.slug !== study.slug)
  .sort((a, b) => {
    const aMatch = a.industry === study.industry ? 1 : 0;
    const bMatch = b.industry === study.industry ? 1 : 0;
    return bMatch - aMatch;
  })
  .slice(0, 3);

const specs = [
  { label: 'Industry', value: study.industry },
  { label: 'Material', value: study.material },
  { label: 'Process', value: study.process },
  { label: 'Tolerance', value: study.tolerance },
  { label: 'Quantity', value: study.quantity },
  { label: 'Lead Time', value: study.proof.leadTime },
];

const proofCards = [
  { label: 'Inspection', value: study.proof.inspection },
  { label: 'Documentation', value: study.proof.documentation },
  { label: 'Buyer Risk Solved', value: study.proof.buyerConcern },
  { label: 'Measured Outcome', value: study.proof.outcomeMetric },
];

const storySteps = [
  { step: '01', title: 'The Challenge', body: study.content.challenge },
  { step: '02', title: 'Why They Chose Us', body: study.decision },
  { step: '03', title: 'How the Team Solved It', body: study.content.solution },
  { step: '04', title: 'Measured Results', body: study.content.result },
];

const pageJsonLd = [
  breadcrumbSchema([
    { name: 'Home', url: site.url },
    { name: 'Case Studies', url: `${site.url}/case-studies/` },
    { name: study.title, url: pageUrl },
  ]),
  caseStudySchema({
    title: study.h1Title,
    description: study.summary,
    url: pageUrl,
    image: `${site.url}${study.image}`,
    datePublished: study.datePublished,
    industry: study.industry,
    authorName: author.name,
    authorUrl,
    authorJobTitle: author.jobTitle,
  }),
];
---

<BaseLayout
  title={study.seoTitle}
  description={study.summary}
  currentPath="/case-studies"
  noindex
  image={study.image}
  jsonLd={pageJsonLd}
>
  <FunnelPageView stage="signing" label={study.slug} />
  <BreadcrumbHero
    title={study.h1Title}
    trail={[
      { label: 'Home', href: '/' },
      { label: 'Case Studies', href: '/case-studies/' },
      { label: study.title },
    ]}
    variant="2"
  />

  <DetailPageShell>
    <div slot="hero" class="case-study-hero-image">
      <img
        src={study.image}
        alt={study.title}
        class="case-study-hero-img"
        width="1400"
        height="692"
        loading="eager"
        fetchpriority="high"
        decoding="async"
      />
      <span class="case-study-hero-badge">{study.industry}</span>
    </div>

    <div class="case-study-summary-card">
      <p class="case-study-summary-text">{study.summary}</p>
    </div>

    <div class="resource-meta" aria-label="Project snapshot">
      <span><strong>{study.industry}</strong></span>
      <span><strong>{study.material}</strong></span>
      <span>Lead time · {study.proof.leadTime}</span>
    </div>

    <DetailRfqStrip
      quoteHref={quoteHref}
      title="Request similar scope"
      text={study.proof.nextStep}
    />

    <CaseStudyNarrativeBanner narrative={study.narrative} />

    <div class="case-study-specs">
      {specs.map((spec) => (
        <div class="case-study-spec">
          <span class="spec-label">{spec.label}</span>
          <span class="spec-value">{spec.value}</span>
        </div>
      ))}
    </div>

    <CaseStudyClientProfile profile={study.clientProfile} />

    <CaseStudyTrustLinks context={proofContext} caseStudySlug={study.slug} />

    <section class="case-study-proof" aria-labelledby="proof-heading">
      <div class="case-study-proof-heading">
        <p class="case-study-proof-kicker">Buyer proof package</p>
        <h2 id="proof-heading">What procurement and quality teams can verify</h2>
      </div>
      <div class="case-study-proof-grid">
        {proofCards.map((item) => (
          <article class="case-study-proof-card">
            <span>{item.label}</span>
            <p>{item.value}</p>
          </article>
        ))}
      </div>
      <div class="case-study-next-rfq">
        <strong>RFQ tip:</strong> {study.proof.nextStep}
      </div>
      <p class="case-study-proof-footer">
        {study.inspectionSampleHref && (
          <>
            <a href={study.inspectionSampleHref}>See redacted report layouts</a>
            <span aria-hidden="true"> · </span>
          </>
        )}
        <a href={quoteHref}>Request similar scope</a>
      </p>
    </section>

    <CaseStudyBeforeAfter rows={study.beforeAfter} />

    <div class="case-study-story">
      {storySteps.map((item) => (
        <article class="case-study-step">
          <div class="case-study-step-marker" aria-hidden="true">{item.step}</div>
          <div class="case-study-step-body">
            <h2 class="case-study-step-title">{item.title}</h2>
            <p>{item.body}</p>
          </div>
        </article>
      ))}
    </div>

    <CaseStudyCustomerQuote quote={study.customerQuote} />

    <RelatedComparisons
      id="case-study-comparisons"
      items={relatedComparisons}
      title="Comparisons behind this project"
    />

    <h2 class="case-study-related-heading">More case studies</h2>
    <div class="case-studies-grid-related">
      {related.map((item) => (
        <CaseStudyCard
          slug={item.slug}
          title={item.title}
          image={item.image}
          industry={item.industry}
          material={item.material}
          process={item.process}
          tolerance={item.tolerance}
          quantity={item.quantity}
          outcomeMetric={item.proof.outcomeMetric}
        />
      ))}
    </div>

    <CaseStudyMetaFooter documentedBy={study.documentedBy} datePublished={study.datePublished} />

    <p class="resource-note detail-page-back">
      <a href="/case-studies/">All case studies</a>
      ·
      <a href="/certifications/">Certifications</a>
      ·
      <a href="/resources/inspection-samples/">Inspection samples</a>
      ·
      <a href={quoteHref}>Request a quote</a>
    </p>
  </DetailPageShell>

  <BlogCta
    stage="signing"
    topic={study.slug}
    title="Quote a project like this"
    text="Send your part number with part and documentation requirements — we confirm scope and respond within 24 hours."
    primaryLabel="Request a Quote"
    primaryHref={quoteHref}
    primaryEvent={`case_study_${study.slug}_rfq`}
    secondaryLabel="Certifications"
    secondaryHref="/certifications/"
    secondaryEvent="case_study_certifications"
  />
</BaseLayout>

<style>
  .detail-page-hero .case-study-hero-image {
    position: relative;
    margin-bottom: 0;
    border-radius: 4px;
    overflow: hidden;
    border: 1px solid var(--color-stroke);
  }

  .case-study-hero-img {
    display: block;
    width: 50%;
    height: auto;
    aspect-ratio: 16 / 9;
    object-fit: cover;
  }

  .case-study-hero-badge {
    position: absolute;
    left: 16px;
    bottom: 16px;
    padding: 6px 12px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-white);
    background: rgba(8, 8, 8, 0.72);
    backdrop-filter: blur(4px);
    border-radius: 4px;
  }

  .case-study-summary-card {
    margin-bottom: 24px;
    padding: 20px 22px;
    background: var(--color-background);
    border: 1px solid var(--color-stroke);
    border-left: 4px solid var(--color-primary);
    border-radius: 4px;
  }

  .case-study-summary-text {
    margin: 0;
    font-size: 17px;
    line-height: 1.65;
    color: var(--color-body-text);
    text-transform: none;
  }

  .case-study-specs {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(130px, 1fr));
    gap: 10px;
    margin-bottom: 24px;
  }

  .case-study-spec {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 14px 12px;
    background: var(--color-background);
    border: 1px solid var(--color-stroke);
    border-radius: 4px;
    text-align: center;
  }

  .spec-label {
    font-size: 11px;
    font-weight: 700;
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .spec-value {
    font-size: 14px;
    font-weight: 600;
    color: var(--color-title);
    line-height: 1.35;
  }

  .case-study-proof {
    margin: 0 0 28px;
    padding: 24px;
    border: 1px solid var(--color-stroke);
    border-radius: 4px;
    background: var(--color-background);
  }

  .case-study-proof-heading {
    margin-bottom: 18px;
  }

  .case-study-proof-kicker {
    margin: 0 0 6px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-primary);
  }

  .case-study-proof-heading h2 {
    margin: 0;
    font-size: 22px;
    font-weight: 600;
    color: var(--color-title);
    text-transform: none;
  }

  .case-study-proof-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
  }

  .case-study-proof-card {
    padding: 16px;
    border: 1px solid var(--color-stroke);
    border-radius: 4px;
    background: var(--color-white);
  }

  .case-study-proof-card span {
    display: block;
    margin-bottom: 8px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-primary);
  }

  .case-study-proof-card p {
    margin: 0;
    font-size: 14px;
    line-height: 1.55;
    color: var(--color-body-text);
  }

  .case-study-next-rfq {
    margin-top: 14px;
    padding: 14px 16px;
    border-left: 4px solid var(--color-primary);
    border-radius: 4px;
    background: var(--color-white);
    font-size: 15px;
    line-height: 1.6;
    color: var(--color-body-text);
  }

  .case-study-next-rfq strong {
    color: var(--color-title);
  }

  .case-study-proof-footer {
    margin: 14px 0 0;
    font-size: 14px;
    font-weight: 600;
  }

  .case-study-proof-footer a {
    color: var(--color-primary);
    text-decoration: none;
  }

  .case-study-proof-footer a:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
    border-radius: 2px;
  }

  .case-study-story {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-bottom: 28px;
  }

  .case-study-step {
    display: grid;
    grid-template-columns: 52px 1fr;
    gap: 18px;
    padding: 22px;
    background: var(--color-background);
    border: 1px solid var(--color-stroke);
    border-radius: 4px;
  }

  .case-study-step-marker {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 52px;
    height: 52px;
    font-family: var(--font-title);
    font-size: 17px;
    font-weight: 600;
    color: var(--color-primary);
    background: rgba(20, 110, 245, 0.08);
    border-radius: 4px;
    flex-shrink: 0;
  }

  .case-study-step-title {
    margin: 0 0 8px;
    font-size: 20px;
    font-weight: 600;
    color: var(--color-title);
    text-transform: none;
  }

  .case-study-step-body p {
    margin: 0;
    font-size: 15px;
    line-height: 1.7;
    color: var(--color-body-text);
  }

  .case-study-related-heading {
    margin: 32px 0 16px;
    font-size: 22px;
    font-weight: 600;
    color: var(--color-title);
    text-transform: none;
  }

  .case-studies-grid-related {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-bottom: 8px;
  }

  @media (max-width: 991px) {
    .case-studies-grid-related {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .case-study-hero-img {
      width: 100%;
    }
    .case-study-proof-grid,
    .case-study-specs {
      grid-template-columns: 1fr;
    }
    .case-study-proof {
      padding: 18px 16px;
    }
    .case-study-step {
      grid-template-columns: 1fr;
      gap: 12px;
      padding: 18px 16px;
    }
    .case-study-step-marker {
      width: 44px;
      height: 44px;
      font-size: 15px;
    }
    .case-study-step-title {
      font-size: 18px;
    }
    .case-study-summary-card {
      padding: 16px 18px;
    }
  }
</style>
