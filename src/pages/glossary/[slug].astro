---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BreadcrumbHero from '../../components/BreadcrumbHero.astro';
import BlogCta from '../../components/BlogCta.astro';
import DetailPageShell from '../../components/DetailPageShell.astro';
import DetailRfqStrip from '../../components/DetailRfqStrip.astro';
import FunnelPageView from '../../components/FunnelPageView.astro';
import { getRelatedGlossaryTerms, glossaryTerms } from '../../data/glossary';
import { isGlossaryNoindex } from '../../data/glossary-quality';
import { breadcrumbSchema, site } from '../../data/site';
import '../../styles/resource-page.css';

export function getStaticPaths() {
  return glossaryTerms.map((term) => ({ params: { slug: term.slug }, props: { term } }));
}

const { term } = Astro.props;
const pageUrl = `${site.url}/glossary/${term.slug}/`;
const quoteHref = `/contact/?source=glossary-${term.slug}`;
const related = getRelatedGlossaryTerms(term);
const noindex = isGlossaryNoindex(term.slug);
---

<BaseLayout
  title={`${term.term} — Engine Parts Glossary`}
  description={term.shortDefinition}
  currentPath="/glossary"
  noindex={noindex}
  jsonLd={breadcrumbSchema([
    { name: 'Home', url: site.url },
    { name: 'Glossary', url: `${site.url}/glossary/` },
    { name: term.term, url: pageUrl },
  ])}
>
  <FunnelPageView stage="awareness" label={term.slug} />
  <BreadcrumbHero
    title={term.term}
    trail={[
      { label: 'Home', href: '/' },
      { label: 'Glossary', href: '/glossary/' },
      { label: term.term.length > 40 ? `${term.term.slice(0, 40)}…` : term.term },
    ]}
    variant="5"
  />

  <DetailPageShell intro={term.shortDefinition}>
    <div class="resource-meta">
      <span>Glossary term</span>
      {term.relatedLinks && term.relatedLinks.length > 0 && (
        <span><strong>{term.relatedLinks.length}</strong> deep-dive links</span>
      )}
      {related.length > 0 && (
        <span><strong>{related.length}</strong> related terms</span>
      )}
    </div>

    <DetailRfqStrip
      quoteHref={quoteHref}
      title="Apply this on your RFQ"
      text="Send your part number and reference this term in notes — we confirm tolerances, finishes, and compliance language in the quote."
      label="Request a Quote"
    />

    <div set:html={term.body} />

    {term.relatedLinks && term.relatedLinks.length > 0 && (
      <>
        <h2>Learn more</h2>
        <ul class="resource-list">
          {term.relatedLinks.map((link) => (
            <li><a href={link.href}>{link.label}</a></li>
          ))}
        </ul>
      </>
    )}

    {related.length > 0 && (
      <>
        <h2>Related terms</h2>
        <div class="hub-grid">
          {related.map((item) => (
            <a href={`/glossary/${item.slug}/`} class="hub-card">
              <span class="hub-card-title">{item.term}</span>
              <span class="hub-card-summary">{item.shortDefinition}</span>
            </a>
          ))}
        </div>
      </>
    )}

    <p class="resource-note detail-page-back">
      <a href="/glossary/">All glossary terms</a>
      ·
      <a href="/blog/guides/">Guide hubs</a>
      ·
      <a href="/resources/inspection-samples/">Tolerance guide</a>
      ·
      <a href={quoteHref}>Request a quote</a>
    </p>
  </DetailPageShell>

  <BlogCta
    stage="awareness"
    topic={term.slug}
    title="Turn this term into a scoped quote"
    text="Send your part number — we confirm specs and feasibility in the quotation response."
    primaryLabel="Request a Quote"
    primaryHref={quoteHref}
    primaryEvent={`glossary_${term.slug}_rfq`}
    secondaryLabel="Inquiry checklist"
    secondaryHref="/resources/dfm-checklist/"
    secondaryEvent="glossary_dfm_checklist"
  />
</BaseLayout>
