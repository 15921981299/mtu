---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BreadcrumbHero from '../../components/BreadcrumbHero.astro';
import DetailPageShell from '../../components/DetailPageShell.astro';
import DetailRfqStrip from '../../components/DetailRfqStrip.astro';
import FunnelPageView from '../../components/FunnelPageView.astro';
import { getFrequentlyPairedParts, getRelatedMtuParts, getSameCategoryParts, getSameSeriesParts, mtuCatalogHubs, mtuParts } from '../../data/mtu-parts';
import { breadcrumbSchema, faqSchema, productSchema, site } from '../../data/site';
import '../../styles/resource-page.css';

export function getStaticPaths() {
  return mtuParts.map((part) => ({ params: { slug: part.slug }, props: { part } }));
}

const { part } = Astro.props;
const pageUrl = `${site.url}/part-products/${part.slug}/`;
const quoteHref = `/contact/?source=part-${part.slug}`;
const relatedParts = getRelatedMtuParts(part, 8);
const sameSeriesParts = getSameSeriesParts(part, 12);
const sameCategoryParts = getSameCategoryParts(part, 8);
const pairedParts = getFrequentlyPairedParts(part, 8);
const hasSpecificEngineType = part.engineType && !/^Verify by engine serial number$/i.test(part.engineType);
const hasSpecificApplicableEngines = part.applicableEngines && !/^Verify by engine serial number$/i.test(part.applicableEngines);
const shortApplicableEngines = hasSpecificApplicableEngines
  ? part.applicableEngines!.split(';')[0].replace(/\.$/, '')
  : undefined;
const seriesText = part.series.length > 0
  ? part.series.join(', ')
  : hasSpecificEngineType
    ? part.engineType!
    : hasSpecificApplicableEngines
      ? shortApplicableEngines!
      : 'MTU engine serial-number verified applications';
const title = `${part.partNumber} ${part.name} - ${seriesText} Part`;
const metaStock = part.stockStatus ?? 'Availability checked after inquiry';
const metaRaw = `${metaStock}. ${part.partNumber} ${part.name} for ${seriesText}. Engine type, dimensions, weight, HS code, and fitment checked before quote.`;
const metaDesc = metaRaw.length <= 160 ? metaRaw : metaRaw.slice(0, 157).replace(/\s+\S*$/, '') + '...';
const partFaqs = part.faqs ?? [];
const replacementRefs = part.replacementFor?.filter((ref) => ref.trim() !== '') ?? [];
const hasReplacementRefs = replacementRefs.length > 0;
const replacementReviewText = hasReplacementRefs
  ? `${part.partNumber} may replace, supersede, or cross-reference the numbers below. Final fitment is checked against the engine serial number and installation position before quotation.`
  : `${part.partNumber} has no public alternative number listed in our current data. We still check old-part photos, engine serial number, and catalog position for supersession before quotation.`;
const quoteChecklist = part.quoteChecklist ?? [
  `Part number: ${part.partNumber}`,
  'Engine model, rating, and serial number',
  'Nameplate photo and old part photo when available',
  'Quantity, destination country, and required delivery date',
];
const orderReleaseChecks = [
  ['Supply route', 'Quote notes identify OEM, OEM-alternative, reman, repaired, or sourcing route when available.'],
  ['Buyer confirmation', 'Serial number, old-part photo, installation position, or quantity questions are listed before order release.'],
  ['Export handling', 'Approximate weight, HS code, packing route, and shipment method are confirmed when available.'],
  ['Dispatch proof', 'Packing photos, visible label checks, or tracking details can be shared on request before shipment.'],
];
const procurementChecks = [
  ['Fitment basis', hasSpecificApplicableEngines ? part.applicableEngines : seriesText],
  ['Replacement check', hasReplacementRefs ? replacementRefs.join(', ') : 'Checked by old part number, serial number, and catalog position'],
  ['Failure context', part.commonFailureScenarios?.[0] ?? 'Describe alarm, leakage, wear, service interval, or downtime symptom'],
  ['Export fields', [part.weightKg ? `Weight ${part.weightKg}` : undefined, part.hsCode ? `HS ${part.hsCode}` : undefined]
    .filter(Boolean)
    .join(' / ') || 'Confirmed before export quote'],
];

const specRows = [
  ['Part No.', part.partNumber],
  ['Name', part.name],
  ['Category', part.category],
  ['Engine Type', hasSpecificEngineType ? part.engineType : seriesText],
  ['Series', seriesText],
  ['Dimensions', part.dimensions],
  ['Unit Weight', part.weightKg],
  ['HS Code', part.hsCode],
  ['NATO No.', part.natoNumber],
  ['Lead Time', part.leadTime],
].filter(([, value]) => value != null && String(value).trim() !== '');
const browseCatalogLinks = Array.from(
  new Map(
    [
      ...mtuCatalogHubs.filter((hub) => hub.partFilter(part)),
      ...mtuCatalogHubs,
    ].map((hub) => [hub.slug, hub]),
  ).values(),
).slice(0, 12);
---

<BaseLayout
  title={title}
  description={metaDesc}
  currentPath="/products"
  image={part.image}
  jsonLd={[
    breadcrumbSchema([
      { name: 'Home', url: site.url },
      { name: 'MTU Parts Catalog', url: `${site.url}/part-products/` },
      { name: `${part.partNumber} ${part.name}`, url: pageUrl },
    ]),
    productSchema({
      name: `${part.partNumber} ${part.name}`,
      description: part.summary,
      url: pageUrl,
      image: `${site.url}${part.image}`,
      sku: part.partNumber,
      model: seriesText,
      brandName: 'MTU',
      category: part.category,
    }),
    ...(partFaqs.length > 0 ? [faqSchema(partFaqs)] : []),
  ]}
>
  <FunnelPageView stage="selection" label={`mtu-part-${part.slug}`} />
  <BreadcrumbHero
    title={`${part.partNumber}<br>${part.name}`}
    trail={[
      { label: 'Home', href: '/' },
      { label: 'MTU Parts Catalog', href: '/part-products/' },
      { label: part.partNumber },
    ]}
    variant="2"
  />

  <DetailPageShell intro={part.summary}>
    <img
      slot="hero"
      src={part.image}
      alt={part.imageAlt ?? `${part.partNumber} ${part.name} - MTU ${part.category} spare part`}
      width="1400"
      height="692"
      loading="eager"
      fetchpriority="high"
      decoding="async"
    />

    <div class="resource-meta" aria-label="Part specifications">
      {specRows.slice(0, 8).map(([label, value]) => (
        <span><strong>{label}</strong> {value}</span>
      ))}
      <span><strong>Delivery</strong> Global shipping</span>
    </div>

    <div class="stock-status-bar">
      <span class="stock-indicator"></span>
      <span>{part.stockStatus ?? 'Stock status confirmed after inquiry'}</span>
    </div>

    <DetailRfqStrip
      quoteHref={quoteHref}
      title={`Check ${part.partNumber} availability`}
      text="Send engine model, serial number, nameplate photo, old part photo, quantity, destination, and required delivery date."
      modalContext={`${part.partNumber} ${part.name} - ${seriesText}`}
      modalSource={`part-${part.slug}`}
      secondaryHref="/part-products/"
      secondaryLabel="All MTU part numbers"
    />

    <h2>{part.partNumber} Specification</h2>
    <div class="part-spec-table">
      {specRows.map(([label, value]) => (
        <div>
          <dt>{label}</dt>
          <dd>{value}</dd>
        </div>
      ))}
      <div>
        <dt>Availability</dt>
        <dd>{part.availability}</dd>
      </div>
    </div>

    <h2>About {part.partNumber} - {part.name}</h2>
    <p>{part.description ?? part.summary}</p>

    {part.applicableEngines && (
      <>
        <h2>Applicable Engine Models</h2>
        <p>{part.applicableEngines}</p>
      </>
    )}

    {part.commonFailureScenarios && part.commonFailureScenarios.length > 0 && (
      <>
        <h2>Common Replacement Scenarios</h2>
        <p>This part is commonly replaced when:</p>
        <ul>
          {part.commonFailureScenarios.map((s) => <li>{s}</li>)}
        </ul>
      </>
    )}

    <h2>Cross-Reference and Superseded Part Numbers</h2>
    <p>{replacementReviewText}</p>
    {hasReplacementRefs ? (
      <ul>
        {replacementRefs.map((ref) => <li><strong>{ref}</strong></li>)}
      </ul>
    ) : (
      <div class="part-verification-card">
        <strong>Replacement status to verify:</strong>
        <span>Send the old part marking, engine model, engine serial number, and installation photo. We check whether a newer, reman, or OEM-alternative route applies before quoting.</span>
      </div>
    )}

    <h2>Procurement Snapshot</h2>
    <div class="part-procurement-grid">
      {procurementChecks.map(([label, value]) => (
        <div>
          <dt>{label}</dt>
          <dd>{value}</dd>
        </div>
      ))}
    </div>

    <h2>Common Applications</h2>
    <ul>
      {part.applications.map((application) => <li>{application}</li>)}
    </ul>

    <h2>Information to Send for Quotation</h2>
    <ul>
      {quoteChecklist.map((item) => <li>{item}</li>)}
      {part.dimensions && <li><strong>Dimensions reference:</strong> {part.dimensions}</li>}
      {part.weightKg && <li><strong>Approximate shipping weight:</strong> {part.weightKg}</li>}
      {part.hsCode && <li><strong>HS code for customs reference:</strong> {part.hsCode}</li>}
      {part.natoNumber && <li><strong>NATO number:</strong> {part.natoNumber}</li>}
    </ul>

    <h2>Order Release Standard</h2>
    <p>For {part.partNumber} inquiries, the quote should make the sourcing route and remaining confirmation points clear before payment or shipment approval.</p>
    <div class="part-release-grid">
      {orderReleaseChecks.map(([label, value]) => (
        <div>
          <dt>{label}</dt>
          <dd>{value}</dd>
        </div>
      ))}
    </div>

    {part.orderingNotes && (
      <>
        <h2>Ordering Notes</h2>
        <p>{part.orderingNotes}</p>
      </>
    )}

    {partFaqs.length > 0 && (
      <>
        <h2>{part.partNumber} FAQ</h2>
        <div class="part-faq-list">
          {partFaqs.map((faq) => (
            <article>
              <h3>{faq.question}</h3>
              <p>{faq.answer}</p>
            </article>
          ))}
        </div>
      </>
    )}

    <h2>Verification Notes</h2>
    <ul>
      {part.notes.map((note) => <li>{note}</li>)}
    </ul>

    {relatedParts.length > 0 && (
      <section class="hub-section">
        <header class="hub-section-header">
          <h2>Related MTU Parts</h2>
          <p>Similar parts by engine series or category.</p>
        </header>
        <div class="hub-grid part-related-grid">
          {relatedParts.map((related) => (
            <article class="hub-card">
              <div class="hub-card-body">
                <p class="hub-card-meta">{related.category}</p>
                <h3 class="hub-card-title">
                  <a href={`/part-products/${related.slug}/`}>{related.partNumber} {related.name}</a>
                </h3>
                <p class="hub-card-summary">{related.summary}</p>
              </div>
            </article>
          ))}
        </div>
      </section>
    )}

    {/* Same Series cross-links */}
    {sameSeriesParts.length > 0 && (
      <section class="hub-section">
        <header class="hub-section-header">
          <h2>Same Engine Series</h2>
          <p>Other parts for {part.series.join(', ')} engines.</p>
        </header>
        <div class="hub-grid part-related-grid">
          {sameSeriesParts.map((p) => (
            <article class="hub-card">
              <div class="hub-card-body">
                <p class="hub-card-meta">{p.category}</p>
                <h3 class="hub-card-title">
                  <a href={`/part-products/${p.slug}/`}>{p.partNumber} {p.name}</a>
                </h3>
              </div>
            </article>
          ))}
        </div>
      </section>
    )}

    {/* Same System cross-links */}
    {sameCategoryParts.length > 0 && (
      <section class="hub-section">
        <header class="hub-section-header">
          <h2>Same System — {part.category}</h2>
          <p>Other {part.category.toLowerCase()} parts across different MTU engine series.</p>
        </header>
        <div class="hub-grid part-related-grid">
          {sameCategoryParts.map((p) => (
            <article class="hub-card">
              <div class="hub-card-body">
                <p class="hub-card-meta">{p.series.join(', ')}</p>
                <h3 class="hub-card-title">
                  <a href={`/part-products/${p.slug}/`}>{p.partNumber} {p.name}</a>
                </h3>
              </div>
            </article>
          ))}
        </div>
      </section>
    )}

    {/* Frequently Purchased Together */}
    {pairedParts.length > 0 && (
      <section class="hub-section">
        <header class="hub-section-header">
          <h2>Frequently Purchased Together</h2>
          <p>Parts commonly ordered alongside {part.partNumber} {part.name}.</p>
        </header>
        <div class="hub-grid part-related-grid">
          {pairedParts.map((p) => (
            <article class="hub-card">
              <div class="hub-card-body">
                <p class="hub-card-meta">{p.category} / {p.series.join(', ')}</p>
                <h3 class="hub-card-title">
                  <a href={`/part-products/${p.slug}/`}>{p.partNumber} {p.name}</a>
                </h3>
                <p class="hub-card-summary">{p.summary}</p>
              </div>
            </article>
          ))}
        </div>
      </section>
    )}

    {/* Browse more catalogs */}
    <section style="margin-top: 32px; padding-top: 24px; border-top: 1px solid var(--color-stroke);">
      <h2 style="font-size: 18px; margin-bottom: 12px;">Browse More MTU Parts</h2>
      <div style="display: flex; flex-wrap: wrap; gap: 8px 16px; font-size: 14px;">
        {browseCatalogLinks.map((hub) => (
          <a href={`/part-products/catalog/${hub.slug}/`} style="color: var(--color-primary); text-decoration: none;">{hub.h1Title}</a>
        ))}
        <a href="/part-products/" style="color: var(--color-primary); text-decoration: none; font-weight: 600;">All catalogs →</a>
      </div>
    </section>

    <p class="resource-note detail-page-back">
      <a href="/part-products/">All MTU part numbers</a>
      /
      <a href="/products/mtu-spare-parts/">MTU spare parts</a>
      /
      <a
        href={quoteHref}
        data-rfq-modal
        data-rfq-context={`${part.partNumber} ${part.name} - ${seriesText}`}
        data-rfq-source={`part-${part.slug}`}
      >Check this part</a>
    </p>
  </DetailPageShell>
</BaseLayout>

<style>
  .part-related-grid {
    grid-template-columns: repeat(2, 1fr);
  }

  .part-spec-table {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    border: 1px solid var(--color-stroke);
    border-radius: 6px;
    overflow: hidden;
    margin: 16px 0 28px;
  }

  .part-spec-table div {
    display: grid;
    grid-template-columns: minmax(120px, 0.55fr) minmax(0, 1fr);
    border-bottom: 1px solid var(--color-stroke);
  }

  .part-spec-table div:nth-last-child(-n + 2) {
    border-bottom: 0;
  }

  .part-spec-table dt,
  .part-spec-table dd {
    margin: 0;
    padding: 12px 14px;
    font-size: 14px;
    line-height: 1.45;
  }

  .part-spec-table dt {
    background: #f8fafc;
    color: #475569;
    font-weight: 700;
  }

  .part-spec-table dd {
    color: #0f172a;
  }

  .part-faq-list {
    display: grid;
    gap: 12px;
    margin: 16px 0 28px;
  }

  .part-faq-list article {
    border: 1px solid var(--color-stroke);
    border-radius: 6px;
    padding: 16px;
    background: #fff;
  }

  .part-faq-list h3 {
    margin: 0 0 8px;
    font-size: 16px;
    line-height: 1.35;
  }

  .part-faq-list p {
    margin: 0;
    color: #475569;
  }

  .part-verification-card {
    display: grid;
    gap: 6px;
    margin: 12px 0 28px;
    padding: 16px 18px;
    border: 1px solid #bfdbfe;
    border-radius: 6px;
    background: #eff6ff;
    color: #1e3a8a;
  }

  .part-verification-card strong {
    font-size: 14px;
    line-height: 1.35;
  }

  .part-verification-card span {
    font-size: 14px;
    line-height: 1.55;
  }

  .part-procurement-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px;
    margin: 14px 0 28px;
  }

  .part-procurement-grid div {
    min-width: 0;
    padding: 14px 16px;
    border: 1px solid var(--color-stroke);
    border-radius: 6px;
    background: #fff;
  }

  .part-procurement-grid dt {
    margin: 0 0 5px;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: #64748b;
  }

  .part-procurement-grid dd {
    margin: 0;
    font-size: 14px;
    line-height: 1.45;
    color: #0f172a;
    overflow-wrap: anywhere;
  }

  .part-release-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px;
    margin: 14px 0 28px;
  }

  .part-release-grid div {
    padding: 16px;
    border: 1px solid rgba(20, 110, 245, 0.16);
    border-radius: 6px;
    background: #f8fafc;
  }

  .part-release-grid dt {
    margin: 0 0 6px;
    color: var(--color-title);
    font-size: 14px;
    font-weight: 800;
    line-height: 1.35;
  }

  .part-release-grid dd {
    margin: 0;
    color: #475569;
    font-size: 14px;
    line-height: 1.55;
  }

  .stock-status-bar {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 14px 20px;
    background: #f0fdf4;
    border: 1px solid #bbf7d0;
    border-radius: 6px;
    font-size: 15px;
    color: #166534;
    line-height: 1.5;
    margin-bottom: 24px;
  }

  .stock-indicator {
    flex-shrink: 0;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: #22c55e;
    box-shadow: 0 0 0 3px rgba(34, 197, 94, 0.2);
  }

  @media (max-width: 700px) {
    .part-related-grid,
    .part-spec-table,
    .part-procurement-grid,
    .part-release-grid {
      grid-template-columns: 1fr;
    }

    .part-spec-table div,
    .part-spec-table div:nth-last-child(-n + 2) {
      border-bottom: 1px solid var(--color-stroke);
    }
  }
</style>
