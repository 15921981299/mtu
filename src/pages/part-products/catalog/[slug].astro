---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import BreadcrumbHero from '../../../components/BreadcrumbHero.astro';
import BlogCta from '../../../components/BlogCta.astro';
import FunnelPageView from '../../../components/FunnelPageView.astro';
import { isRealPartImage, mtuCatalogHubs, mtuParts, type MtuCatalogHub } from '../../../data/mtu-parts';
import { breadcrumbSchema, itemListSchema, site } from '../../../data/site';
import '../../../styles/resource-page.css';

export function getStaticPaths() {
  return mtuCatalogHubs.map((hub) => ({ params: { slug: hub.slug }, props: { hub } }));
}

const { hub } = Astro.props as { hub: MtuCatalogHub };
const parts = mtuParts.filter(hub.partFilter);
const pageUrl = `${site.url}/part-products/catalog/${hub.slug}/`;
const quoteHref = `/contact/?source=catalog-${hub.slug}`;

// For series hubs: group by category. For category hubs: group by engine series.
const categoryGroups = new Map<string, typeof parts>();
for (const part of parts) {
  const groupKeys = hub.type === 'series'
    ? [part.category]
    : part.series.length > 0
      ? part.series
      : [part.engineType ?? 'Verify by engine serial number'];

  for (const key of groupKeys) {
    if (!categoryGroups.has(key)) categoryGroups.set(key, []);
    categoryGroups.get(key)!.push(part);
  }
}

const groupLabel = hub.type === 'series' ? 'category' : 'series';
const featuredParts = [...parts]
  .sort((a, b) => {
    const bScore =
      Number(isRealPartImage(b.image)) * 4 +
      Number(Boolean(b.engineType && b.dimensions && b.weightKg && b.hsCode)) * 3 +
      Number(Boolean(b.replacementFor?.length)) * 2 +
      Number(Boolean(b.applicableEngines));
    const aScore =
      Number(isRealPartImage(a.image)) * 4 +
      Number(Boolean(a.engineType && a.dimensions && a.weightKg && a.hsCode)) * 3 +
      Number(Boolean(a.replacementFor?.length)) * 2 +
      Number(Boolean(a.applicableEngines));
    return bScore - aScore || a.partNumber.localeCompare(b.partNumber);
  })
  .slice(0, 20);
const partSlugSet = new Set(parts.map((part) => part.slug));
const relatedCatalogHubs = mtuCatalogHubs
  .filter((h) => h.slug !== hub.slug)
  .map((h) => ({
    hub: h,
    overlap: mtuParts.filter(h.partFilter).filter((part) => partSlugSet.has(part.slug)).length,
    crossTypeBoost: h.type === hub.type ? 0 : 1,
  }))
  .sort((a, b) => b.overlap - a.overlap || b.crossTypeBoost - a.crossTypeBoost || a.hub.h1Title.localeCompare(b.hub.h1Title))
  .slice(0, 12)
  .map(({ hub }) => hub);
const catalogSeries = Array.from(new Set(parts.flatMap((part) => part.series.length > 0 ? part.series : [part.engineType ?? 'serial-number verified']))).slice(0, 8);
const catalogCategories = Array.from(new Set(parts.map((part) => part.category))).slice(0, 8);
const catalogScope = hub.type === 'series'
  ? `${hub.h1Title} covers ${catalogCategories.join(', ')} and related service references.`
  : `${hub.h1Title} covers ${catalogSeries.join(', ')} and serial-number verified applications.`;
const quoteChecklist = [
  'Exact part number and quantity',
  'Engine model, rating, and serial number',
  'Nameplate photo or old-part photo when the marking is unclear',
  'Destination country, delivery deadline, and preferred shipping method',
];
const catalogUseCases = hub.type === 'series'
  ? ['Preventive maintenance list by engine serial number', 'Major overhaul quotation by category', 'Urgent downtime replacement for one confirmed part number', 'Fleet replenishment across several engines in the same series']
  : ['Bulk replenishment for repeated service items', 'Cross-series part-number verification', 'Old-stock replacement and supersession checks', 'Mixed RFQ lists from service companies or shipyards'];
---

<BaseLayout
  title={hub.title}
  description={hub.summary}
  currentPath="/products"
  jsonLd={[
    breadcrumbSchema([
      { name: 'Home', url: site.url },
      { name: 'MTU Parts Catalog', url: `${site.url}/part-products/` },
      { name: hub.h1Title, url: pageUrl },
    ]),
    itemListSchema(
      parts.slice(0, 50).map((p) => ({
        name: `${p.partNumber} ${p.name}`,
        url: `${site.url}/part-products/${p.slug}/`,
      })),
    ),
  ]}
>
  <FunnelPageView stage="selection" label={`catalog-${hub.slug}`} />
  <BreadcrumbHero
    title={hub.h1Title}
    trail={[
      { label: 'Home', href: '/' },
      { label: 'MTU Parts Catalog', href: '/part-products/' },
      { label: hub.type === 'series' ? hub.h1Title.replace(' Engine Parts', '') : hub.h1Title.replace('MTU ', '').replace(' & Seal Kits', '') },
    ]}
    variant="2"
  />

  <section class="blog-details-section resource-page-section">
    <div class="section-gap bottom">
      <div class="container">
        <article class="blog-details-content-block resource-page fade-in">
          <!-- ── Stat bar ── -->
          <div class="catalog-stat-bar">
            <div class="catalog-stat-item">
              <span class="catalog-stat-icon catalog-stat-icon--docs">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
              </span>
              <span class="catalog-stat-value">{parts.length}</span>
              <span class="catalog-stat-label">Part Numbers</span>
            </div>
            <div class="catalog-stat-item">
              <span class="catalog-stat-icon catalog-stat-icon--grid">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/></svg>
              </span>
              <span class="catalog-stat-value">{categoryGroups.size}</span>
              <span class="catalog-stat-label">{groupLabel === 'series' ? 'Categories' : 'Series'}</span>
            </div>
            <div class="catalog-stat-item">
              <span class="catalog-stat-icon catalog-stat-icon--moq">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
              </span>
              <span class="catalog-stat-value">No Min</span>
              <span class="catalog-stat-label">MOQ</span>
            </div>
            <div class="catalog-stat-item">
              <span class="catalog-stat-icon catalog-stat-icon--globe">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
              </span>
              <span class="catalog-stat-value">Global</span>
              <span class="catalog-stat-label">Delivery</span>
            </div>
          </div>

          <!-- ── RFQ strip ── -->
          <div class="detail-rfq-strip">
            <span class="catalog-rfq-strip-icon" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
            </span>
            <p><strong>Send part numbers, engine model, serial number, quantity, and destination.</strong> We check compatibility, stock, and shipping options.</p>
            <a
              href={quoteHref}
              class="detail-rfq-link"
              data-rfq-modal
              data-rfq-context={`${hub.h1Title} parts list inquiry`}
              data-rfq-source={`catalog-${hub.slug}`}
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>
              Request Parts Inquiry
            </a>
          </div>

          <h2>{hub.type === 'series' ? 'Parts by Category' : 'Parts by Engine Series'}</h2>
          <p class="catalog-intro-text">{hub.description}</p>

          {hub.longDescription && (
            <div class="catalog-long-description">
              {hub.longDescription.split('\n\n').map((p) => <p>{p.trim()}</p>)}
            </div>
          )}

          <!-- ── Scope + coverage ── -->
          <section class="catalog-depth-section">
            <h2>Catalog Scope and Fitment Method</h2>
            <p>{catalogScope} We do not treat a part number as interchangeable until the engine serial number, installation position, and any superseded reference have been checked.</p>
            <div class="catalog-info-grid">
              <article class="catalog-info-card">
                <span class="catalog-info-card-icon" aria-hidden="true">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M8.45 2.09A10 10 0 0 0 2.05 8.5"/><path d="M12 2a10 10 0 0 1 10 10"/><circle cx="12" cy="12" r="10"/></svg>
                </span>
                <h3>Included engine coverage</h3>
                <p>{catalogSeries.join(', ')}</p>
              </article>
              <article class="catalog-info-card">
                <span class="catalog-info-card-icon" aria-hidden="true">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/></svg>
                </span>
                <h3>Included part categories</h3>
                <p>{catalogCategories.join(', ')}</p>
              </article>
            </div>
          </section>

          <!-- ── Spec table ── -->
          <section class="catalog-depth-section">
            <h2>Representative Part Data</h2>
            <p>These examples show the type of fields checked before quotation: engine type, dimensions, unit weight, HS code, and stock route.</p>
            <div class="catalog-spec-table" role="table" aria-label={`${hub.h1Title} representative part data`}>
              <div class="catalog-spec-head" role="row">
                <span role="columnheader">Part No.</span>
                <span role="columnheader">Name</span>
                <span role="columnheader">Engine</span>
                <span role="columnheader">Weight</span>
                <span role="columnheader">HS Code</span>
                <span role="columnheader">Alt / NATO</span>
              </div>
              {featuredParts.map((part) => (
                <a class="catalog-spec-row" role="row" href={`/part-products/${part.slug}/`}>
                  <span role="cell" class="catalog-spec-cell-pn">{part.partNumber}</span>
                  <span role="cell">{part.name}</span>
                  <span role="cell">{part.engineType ?? (part.series.length > 0 ? part.series.join(', ') : 'Verify')}</span>
                  <span role="cell">{part.weightKg ?? '—'}</span>
                  <span role="cell">{part.hsCode ? <code class="catalog-hs-code">{part.hsCode}</code> : '—'}</span>
                  <span role="cell">{part.replacementFor?.slice(0, 2).join(', ') || part.natoNumber || 'Serial check'}</span>
                </a>
              ))}
            </div>
          </section>

          <!-- ── Verification checklist ── -->
          <section class="catalog-depth-section">
            <h2>What We Verify Before Quoting</h2>
            <div class="catalog-checklist-grid">
              {quoteChecklist.map((item, i) => (
                <article class="catalog-checklist-card">
                  <span class="catalog-checklist-step">{String(i + 1).padStart(2, '0')}</span>
                  <div class="catalog-checklist-body">
                    <h3>{item}</h3>
                    <p>Checked against part-number history, engine application, stock status, and export shipping requirements.</p>
                  </div>
                </article>
              ))}
            </div>
          </section>

          <!-- ── RFQ scenarios ── -->
          <section class="catalog-depth-section">
            <h2>Common RFQ Scenarios</h2>
            <ul class="catalog-scenarios-list">
              {catalogUseCases.map((item) => (
                <li>
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
            <p class="catalog-scenarios-note">For mixed lists, send the spreadsheet as-is. We return line-by-line availability, replacement notes, and practical shipping options instead of a generic catalog reply.</p>
          </section>

          <!-- ── Grouped part cards ── -->
          {
            Array.from(categoryGroups.entries()).map(([groupKey, groupParts]) => (
              <section class="catalog-group-section">
                <h3 class="catalog-group-title">
                  <span>{groupKey}</span>
                  <span class="catalog-group-count">{groupParts.length} parts</span>
                </h3>
                <div class="hub-grid">
                  {groupParts.slice(0, 12).map((part) => (
                    <a href={`/part-products/${part.slug}/`} class="hub-card catalog-part-card">
                      <div class="hub-card-image">
                        <img
                          src={part.image}
                          alt={part.imageAlt ?? `${part.partNumber} ${part.name}`}
                          width="320"
                          height="200"
                          loading="lazy"
                          decoding="async"
                        />
                      </div>
                      <div class="hub-card-body">
                        <p class="hub-card-meta">{part.partNumber}</p>
                        <h4 class="hub-card-title">{part.name}</h4>
                        <dl class="catalog-part-specs">
                          <div>
                            <dt>Engine</dt>
                            <dd>{part.engineType ?? (part.series.length > 0 ? part.series.join(', ') : 'Serial check')}</dd>
                          </div>
                          <div>
                            <dt>Category</dt>
                            <dd>{part.category}</dd>
                          </div>
                          <div>
                            <dt>Weight</dt>
                            <dd>{part.weightKg ?? 'Quote check'}</dd>
                          </div>
                          <div>
                            <dt>HS Code</dt>
                            <dd>{part.hsCode ?? 'Quote check'}</dd>
                          </div>
                          <div>
                            <dt>Alt Refs</dt>
                            <dd>{part.replacementFor?.slice(0, 2).join(', ') || 'Verify'}</dd>
                          </div>
                          <div>
                            <dt>Image</dt>
                            <dd>{isRealPartImage(part.image) ? 'Part photo' : 'Category image'}</dd>
                          </div>
                        </dl>
                        <p class="hub-card-summary">
                          {part.engineType ?? (part.series.length > 0 ? part.series.join(', ') : 'Serial-number verified')}
                          {part.stockStatus && ` - ${part.stockStatus.slice(0, 60)}`}
                        </p>
                      </div>
                    </a>
                  ))}
                </div>
                {groupParts.length > 12 && (
                  <p class="catalog-group-more">
                    <span class="catalog-group-more-count">+{groupParts.length - 12}</span> more {groupKey.toLowerCase()} parts —
                    <a
                      href={quoteHref}
                      data-rfq-modal
                      data-rfq-context={`${hub.h1Title} full catalog list inquiry`}
                      data-rfq-source={`catalog-${hub.slug}`}
                    >send a part list for full catalog</a>
                  </p>
                )}
              </section>
            ))
          }

          <!-- Related catalog hubs -->
          <hr class="catalog-divider" />
          <h2>Browse More MTU Parts Catalogs</h2>
          <div class="hub-grid">
            {relatedCatalogHubs.map((h) => (
                <a href={`/part-products/catalog/${h.slug}/`} class="hub-card catalog-related-card">
                  <div class="hub-card-body">
                    <span class="catalog-related-badge">{h.type === 'series' ? 'Engine Series' : 'Parts Category'}</span>
                    <h4 class="hub-card-title">{h.h1Title}</h4>
                    <p class="hub-card-summary">{h.summary}</p>
                  </div>
                </a>
              ))}
          </div>

          <!-- ── Footer links ── -->
          <div class="catalog-footer-links">
            <a href="/part-products/" class="catalog-footer-link">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
              All Part Numbers
            </a>
            <span class="catalog-footer-sep" aria-hidden="true">/</span>
            <a href="/products/mtu-spare-parts/" class="catalog-footer-link">MTU Spare Parts</a>
            <span class="catalog-footer-sep" aria-hidden="true">/</span>
            <a
              href={quoteHref}
              class="catalog-footer-link catalog-footer-link--cta"
              data-rfq-modal
              data-rfq-context={`${hub.h1Title} parts inquiry`}
              data-rfq-source={`catalog-${hub.slug}`}
            >Request Parts Inquiry</a>
          </div>
        </article>
      </div>
    </div>
  </section>

  <BlogCta
    stage="selection"
    topic={`catalog-${hub.slug}`}
    title="Ready to check engine parts?"
    text="Send part numbers, engine model, serial number, quantity, and destination. We confirm availability before quotation."
    primaryLabel="Send Parts Inquiry"
    primaryHref={quoteHref}
    primaryEvent={`catalog_${hub.slug}_rfq`}
    useRfqModal
    rfqContext={`${hub.h1Title} parts inquiry`}
    rfqSource={`catalog-${hub.slug}`}
    secondaryLabel="All part numbers"
    secondaryHref="/part-products/"
    secondaryEvent="catalog_all_parts"
  />
</BaseLayout>

<style>
  /* ── Stat bar ── */
  .catalog-stat-bar {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
    margin-bottom: 24px;
  }

  .catalog-stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    padding: 18px 12px 16px;
    background: var(--color-white);
    border: 1px solid var(--color-stroke);
    border-radius: 8px;
    text-align: center;
  }

  .catalog-stat-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 12px;
    flex-shrink: 0;
  }

  .catalog-stat-icon--docs { background: rgba(20, 110, 245, 0.08); color: var(--color-primary); }
  .catalog-stat-icon--grid { background: rgba(16, 185, 129, 0.1); color: #059669; }
  .catalog-stat-icon--moq { background: rgba(245, 158, 11, 0.1); color: #d97706; }
  .catalog-stat-icon--globe { background: rgba(139, 92, 246, 0.1); color: #7c3aed; }

  .catalog-stat-value {
    font-family: var(--font-title);
    font-size: 22px;
    font-weight: 700;
    line-height: 1.2;
    color: var(--color-title);
  }

  .catalog-stat-label {
    font-size: 12px;
    font-weight: 600;
    color: #64748b;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* ── RFQ strip ── */
  .detail-rfq-strip {
    margin-bottom: 24px;
  }

  .catalog-rfq-strip-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 42px;
    height: 42px;
    border-radius: 12px;
    background: linear-gradient(135deg, rgba(20, 110, 245, 0.12), rgba(20, 110, 245, 0.06));
    color: var(--color-primary);
    flex-shrink: 0;
  }

  .detail-rfq-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    min-height: 44px;
    padding: 10px 22px;
    background: linear-gradient(135deg, #146ef5, #0d5ad4);
    color: #fff;
    font-weight: 600;
    font-size: 14px;
    text-decoration: none;
    border-radius: 8px;
    white-space: nowrap;
    transition: opacity 0.2s ease, transform 0.15s ease, box-shadow 0.2s ease;
    -webkit-tap-highlight-color: transparent;
    box-shadow: 0 2px 8px rgba(20, 110, 245, 0.2);
  }

  .detail-rfq-link:hover {
    opacity: 0.94;
    box-shadow: 0 4px 16px rgba(20, 110, 245, 0.3);
    transform: translateY(-1px);
  }

  .detail-rfq-link:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 3px;
    border-radius: 8px;
  }

  .catalog-intro-text {
    font-size: 16px;
    line-height: 1.65;
    color: #475569;
    margin: 0 0 8px;
  }

  /* ── Info cards (scope) ── */
  .catalog-depth-section {
    margin: 32px 0;
  }

  .catalog-info-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
    margin-top: 16px;
  }

  .catalog-info-card {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 22px;
    background: var(--color-white);
    border: 1px solid var(--color-stroke);
    border-radius: 10px;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .catalog-info-card:hover {
    border-color: rgba(20, 110, 245, 0.25);
    box-shadow: 0 2px 12px rgba(20, 110, 245, 0.06);
  }

  .catalog-info-card-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 8px;
    background: rgba(20, 110, 245, 0.07);
    color: var(--color-primary);
  }

  .catalog-info-card h3 {
    font-size: 14px;
    font-weight: 600;
    color: var(--color-title);
    margin: 0;
    text-transform: none;
  }

  .catalog-info-card p {
    font-size: 14px;
    line-height: 1.6;
    color: #475569;
    margin: 0;
  }

  /* ── Checklist (step numbers) ── */
  .catalog-checklist-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 14px;
    margin-top: 16px;
  }

  .catalog-checklist-card {
    display: flex;
    gap: 14px;
    padding: 20px;
    background: var(--color-white);
    border: 1px solid var(--color-stroke);
    border-radius: 10px;
    transition: border-color 0.2s ease;
  }

  .catalog-checklist-card:hover {
    border-color: rgba(20, 110, 245, 0.2);
  }

  .catalog-checklist-step {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 10px;
    background: rgba(20, 110, 245, 0.08);
    font-family: var(--font-title);
    font-size: 14px;
    font-weight: 700;
    color: var(--color-primary);
    flex-shrink: 0;
  }

  .catalog-checklist-body h3 {
    font-size: 14px;
    font-weight: 600;
    color: var(--color-title);
    margin: 0 0 4px;
  }

