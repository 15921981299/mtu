---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BreadcrumbHero from '../../components/BreadcrumbHero.astro';
import FunnelPageView from '../../components/FunnelPageView.astro';
import { mtuPartCategories, mtuParts, mtuPartSeries } from '../../data/mtu-parts';
import { breadcrumbSchema, itemListSchema, site } from '../../data/site';
import '../../styles/resource-page.css';

const pageUrl = `${site.url}/part-products/`;
---

<BaseLayout
  title="MTU Parts Catalog by Part Number | Engine Family"
  description="Browse MTU spare parts by part number, category, and engine series. Check availability for sensors, gaskets, fuel parts, turbochargers, cooling parts, and overhaul items."
  currentPath="/products"
  jsonLd={[
    breadcrumbSchema([
      { name: 'Home', url: site.url },
      { name: 'MTU Parts Catalog', url: pageUrl },
    ]),
    itemListSchema(mtuParts.map((part) => ({ name: `${part.partNumber} ${part.name}`, url: `${site.url}/part-products/${part.slug}/` }))),
  ]}
>
  <FunnelPageView stage="selection" label="mtu-part-products-index" />
  <BreadcrumbHero
    title="MTU Parts<br>Catalog"
    trail={[
      { label: 'Home', href: '/' },
      { label: 'MTU Parts Catalog' },
    ]}
    variant="2"
  />

  <section class="blog-details-section resource-page-section">
    <div class="section-gap bottom">
      <div class="container">
        <article class="blog-details-content-block resource-page fade-in">
          <nav class="resource-nav" aria-label="Parts catalog navigation">
            <a href="/part-products/" class="resource-nav-link active" aria-current="page">Part numbers</a>
            <a href="/products/mtu-spare-parts/" class="resource-nav-link">MTU spare parts</a>
            <a href="/products/mtu-2000-series-parts/" class="resource-nav-link">MTU 2000</a>
            <a href="/products/mtu-4000-series-parts/" class="resource-nav-link">MTU 4000</a>
            <a href="/contact/" class="resource-nav-link resource-nav-all">Check availability</a>
          </nav>

          <p class="resource-intro">
            Searchable MTU part-number pages help procurement teams move from a loose request to a verified quotation.
            Send the part number, engine model, serial number, nameplate photo, quantity, destination, and required
            delivery date so Engine Family can check compatibility before shipment.
          </p>

          <div class="resource-meta">
            <span><strong>{mtuParts.length}</strong> MTU part-number pages</span>
            <span><strong>{mtuPartCategories.length}</strong> part categories</span>
            <span>{mtuPartSeries.join(' · ')}</span>
          </div>

          <div class="detail-rfq-strip">
            <p>Have an Excel list? Send all part numbers together. We check availability line by line and quote practical shipping from Shanghai.</p>
            <a href="/contact/?source=part-products" class="detail-rfq-link">Send Parts List</a>
          </div>

          <section class="hub-section">
            <header class="hub-section-header">
              <h2>MTU Part Numbers</h2>
              <p>Sensors, fuel-system parts, gaskets, cooling parts, turbocharging parts, repair kits, and overhaul components.</p>
            </header>
            <div class="hub-grid part-products-grid">
              {mtuParts.map((part) => (
                <article class="hub-card">
                  <div class="hub-card-body">
                    <p class="hub-card-meta">{part.category} · {part.series.join(', ')}</p>
                    <h3 class="hub-card-title">
                      <a href={`/part-products/${part.slug}/`}>{part.partNumber} {part.name}</a>
                    </h3>
                    <p class="hub-card-summary">{part.summary}</p>
                    <a href={`/part-products/${part.slug}/`} class="hub-card-link">View part →</a>
                  </div>
                </article>
              ))}
            </div>
          </section>

          <div class="resource-note">
            Confirm MTU replacement parts with serial number and old-part photos before purchase.
          </div>
        </article>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .part-products-grid {
    grid-template-columns: repeat(3, 1fr);
  }

  @media (max-width: 991px) {
    .part-products-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .part-products-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
