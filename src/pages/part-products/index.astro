---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BreadcrumbHero from '../../components/BreadcrumbHero.astro';
import FunnelPageView from '../../components/FunnelPageView.astro';
import { mtuPartCategories, mtuParts, mtuPartSeries, mtuCatalogHubs } from '../../data/mtu-parts';

const seriesHubs = mtuCatalogHubs.filter((h) => h.type === 'series');
const categoryHubs = mtuCatalogHubs.filter((h) => h.type === 'category');
import { breadcrumbSchema, itemListSchema, site } from '../../data/site';
import '../../styles/resource-page.css';

const pageUrl = `${site.url}/part-products/`;
const isRealPartImage = (image: string) => image.includes('/diesel-part-source-parts/');
const priorityParts = [...mtuParts]
  .filter((part) => isRealPartImage(part.image) && part.weightKg && part.hsCode)
  .sort((a, b) => {
    const bScore =
      Number(Boolean(b.replacementFor?.length)) +
      Number(Boolean(b.applicableEngines)) +
      Number(Boolean(b.commonFailureScenarios?.length));
    const aScore =
      Number(Boolean(a.replacementFor?.length)) +
      Number(Boolean(a.applicableEngines)) +
      Number(Boolean(a.commonFailureScenarios?.length));
    return bScore - aScore || a.partNumber.localeCompare(b.partNumber);
  })
  .slice(0, 60);
---

<BaseLayout
  title="MTU Parts Catalog by Part Number | Diesel Part Source"
  description="Browse MTU spare parts by part number, category, and engine series. Check availability for sensors, gaskets, fuel parts, turbochargers, cooling parts, and overhaul items."
  currentPath="/products"
  jsonLd={[
    breadcrumbSchema([
      { name: 'Home', url: site.url },
      { name: 'MTU Parts Catalog', url: pageUrl },
    ]),
    itemListSchema(mtuParts.map((part) => ({ name: `${part.partNumber} ${part.name}`, url: `${site.url}/part-products/${part.slug}/` }))),
  ]}
>
  <FunnelPageView stage="selection" label="mtu-part-products-index" />
  <BreadcrumbHero
    title="MTU Parts<br>Catalog"
    trail={[
      { label: 'Home', href: '/' },
      { label: 'MTU Parts Catalog' },
    ]}
    variant="2"
  />

  <section class="blog-details-section resource-page-section">
    <div class="section-gap bottom">
      <div class="container">
        <article class="blog-details-content-block resource-page fade-in">
          <nav class="resource-nav" aria-label="Parts catalog navigation">
            <a href="/part-products/" class="resource-nav-link active" aria-current="page">All Part Numbers</a>
            <a href="/products/mtu-spare-parts/" class="resource-nav-link">MTU Spare Parts</a>
            <a
              href="/contact/?source=part-products-nav"
              class="resource-nav-link resource-nav-all"
              data-rfq-modal
              data-rfq-context="MTU parts catalog availability check"
              data-rfq-source="part-products-nav"
            >Check Availability →</a>
          </nav>

          <p class="resource-intro">
            Browse MTU parts by engine series, part category, or individual part number. Each part page includes cross-references, applicable engine models, stock status, and ordering notes. Send your part list for line-by-line availability check and quotation.
          </p>

          <div class="resource-meta">
            <span><strong>{mtuParts.length}</strong> part numbers</span>
            <span><strong>{seriesHubs.length}</strong> engine series</span>
            <span><strong>{categoryHubs.length}</strong> part categories</span>
          </div>

          <!-- Browse by Engine Series -->
          <h2 style="margin-top: 36px;">Browse by Engine Series</h2>
          <div class="hub-grid part-products-grid">
            {seriesHubs.map((hub) => (
              <article class="hub-card">
                <div class="hub-card-body">
                  <h3 class="hub-card-title">
                    <a href={`/part-products/catalog/${hub.slug}/`}>{hub.h1Title}</a>
                  </h3>
                  <p class="hub-card-summary">{hub.summary}</p>
                  <a href={`/part-products/catalog/${hub.slug}/`} class="hub-card-link">Browse parts →</a>
                </div>
              </article>
            ))}
          </div>

          <!-- Browse by Category -->
          <h2 style="margin-top: 36px;">Browse by Part Category</h2>
          <div class="hub-grid part-products-grid">
            {categoryHubs.map((hub) => (
              <article class="hub-card">
                <div class="hub-card-body">
                  <h3 class="hub-card-title">
                    <a href={`/part-products/catalog/${hub.slug}/`}>{hub.h1Title}</a>
                  </h3>
                  <p class="hub-card-summary">{hub.summary}</p>
                  <a href={`/part-products/catalog/${hub.slug}/`} class="hub-card-link">Browse parts →</a>
                </div>
              </article>
            ))}
          </div>

          <div class="detail-rfq-strip" style="margin-top: 36px;">
            <p>Have an Excel list? Send all part numbers together. We check availability line by line and quote practical shipping from Shanghai.</p>
            <a
              href="/contact/?source=part-products"
              class="detail-rfq-link"
              data-rfq-modal
              data-rfq-context="MTU Excel parts list inquiry"
              data-rfq-source="part-products"
            >Send Parts List</a>
          </div>

          <section class="hub-section priority-parts-section" style="margin-top: 36px;">
            <header class="hub-section-header">
              <h2>Priority MTU Parts with Real Data</h2>
              <p>High-value part pages using imported real part images, unit weight, HS code, replacement references, and fitment notes.</p>
            </header>
            <div class="priority-parts-grid">
              {priorityParts.map((part) => (
                <a href={`/part-products/${part.slug}/`} class="priority-part-card">
                  <div class="priority-part-media">
                    <img
                      src={part.image}
                      alt={part.imageAlt ?? `${part.partNumber} ${part.name}`}
                      width="220"
                      height="160"
                      loading="lazy"
                      decoding="async"
                    />
                  </div>
                  <div class="priority-part-body">
                    <span class="priority-part-number">{part.partNumber}</span>
                    <strong>{part.name}</strong>
                    <dl>
                      <div><dt>Engine</dt><dd>{part.engineType ?? (part.series.length > 0 ? part.series.join(', ') : 'Serial check')}</dd></div>
                      <div><dt>Weight</dt><dd>{part.weightKg}</dd></div>
                      <div><dt>HS</dt><dd>{part.hsCode}</dd></div>
                      <div><dt>Alt</dt><dd>{part.replacementFor?.slice(0, 2).join(', ') || 'Check by serial'}</dd></div>
                    </dl>
                  </div>
                </a>
              ))}
            </div>
          </section>

          <!-- All Part Numbers -->
          <section class="hub-section" style="margin-top: 36px;">
            <header class="hub-section-header">
              <h2>All MTU Part Numbers (A-Z)</h2>
              <p>Complete index of {mtuParts.length} part number pages across {mtuPartCategories.length} categories and {mtuPartSeries.length} engine series.</p>
            </header>
            <div class="hub-grid part-products-grid">
              {mtuParts.map((part) => (
                <article class="hub-card">
                  <div class="hub-card-body">
                    <p class="hub-card-meta">{part.category} · {part.series.join(', ')}</p>
                    <h3 class="hub-card-title">
                      <a href={`/part-products/${part.slug}/`}>{part.partNumber} {part.name}</a>
                    </h3>
                    <p class="hub-card-summary">{part.summary}</p>
                    <a href={`/part-products/${part.slug}/`} class="hub-card-link">View part →</a>
                  </div>
                </article>
              ))}
            </div>
          </section>

          <div class="resource-note">
            Confirm MTU replacement parts with serial number and old-part photos before purchase.
          </div>
        </article>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .part-products-grid {
    grid-template-columns: repeat(3, 1fr);
  }

  .priority-parts-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 12px;
  }

  .priority-part-card {
    display: grid;
    grid-template-columns: 96px minmax(0, 1fr);
    gap: 12px;
    padding: 12px;
    border: 1px solid var(--color-stroke);
    border-radius: 8px;
    background: #fff;
    color: inherit;
    text-decoration: none;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .priority-part-card:hover {
    border-color: var(--color-primary);
    box-shadow: 0 10px 24px rgba(15, 23, 42, 0.08);
  }

  .priority-part-card:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 3px;
  }

  .priority-part-media {
    aspect-ratio: 1 / 1;
    border: 1px solid #e2e8f0;
    border-radius: 6px;
    overflow: hidden;
    background: #f8fafc;
  }

  .priority-part-media img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }

  .priority-part-body {
    min-width: 0;
    display: grid;
    gap: 5px;
  }

  .priority-part-number {
    font-family: var(--font-title);
    font-size: 13px;
    font-weight: 800;
    color: var(--color-primary);
    overflow-wrap: anywhere;
  }

  .priority-part-body strong {
    font-size: 13px;
    line-height: 1.3;
    color: #0f172a;
  }

  .priority-part-body dl {
    display: grid;
    gap: 3px;
    margin: 0;
  }

  .priority-part-body dl div {
    display: grid;
    grid-template-columns: 46px minmax(0, 1fr);
    gap: 4px;
  }

  .priority-part-body dt,
  .priority-part-body dd {
    margin: 0;
    font-size: 11px;
    line-height: 1.35;
    overflow-wrap: anywhere;
  }

  .priority-part-body dt {
    color: #64748b;
    font-weight: 800;
    text-transform: uppercase;
  }

  .priority-part-body dd {
    color: #334155;
  }

  @media (max-width: 991px) {
    .part-products-grid,
    .priority-parts-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .part-products-grid,
    .priority-parts-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 480px) {
    .priority-part-card {
      grid-template-columns: 82px minmax(0, 1fr);
    }
  }
</style>
