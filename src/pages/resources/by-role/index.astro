---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import BreadcrumbHero from '../../../components/BreadcrumbHero.astro';
import BlogCta from '../../../components/BlogCta.astro';
import FunnelPageView from '../../../components/FunnelPageView.astro';
import ResourceNav from '../../../components/ResourceNav.astro';
import { roleHubs } from '../../../data/role-hubs';
import { breadcrumbSchema, site } from '../../../data/site';
import '../../../styles/resource-page.css';

const totalLinks = roleHubs.reduce((sum, hub) => sum + hub.links.length, 0);
---

<BaseLayout
  title="Engine Parts Resources by Buyer Role | Engine Family"
  description="MTU and diesel engine parts resources for maintenance engineers, procurement teams, and quality/documentation buyers."
  currentPath="/resources/by-role"
  jsonLd={breadcrumbSchema([
    { name: 'Home', url: site.url },
    { name: 'Resources', url: `${site.url}/resources/` },
    { name: 'By Buyer Role', url: `${site.url}/resources/by-role/` },
  ])}
>
  <FunnelPageView stage="service" label="role-hubs-index" />
  <BreadcrumbHero
    title="Resources by Buyer Role"
    trail={[
      { label: 'Home', href: '/' },
      { label: 'Resources', href: '/resources/' },
      { label: 'By Role' },
    ]}
    variant="1"
  />

  <section class="blog-details-section resource-page-section">
    <div class="section-gap bottom">
      <div class="container">
        <article class="blog-details-content-block resource-page fade-in">
          <ResourceNav active="by-role" />

          <p class="resource-intro">
            Engine parts orders often involve maintenance engineers, procurement, and quality teams. Pick the path that matches your role and send the right information first.
          </p>

          <div class="resource-meta">
            <span><strong>{roleHubs.length}</strong> buyer paths</span>
            <span><strong>{totalLinks}</strong> curated links</span>
            <span>Select your <strong>role</strong> below</span>
          </div>

          <div class="detail-rfq-strip">
            <p>Pick your role path below — each hub includes a parts inquiry checklist so Engine Family can verify fitment, stock, documents, and delivery faster.</p>
            <a href="/contact/?source=role-hubs" class="detail-rfq-link">Send Parts Inquiry</a>
          </div>

          <div class="resource-checklist-grid">
            {roleHubs.map((hub, index) => (
              <section
                class:list={[
                  'resource-checklist-card',
                  { 'resource-checklist-card--full': index === roleHubs.length - 1 && roleHubs.length % 2 === 1 },
                ]}
              >
                <h2>
                  <a href={`/resources/by-role/${hub.slug}/`}>{hub.title}</a>
                </h2>
                <p class="role-hub-headline">{hub.headline}</p>
                <ul class="resource-list">
                  {hub.links.slice(0, 4).map((link) => (
                    <li>
                      <a href={link.href}>{link.label}</a>
                    </li>
                  ))}
                </ul>
                <a href={`/resources/by-role/${hub.slug}/`} class="role-hub-more">
                  View all {hub.links.length} guides →
                </a>
              </section>
            ))}
          </div>

          <div class="resource-note">
            <strong>Buyer tip:</strong> Send part numbers, engine serial numbers, old-part photos, quantity, destination, and required delivery date in the first message.
          </div>

          <p class="resource-related">
            <a href="/resources/">All parts resources</a>
            <span aria-hidden="true">·</span>
            <a href="/part-products/">MTU part numbers</a>
            <span aria-hidden="true">·</span>
            <a href="/resources/inspection-samples/">Inspection samples</a>
            <span aria-hidden="true">·</span>
            <a href="/blog/guides/">Guide hubs</a>
          </p>
        </article>
      </div>
    </div>
  </section>

  <BlogCta
    stage="service"
    topic="role-hubs-index"
    title="Send the right parts inquiry package"
    text="Use the checklist from your role hub: part number, engine details, photos, quantity, destination, and documents needed."
    primaryLabel="Send Inquiry"
    primaryHref="/contact/?source=role-hubs"
    primaryEvent="role_hubs_rfq"
    secondaryLabel="MTU part numbers"
    secondaryHref="/part-products/"
    secondaryEvent="role_hubs_dfm"
  />
</BaseLayout>

<style>
  .resource-checklist-card h2 a {
    color: var(--color-title);
    text-decoration: none;
    cursor: pointer;
    transition: color 0.2s ease;
  }

  .resource-checklist-card h2 a:hover {
    color: var(--color-primary);
  }

  .resource-checklist-card h2 a:focus-visible,
  .role-hub-more:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
    border-radius: 4px;
  }

  .role-hub-headline {
    margin: 0 0 12px;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-primary);
  }

  .role-hub-more {
    margin-top: 4px;
    font-size: 14px;
    font-weight: 600;
    color: var(--color-primary);
    text-decoration: none;
    cursor: pointer;
    transition: color 0.2s ease;
  }

  .role-hub-more:hover {
    text-decoration: underline;
  }
</style>
