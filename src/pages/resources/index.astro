const resources = [
  {
    slug: 'material-certificates',
    title: 'MTU Part Number Lookup',
    summary: 'How to send an MTU part number, engine serial number, nameplate photo, and old part photo for compatibility verification.',
    href: '/products/mtu-spare-parts/mtu-part-number-lookup/',
    featured: true,
  },
  {
    slug: 'inspection-samples',
    title: 'MTU Engine Series Guide',
    summary: 'Series coverage for MTU 183, 331, 396, 493, 538, 595, 956, 1163, 2000, 4000, and 8000 engine parts.',
    href: '/products/mtu-spare-parts/mtu-engine-series-guide/',
    featured: true,
  },
  {
    slug: 'process-selection',
    title: 'MTU 2000 Marine & Generator Parts',
    summary: 'Service, fuel, cooling, lubrication, electrical, and overhaul parts for MTU 2000 series marine and generator applications.',
    href: '/products/mtu-2000-series-parts/marine-generator-service-parts/',
  },
  {
    slug: 'hardness-conversion-chart',
    title: 'MTU 4000 Overhaul Parts',
    summary: 'Overhaul categories for MTU 4000 series engines: pistons, liners, bearings, valves, gaskets, fuel, cooling, and turbocharging parts.',
    href: '/products/mtu-4000-series-parts/overhaul-parts/',
  },
  {
    slug: 'by-role',
    title: 'Cummins Service Kits & Overhaul Parts',
    summary: 'What to provide for Cummins parts inquiries, including model, CPL, serial number, part number, quantity, and application.',
    href: '/products/cummins-parts/service-kits-and-overhaul-parts/',
  },
  {
    slug: 'metal-weight-calculator',
    title: 'DEUTZ Industrial Equipment Parts',
    summary: 'DEUTZ parts for construction equipment, compressors, pumps, power units, and industrial maintenance programs.',
    href: '/products/deutz-parts/industrial-equipment-parts/',
  },
  {
    slug: 'cnc-pricing-guide',
    title: 'Parts Inquiry Checklist',
    summary: 'A practical checklist for part number, engine serial, old part photos, quantity, destination, and required delivery date.',
    href: '/contact/?source=resources-checklist',
    featured: true,
  },
];

const featuredCount = resources.filter((r) => r.featured).length;
---

<BaseLayout
  title="Diesel Engine Parts Resources — MTU, Cummins & DEUTZ Guides"
  description="Engine parts resources for MTU, Cummins, DEUTZ, and Detroit Diesel buyers: part-number lookup, engine series guides, service kits, overhaul parts, and inquiry checklist."
  currentPath="/resources"
  jsonLd={breadcrumbSchema([
    { name: 'Home', url: site.url },
    { name: 'Resources', url: `${site.url}/resources/` },
  ])}
>
  <FunnelPageView stage="service" label="resources-index" />
  <BreadcrumbHero
    title="Engineering Resources"
    trail={[
      { label: 'Home', href: '/' },
      { label: 'Resources' },
    ]}
    variant="1"
  />

  <section class="blog-details-section resource-page-section">
    <div class="section-gap bottom">
      <div class="container">
        <article class="blog-details-content-block resource-page fade-in">
          <ResourceNav active="resources-index" />

          <p class="resource-intro">
            Engine parts resources for procurement, fleet maintenance, shipyards, generator operators, and repair companies. Start with the part number or engine series guide, then send your list for availability confirmation.
          </p>

          <div class="resource-meta">
            <span><strong>{resources.length}</strong> parts guides</span>
            <span><strong>{featuredCount}</strong> featured</span>
            <span>MTU · Cummins · DEUTZ</span>
            <span>Part number · <strong>serial number</strong></span>
          </div>

          <div class="detail-rfq-strip">
            <p>Send your part list, engine model, serial number, quantity, and destination. We check compatibility, stock, and shipping options.</p>
            <a href="/contact/?source=resources-index" class="detail-rfq-link">Send Parts Inquiry</a>
          </div>

          <div class="hub-grid resources-hub-grid">
            {resources.map((r) => (
              <article class:list={['hub-card', { featured: r.featured }]}>
                {r.featured && <span class="hub-featured-badge">Featured</span>}
                <span class="hub-card-icon" set:html={resourceIcons[r.slug]} />
                <div class="hub-card-body">
                  <h2 class="hub-card-title">
                    <a href={r.href ?? `/resources/${r.slug}/`}>{r.title}</a>
                  </h2>
                  <p class="hub-card-summary">{r.summary}</p>
                  <a href={r.href ?? `/resources/${r.slug}/`} class="hub-card-link">
                    Open guide →
                  </a>
                </div>
              </article>
            ))}
          </div>

          <div class="resource-note">
            <strong>Procurement tip:</strong> For urgent downtime orders, include the engine nameplate photo and destination city in the first message. It shortens part verification and freight checking.
          </div>

          <p class="resource-related">
            <a href="/products/mtu-spare-parts/">MTU spare parts</a>
            <span aria-hidden="true">·</span>
            <a href="/products/cummins-parts/">Cummins parts</a>
            <span aria-hidden="true">·</span>
            <a href="/products/deutz-parts/">DEUTZ parts</a>
            <span aria-hidden="true">·</span>
            <a href="/terms/payment/">Payment &amp; shipping terms</a>
          </p>
        </article>
      </div>
    </div>
  </section>

  <BlogCta
    stage="service"
    topic="resources-index"
    title="Ready to check engine parts?"
    text="Send part numbers, engine model, serial number, quantity, and destination. We confirm availability before quotation."
    primaryLabel="Send Parts Inquiry"
    primaryHref="/contact/?source=resources-index"
    primaryEvent="resources_index_rfq"
    secondaryLabel="MTU lookup"
    secondaryHref="/products/mtu-spare-parts/mtu-part-number-lookup/"
    secondaryEvent="resources_index_inspection"
  />
</BaseLayout>

<style>
  .resources-hub-grid {
    grid-template-columns: repeat(2, 1fr);
  }

  .hub-card.featured {
    position: relative;
  }

  .resources-hub-grid .hub-card-icon {
    color: var(--color-primary);
  }

  @media (max-width: 768px) {
    .resources-hub-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
