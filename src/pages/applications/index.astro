---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BreadcrumbHero from '../../components/BreadcrumbHero.astro';
import BlogCta from '../../components/BlogCta.astro';
import FunnelPageView from '../../components/FunnelPageView.astro';
import { applications } from '../../data/applications';
import { breadcrumbSchema, site } from '../../data/site';
import '../../styles/resource-page.css';

const applicationIcons: Record<string, string> = {
  'motor-drive-components': `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 6v6l4 2M21 12a9 9 0 11-18 0 9 9 0 0118 0z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>`,
  'fluid-handling-components': `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 2.69l5.66 5.66a8 8 0 11-11.32 0L12 2.69z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>`,
  'structural-mounting-components': `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M4 20h16M6 20V8l6-4 6 4v12M10 12h4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  'enclosure-housing-components': `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>`,
  'wear-bearing-components': `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.5"/><circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="1.5"/></svg>`,
  'ev-battery-components': `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="2" y="7" width="18" height="10" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M22 11v2M6 11v2M10 11v2M14 11v2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>`,
  'medical-instrument-components': `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 8v8M8 12h8M21 12a9 9 0 11-18 0 9 9 0 0118 0z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>`,
  'aerospace-structural-components': `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  'robotics-automation-components': `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 8V4H8M12 8h4M12 8v4M8 12H4M8 12v4M12 16h4M12 16v4M16 12h4M16 12V8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  'semiconductor-equipment-components': `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="4" y="4" width="16" height="16" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M9 9h6v6H9zM4 12h4M16 12h4M12 4v4M12 16v4" stroke="currentColor" stroke-width="1.5"/></svg>`,
};

const defaultAppIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" stroke="currentColor" stroke-width="1.5"/><path d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" stroke="currentColor" stroke-width="1.5"/></svg>`;
---

<BaseLayout
  title="Engine Parts by Application — Marine, Generator, Industrial & Rail"
  description="Browse diesel engine parts by application: marine propulsion, auxiliary generators, industrial equipment, rail, shipyard overhaul, and power plant engines."
  currentPath="/applications"
  jsonLd={breadcrumbSchema([
    { name: 'Home', url: site.url },
    { name: 'Engine Parts by Application', url: `${site.url}/applications/` },
  ])}
>
  <FunnelPageView stage="selection" label="applications-index" />
  <BreadcrumbHero
    title="Engine Parts by<br>Application"
    trail={[
      { label: 'Home', href: '/' },
      { label: 'Applications' },
    ]}
    variant="2"
  />

  <section class="blog-details-section resource-page-section">
    <div class="section-gap bottom">
      <div class="container">
        <article class="blog-details-content-block resource-page fade-in">
          <nav class="resource-nav" aria-label="Applications navigation">
            <a href="/applications/" class="resource-nav-link active" aria-current="page">
              All applications
            </a>
            <a href="/applications/marine-propulsion-engines/" class="resource-nav-link">Marine</a>
            <a href="/applications/auxiliary-generator-engines/" class="resource-nav-link">Generators</a>
            <a href="/applications/industrial-equipment-engines/" class="resource-nav-link">Industrial</a>
            <a href="/products/" class="resource-nav-link resource-nav-all">Products</a>
          </nav>

          <p class="resource-intro">
            Find diesel engine parts by operating application. Diesel Part Source supports marine propulsion, auxiliary generators, industrial equipment, rail, shipyard repair, and power generation users with part-number verification and global delivery.
          </p>

          <div class="resource-meta">
            <span><strong>{applications.length}</strong> application paths</span>
            <span>Linked to <strong>engine parts</strong></span>
            <span>Marine · Industrial · Power</span>
          </div>

          <div class="detail-rfq-strip">
            <p>Send your application, engine model, serial number, part list, quantity, and destination. We verify parts before quotation.</p>
            <a href="/contact/?source=applications" class="detail-rfq-link">Send Parts Inquiry</a>
          </div>

          <div class="hub-grid">
            {applications.map((app) => (
              <article class="hub-card">
                <span class="hub-card-icon" set:html={applicationIcons[app.slug] ?? defaultAppIcon} />
                <div class="hub-card-body">
                  <h2 class="hub-card-title">
                    <a href={`/applications/${app.slug}/`}>{app.title}</a>
                  </h2>
                  <p class="hub-card-summary">{app.summary}</p>
                  <a href={`/applications/${app.slug}/`} class="hub-card-link">
                    View application →
                  </a>
                </div>
              </article>
            ))}
          </div>

          <div class="resource-note">
            <strong>Selection tip:</strong> Cross-check the engine application with
            <a href="/products/">parts hubs</a>
            and
            <a href="/products/mtu-spare-parts/mtu-engine-series-guide/">MTU series guide</a>
            before ordering.
          </div>

          <p class="resource-related">
            <a href="/products/">Engine parts</a>
            <span aria-hidden="true">·</span>
            <a href="/products/mtu-spare-parts/">MTU parts</a>
            <span aria-hidden="true">·</span>
            <a href="/products/cummins-parts/">Cummins parts</a>
            <span aria-hidden="true">·</span>
            <a href="/contact/">Contact</a>
          </p>
        </article>
      </div>
    </div>
  </section>

  <BlogCta
    stage="selection"
    topic="applications-index"
    title="Check parts for your engine application"
    text="Send your part list, engine model, serial number, quantity, and destination. We verify compatibility before quotation."
    primaryLabel="Send Parts Inquiry"
    primaryHref="/contact/?source=applications"
    primaryEvent="applications_index_rfq"
    secondaryLabel="Engine parts"
    secondaryHref="/products/"
    secondaryEvent="applications_index_products"
  />
</BaseLayout>
