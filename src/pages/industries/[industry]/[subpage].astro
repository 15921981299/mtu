---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import BreadcrumbHero from '../../../components/BreadcrumbHero.astro';
import BlogCta from '../../../components/BlogCta.astro';
import DetailPageShell from '../../../components/DetailPageShell.astro';
import DetailRfqStrip from '../../../components/DetailRfqStrip.astro';
import FunnelPageView from '../../../components/FunnelPageView.astro';
import { industrySubpages } from '../../../data/industry-subpages';
import { isSubpageNoindex } from '../../../data/subpage-quality';
import { industries } from '../../../data/industries';
import { breadcrumbSchema, site } from '../../../data/site';
import '../../../styles/resource-page.css';

export function getStaticPaths() {
  return industrySubpages.map((sp) => ({ params: { industry: sp.industrySlug, subpage: sp.slug }, props: { subpage: sp } }));
}

const { subpage } = Astro.props;
const parent = industries.find((i) => i.slug === subpage.industrySlug);
const parentTitle = parent?.title ?? subpage.industrySlug;
const pageUrl = `${site.url}/industries/${subpage.industrySlug}/${subpage.slug}/`;
const funnelLabel = `industry-sub-${subpage.slug}`;
const quoteHref = `/contact/?source=${funnelLabel}`;
const noindex = isSubpageNoindex(subpage.industrySlug, subpage.slug);
---

<BaseLayout
  title={subpage.seoTitle}
  description={subpage.summary}
  currentPath="/industries"
  noindex={noindex}
  jsonLd={breadcrumbSchema([
    { name: 'Home', url: site.url },
    { name: 'Industries', url: `${site.url}/industries/` },
    { name: parentTitle, url: `${site.url}/industries/${subpage.industrySlug}/` },
    { name: subpage.title, url: pageUrl },
  ])}
>
  <FunnelPageView stage="selection" label={funnelLabel} />
  <BreadcrumbHero
    title={subpage.h1Title}
    trail={[
      { label: 'Home', href: '/' },
      { label: 'Industries', href: '/industries/' },
      { label: parentTitle, href: `/industries/${subpage.industrySlug}/` },
      { label: subpage.title },
    ]}
    variant="2"
  />

  <DetailPageShell intro={subpage.summary}>
    <div class="resource-meta" aria-label="Industry subpage facts">
      <span><strong>{parentTitle}</strong> focus</span>
      <span><strong>Docs</strong> Traceability on request</span>
      <span><strong>MOQ</strong> No minimum</span>
    </div>

    <DetailRfqStrip
      quoteHref={quoteHref}
      title={`Quote ${parentTitle.toLowerCase()} parts`}
      text="State your industry and documentation requirements — we confirm compliance scope in the quotation response."
    />

    <div set:html={subpage.content.partOne} />
    <div set:html={subpage.content.partTwo} />
    <p class="resource-note detail-page-back">
      <a href={`/industries/${subpage.industrySlug}/`}>← {parentTitle}</a>
      ·
      <a href="/industries/">All industries</a>
      ·
      <a href="/case-studies/">Case studies</a>
      ·
      <a href={quoteHref}>Request a quote</a>
    </p>
  </DetailPageShell>

  <BlogCta
    stage="selection"
    topic={subpage.slug}
    title={`Quote ${parentTitle.toLowerCase()} machining`}
    text="Send your part number with industry and compliance notes — we respond with scope confirmation within 24 hours."
    primaryLabel="Request a Quote"
    primaryHref={quoteHref}
    primaryEvent={`industry_sub_${subpage.slug}_rfq`}
    secondaryLabel="Case studies"
    secondaryHref="/case-studies/"
    secondaryEvent="industry_sub_case_studies"
  />
</BaseLayout>
