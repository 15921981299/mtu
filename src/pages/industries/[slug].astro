---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BreadcrumbHero from '../../components/BreadcrumbHero.astro';
import BlogCta from '../../components/BlogCta.astro';
import DetailPageShell from '../../components/DetailPageShell.astro';
import DetailRfqStrip from '../../components/DetailRfqStrip.astro';
import FunnelPageView from '../../components/FunnelPageView.astro';
import IndustrySidebar from '../../components/IndustrySidebar.astro';
import RelatedArticles from '../../components/RelatedArticles.astro';
import RelatedComparisons from '../../components/RelatedComparisons.astro';
import SubpageLinks from '../../components/SubpageLinks.astro';
import { getComparisonsForIndustry } from '../../data/funnel-links';
import { industries } from '../../data/industries';
import { industrySubpages } from '../../data/industry-subpages';
import { isSubpageNoindex } from '../../data/subpage-quality';
import { industryArticleMap } from '../../data/related-content';
import { breadcrumbSchema, serviceSchema, site } from '../../data/site';
import '../../styles/resource-page.css';

export function getStaticPaths() {
  return industries.map((item) => ({ params: { slug: item.slug }, props: { item } }));
}

const { item } = Astro.props;
const pageUrl = `${site.url}/industries/${item.slug}/`;
const quoteHref = `/contact/?source=industry-${item.slug}`;
const heroImage = item.image;
const secondaryImage = item.image;
const relatedComparisons = getComparisonsForIndustry(item.slug);
const relatedArticles = industryArticleMap[item.slug] ?? [];
const subpages = industrySubpages
  .filter((sp) => sp.industrySlug === item.slug && !isSubpageNoindex(sp.industrySlug, sp.slug))
  .map((sp) => ({ href: `/industries/${item.slug}/${sp.slug}/`, title: sp.title, summary: sp.summary }));
---

<BaseLayout
  title={item.seoTitle}
  description={item.summary}
  currentPath="/industries"
  image={heroImage}
  jsonLd={[
    breadcrumbSchema([
      { name: 'Home', url: site.url },
      { name: 'Industries', url: `${site.url}/industries/` },
      { name: item.title, url: pageUrl },
    ]),
    serviceSchema({
      name: item.title,
      description: item.summary,
      url: pageUrl,
      image: `${site.url}${heroImage}`,
    }),
  ]}
>
  <FunnelPageView stage="selection" label={`industry-${item.slug}`} />
  <BreadcrumbHero
    title={item.h1Title}
    trail={[
      { label: 'Home', href: '/' },
      { label: 'Industries', href: '/industries/' },
      { label: item.title },
    ]}
    variant="2"
  />

  <DetailPageShell intro={item.summary}>
    <img
      slot="hero"
      src={heroImage}
      alt={`CNC parts for ${item.title}`}
      width="1400"
      height="692"
      loading="eager"
      fetchpriority="high"
      decoding="async"
    />
    <div class="resource-meta">
      <span><strong>DFM review</strong> Free with quote</span>
      <span><strong>Lead time</strong> 7–15 days typical</span>
      <span><strong>Inspection</strong> CMM reports included</span>
    </div>

    <DetailRfqStrip
      quoteHref={quoteHref}
      title={`Quote ${item.title.toLowerCase()} parts`}
      text="Upload your drawing for industry-specific DFM feedback, compliance notes, and a quote within 24 hours."
    />

    <div set:html={item.content.partOne} />
    <figure class="detail-page-figure">
      <img src={secondaryImage} alt={`${item.title} — machined components`} width="1200" height="662" loading="lazy" decoding="async" />
    </figure>
    <div set:html={item.content.partTwo} />

    <SubpageLinks title={`${item.title} machining guides`} items={subpages} />
    {relatedArticles.length > 0 && (
      <RelatedArticles slugs={relatedArticles} title={`Guides for ${item.title}`} />
    )}
    <RelatedComparisons items={relatedComparisons} title={`Compare options for ${item.title.toLowerCase()}`} />

    <p class="resource-note detail-page-back">
      <a href="/industries/">All industries</a>
      ·
      <a href="/standards/">Compliance paths</a>
      ·
      <a href="/case-studies/">Case studies</a>
      ·
      <a href={quoteHref}>Request a quote</a>
    </p>
    <IndustrySidebar slot="sidebar" activeSlug={item.slug} quoteHref={quoteHref} />
  </DetailPageShell>

  <BlogCta
    stage="selection"
    topic={item.slug}
    title={`Quote ${item.title.toLowerCase()} machining`}
    text="Upload your drawing with industry and compliance notes — we confirm scope and respond within 24 hours."
    primaryLabel="Request a Quote"
    primaryHref={quoteHref}
    primaryEvent={`industry_${item.slug}_rfq`}
    secondaryLabel="Case studies"
    secondaryHref="/case-studies/"
    secondaryEvent="industry_case_studies"
  />
</BaseLayout>
