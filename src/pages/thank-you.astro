---
import BaseLayout from '../layouts/BaseLayout.astro';
import BreadcrumbHero from '../components/BreadcrumbHero.astro';
import { site } from '../data/site';
import '../styles/resource-page.css';
import '../styles/utility-page.css';
---

<BaseLayout
  title="Thank You — Your Parts Inquiry Was Received | Diesel Part Source"
  description="Thank you for submitting your engine parts inquiry. Diesel Part Source will review your part number, engine details, and delivery needs."
  currentPath="/thank-you"
  hideFloatingCta
  noindex
>
  <BreadcrumbHero title="Thank You!" current="Quote Received" variant="5" />

  <section class="blog-details-section utility-section">
    <div class="section-gap bottom">
      <div class="container">
        <article class="blog-details-content-block resource-page fade-in utility-card">
          <h2>We've Received Your Request</h2>
          <p>Our parts team will review your part number, engine model, serial number, quantity, and delivery needs, then reply with availability or next questions.</p>
          <p>Questions in the meantime? Email us at <a href={`mailto:${site.email}`}>{site.email}</a>.</p>

          <div class="utility-actions">
            <a href="/capabilities/" class="primary-button dark-hover">
              <div class="button-content-block">
                <div class="button-text">Explore Support</div>
                <div class="button-text">Explore Support</div>
              </div>
            </a>
            <a href="/part-products/" class="secondary-button">
              <div class="button-content-block">
                <div class="button-text">Read Parts Guides</div>
                <div class="button-text">Read Parts Guides</div>
              </div>
            </a>
          </div>

          <nav class="utility-pill-nav" aria-label="While you wait">
            <a href="/part-products/" class="utility-pill-link">MTU part numbers</a>
            <a href="/products/mtu-spare-parts/" class="utility-pill-link">MTU spare parts</a>
            <a href="/terms/payment/" class="utility-pill-link">Payment terms</a>
          </nav>
        </article>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  import { getAttributionSnapshot } from '../scripts/attribution';

  const params = new URLSearchParams(window.location.search);
  const source = params.get('source') ?? 'contact';
  const dedupeKey = `lead_tracked:${source}`;
  const attribution = getAttributionSnapshot();

  if (typeof window.gtag === 'function' && !sessionStorage.getItem(dedupeKey)) {
    sessionStorage.setItem(dedupeKey, '1');
    window.gtag('event', 'generate_lead', {
      event_category: 'RFQ',
      event_label: source,
      ...(attribution
        ? {
            first_touch_page: attribution.firstTouchPage,
            first_touch_stage: attribution.firstTouchStage,
            touch_count: attribution.touches.length,
          }
        : {}),
    });
  }
</script>
