---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import BreadcrumbHero from '../../../components/BreadcrumbHero.astro';
import BlogCta from '../../../components/BlogCta.astro';
import DetailPageShell from '../../../components/DetailPageShell.astro';
import DetailRfqStrip from '../../../components/DetailRfqStrip.astro';
import FunnelPageView from '../../../components/FunnelPageView.astro';
import RelatedArticles from '../../../components/RelatedArticles.astro';
import { capabilitySubpages } from '../../../data/capability-subpages';
import { isSubpageNoindex } from '../../../data/subpage-quality';
import { services } from '../../../data/services';
import { capabilityArticleMap } from '../../../data/related-content';
import { breadcrumbSchema, site } from '../../../data/site';
import '../../../styles/resource-page.css';

export function getStaticPaths() {
  return capabilitySubpages.map((sp) => ({ params: { capability: sp.capabilitySlug, subpage: sp.slug }, props: { subpage: sp } }));
}

const { subpage } = Astro.props;
const parent = services.find((s) => s.slug === subpage.capabilitySlug);
const parentTitle = parent?.title ?? subpage.capabilitySlug;
const pageUrl = `${site.url}/capabilities/${subpage.capabilitySlug}/${subpage.slug}/`;
const funnelLabel = `capability-sub-${subpage.slug}`;
const quoteHref = `/contact/?source=${funnelLabel}`;
const noindex = isSubpageNoindex(subpage.capabilitySlug, subpage.slug);
---

<BaseLayout
  title={subpage.seoTitle}
  description={subpage.summary}
  currentPath="/capabilities"
  noindex={noindex}
  jsonLd={breadcrumbSchema([
    { name: 'Home', url: site.url },
    { name: 'Capabilities', url: `${site.url}/capabilities/` },
    { name: parentTitle, url: `${site.url}/capabilities/${subpage.capabilitySlug}/` },
    { name: subpage.title, url: pageUrl },
  ])}
>
  <FunnelPageView stage="selection" label={funnelLabel} />
  <BreadcrumbHero
    title={subpage.h1Title}
    trail={[
      { label: 'Home', href: '/' },
      { label: 'Capabilities', href: '/capabilities/' },
      { label: parentTitle, href: `/capabilities/${subpage.capabilitySlug}/` },
      { label: subpage.title },
    ]}
    variant="2"
  />

  <DetailPageShell intro={subpage.summary}>
    <div class="resource-meta" aria-label="Capability subpage facts">
      <span><strong>Part check</strong> Included</span>
      <span><strong>Verification</strong> Engine and serial number</span>
      <span><strong>Response</strong> Fast stock review</span>
    </div>

    <DetailRfqStrip
      quoteHref={quoteHref}
      title={`Quote ${parentTitle.toLowerCase()} parts`}
      text="Send your part number, engine model, serial number, quantity, and destination for availability review."
    />

    <div set:html={subpage.content.partOne} />
    <div set:html={subpage.content.partTwo} />
    <RelatedArticles slugs={capabilityArticleMap[subpage.capabilitySlug] ?? []} />
    <p class="resource-note detail-page-back">
      <a href={`/capabilities/${subpage.capabilitySlug}/`}>← {parentTitle}</a>
      ·
      <a href="/capabilities/">All capabilities</a>
      ·
      <a href="/compare/">Comparisons</a>
      ·
      <a href={quoteHref}>Request a quote</a>
    </p>
  </DetailPageShell>

  <BlogCta
    stage="selection"
    topic={subpage.slug}
    title={`Quote ${parentTitle.toLowerCase()} parts`}
    text="Send your part number and engine details — we confirm fitment and return a parts quote."
    primaryLabel="Send Parts Inquiry"
    primaryHref={quoteHref}
    primaryEvent={`capability_sub_${subpage.slug}_rfq`}
    secondaryLabel="Parts comparisons"
    secondaryHref="/compare/"
    secondaryEvent="capability_sub_compare"
  />
</BaseLayout>
