---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BreadcrumbHero from '../../components/BreadcrumbHero.astro';
import BlogCta from '../../components/BlogCta.astro';
import FunnelPageView from '../../components/FunnelPageView.astro';
import { materialFaqs } from '../../data/page-faqs';
import { materials } from '../../data/materials';
import { breadcrumbSchema, faqSchema, site } from '../../data/site';
import '../../styles/resource-page.css';

const featuredSlugs = new Set(['aluminum', 'stainless-steel']);
---

<BaseLayout
  title="CNC Machining Materials — Aluminum, Steel, Titanium & Plastics | Machining Supplier"
  description="Explore materials we CNC machine: aluminum, stainless steel, carbon steel, titanium, brass, copper, and engineering plastics. Free DFM feedback with every quote."
  currentPath="/materials"
  jsonLd={[
    breadcrumbSchema([
      { name: 'Home', url: site.url },
      { name: 'Materials', url: `${site.url}/materials/` },
    ]),
    faqSchema(materialFaqs.map((f) => ({ question: f.question, answer: f.answer }))),
  ]}
>
  <FunnelPageView stage="service" label="materials-index" />
  <BreadcrumbHero
    title="Materials We Machine"
    trail={[
      { label: 'Home', href: '/' },
      { label: 'Materials' },
    ]}
    variant="1"
  />

  <section class="blog-details-section resource-page-section">
    <div class="section-gap bottom">
      <div class="container">
        <article class="blog-details-content-block resource-page fade-in">
          <nav class="resource-nav" aria-label="Materials navigation">
            <a href="/materials/" class="resource-nav-link active" aria-current="page">
              All materials
            </a>
            <a href="/materials/grades/" class="resource-nav-link">All grades</a>
            <a href="/products/" class="resource-nav-link">Part types</a>
            <a href="/capabilities/" class="resource-nav-link">Capabilities</a>
            <a href="/resources/material-certificates/" class="resource-nav-link">Material certs</a>
            <a href="/resources/" class="resource-nav-link resource-nav-all">Resources</a>
          </nav>

          <p class="resource-intro">
            We machine aluminum, stainless steel, carbon steel, titanium, brass, copper, and engineering plastics — with certified material traceability and free DFM review on every RFQ.
          </p>

          <div class="resource-meta">
            <span><strong>{materials.length}</strong> material families</span>
            <span>EN 10204 3.1 · Heat-lot traceability</span>
            <span>Free DFM · <strong>24h quote</strong></span>
          </div>

          <div class="detail-rfq-strip">
            <p>Specify material grade and cert level on your RFQ — we confirm EN 10204 traceability and machinability in the quote.</p>
            <a href="/contact/?source=materials" class="detail-rfq-link">Request a Quote</a>
          </div>

          <div class="hub-grid materials-hub-grid">
            {materials.map((material) => (
              <article class:list={['hub-card', { featured: featuredSlugs.has(material.slug) }]}>
                {featuredSlugs.has(material.slug) && <span class="hub-featured-badge">Featured</span>}
                <a href={`/materials/${material.slug}/`} class="hub-card-icon">
                  <img
                    src={material.icon}
                    alt={`${material.title} icon`}
                    width="32"
                    height="32"
                    loading="lazy"
                    decoding="async"
                  />
                </a>
                <div class="hub-card-body">
                  <h2 class="hub-card-title">
                    <a href={`/materials/${material.slug}/`}>{material.title}</a>
                  </h2>
                  <p class="hub-card-meta">{material.grades}</p>
                  <p class="hub-card-summary">{material.summary}</p>
                  <a href={`/materials/${material.slug}/`} class="hub-card-link">
                    View material guide →
                  </a>
                </div>
              </article>
            ))}
          </div>

          <div class="resource-note">
            <strong>Quality tip:</strong> Request
            <a href="/resources/material-certificates/">EN 10204 3.1 certificates</a>
            on your first PO for metals — it sets the traceability bar before production ramps.
          </div>

          <h2 class="hub-faq-heading">Machining Materials FAQ</h2>
          <div class="hub-faq-list">
            {materialFaqs.map((faq) => (
              <details class="hub-faq-item">
                <summary>{faq.question}</summary>
                <p>{faq.answer}</p>
              </details>
            ))}
          </div>

          <p class="resource-related">
            <a href="/compare/">Process comparisons</a>
            <span aria-hidden="true">·</span>
            <a href="/resources/cnc-tolerance-guide/">Tolerance guide</a>
            <span aria-hidden="true">·</span>
            <a href="/case-studies/">Case studies</a>
            <span aria-hidden="true">·</span>
            <a href="/terms/payment/">Payment terms</a>
          </p>
        </article>
      </div>
    </div>
  </section>

  <BlogCta
    stage="service"
    topic="materials-index"
    title="Quote your material and grade"
    text="Upload your drawing with exact alloy callout — we confirm machinability, cert level, and lead time in the quote response."
    primaryLabel="Request a Quote"
    primaryHref="/contact/?source=materials"
    primaryEvent="materials_index_rfq"
    secondaryLabel="Material certs guide"
    secondaryHref="/resources/material-certificates/"
    secondaryEvent="materials_index_certs"
  />
</BaseLayout>

<style>
  .materials-hub-grid {
    grid-template-columns: repeat(2, 1fr);
  }

  .materials-hub-grid .hub-card-icon img {
    width: 28px;
    height: 28px;
    display: block;
  }

  @media (max-width: 768px) {
    .materials-hub-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
