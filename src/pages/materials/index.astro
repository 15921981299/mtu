---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BreadcrumbHero from '../../components/BreadcrumbHero.astro';
import BlogCta from '../../components/BlogCta.astro';
import FunnelPageView from '../../components/FunnelPageView.astro';
import { materialFaqs } from '../../data/page-faqs';
import { materials } from '../../data/materials';
import { breadcrumbSchema, faqSchema, site } from '../../data/site';
import '../../styles/resource-page.css';

const featuredSlugs = new Set(['aluminum', 'stainless-steel']);
---

<BaseLayout
  title="Engine Parts Reference Groups — MTU Series & Spare Parts | Engine Family"
  description="Reference groups for MTU and diesel engine parts inquiries, including series coverage, part categories, verification details, and sourcing notes."
  currentPath="/materials"
  jsonLd={[
    breadcrumbSchema([
      { name: 'Home', url: site.url },
      { name: 'Materials', url: `${site.url}/materials/` },
    ]),
    faqSchema(materialFaqs.map((f) => ({ question: f.question, answer: f.answer }))),
  ]}
>
  <FunnelPageView stage="service" label="materials-index" />
  <BreadcrumbHero
    title="Engine Parts<br>Reference"
    trail={[
      { label: 'Home', href: '/' },
      { label: 'Materials' },
    ]}
    variant="1"
  />

  <section class="blog-details-section resource-page-section">
    <div class="section-gap bottom">
      <div class="container">
        <article class="blog-details-content-block resource-page fade-in">
          <nav class="resource-nav" aria-label="Materials navigation">
            <a href="/materials/" class="resource-nav-link active" aria-current="page">
              All references
            </a>
            <a href="/part-products/" class="resource-nav-link">Part numbers</a>
            <a href="/products/" class="resource-nav-link">Engine parts</a>
            <a href="/capabilities/" class="resource-nav-link">Capabilities</a>
            <a href="/products/mtu-spare-parts/mtu-part-number-lookup/" class="resource-nav-link">MTU lookup</a>
            <a href="/resources/" class="resource-nav-link resource-nav-all">Resources</a>
          </nav>

          <p class="resource-intro">
            These legacy reference pages now support engine-parts sourcing. Use them to navigate MTU series, part categories, verification notes, and inquiry preparation before contacting Engine Family.
          </p>

          <div class="resource-meta">
            <span><strong>{materials.length}</strong> reference groups</span>
            <span>MTU series · part categories</span>
            <span>Part checks before <strong>quotation</strong></span>
          </div>

          <div class="detail-rfq-strip">
            <p>Send part number, engine model, serial number, photos, quantity, and destination — we confirm availability and replacement options.</p>
            <a href="/contact/?source=materials" class="detail-rfq-link">Check Parts</a>
          </div>

          <div class="hub-grid materials-hub-grid">
            {materials.map((material) => (
              <article class:list={['hub-card', { featured: featuredSlugs.has(material.slug) }]}>
                {featuredSlugs.has(material.slug) && <span class="hub-featured-badge">Featured</span>}
                <a href={`/materials/${material.slug}/`} class="hub-card-icon">
                  <img
                    src={material.icon}
                    alt={`${material.title} icon`}
                    width="32"
                    height="32"
                    loading="lazy"
                    decoding="async"
                  />
                </a>
                <div class="hub-card-body">
                  <h2 class="hub-card-title">
                    <a href={`/materials/${material.slug}/`}>{material.title}</a>
                  </h2>
                  <p class="hub-card-meta">{material.grades}</p>
                  <p class="hub-card-summary">{material.summary}</p>
                  <a href={`/materials/${material.slug}/`} class="hub-card-link">
                    View reference →
                  </a>
                </div>
              </article>
            ))}
          </div>

          <div class="resource-note">
            <strong>Verification tip:</strong> Include the engine nameplate and old-part photo when the part number is unclear.
          </div>

          <h2 class="hub-faq-heading">Engine Parts Reference FAQ</h2>
          <div class="hub-faq-list">
            {materialFaqs.map((faq) => (
              <details class="hub-faq-item">
                <summary>{faq.question}</summary>
                <p>{faq.answer}</p>
              </details>
            ))}
          </div>

          <p class="resource-related">
            <a href="/compare/">Parts comparisons</a>
            <span aria-hidden="true">·</span>
            <a href="/part-products/">MTU part numbers</a>
            <span aria-hidden="true">·</span>
            <a href="/case-studies/">Case studies</a>
            <span aria-hidden="true">·</span>
            <a href="/terms/payment/">Payment terms</a>
          </p>
        </article>
      </div>
    </div>
  </section>

  <BlogCta
    stage="service"
    topic="materials-index"
    title="Need a part checked?"
    text="Send the part number, engine model, serial number, old-part photo, quantity, and destination. We verify before quotation."
    primaryLabel="Check Parts"
    primaryHref="/contact/?source=materials"
    primaryEvent="materials_index_rfq"
    secondaryLabel="MTU part numbers"
    secondaryHref="/part-products/"
    secondaryEvent="materials_index_certs"
  />
</BaseLayout>

<style>
  .materials-hub-grid {
    grid-template-columns: repeat(2, 1fr);
  }

  .materials-hub-grid .hub-card-icon img {
    width: 28px;
    height: 28px;
    display: block;
  }

  @media (max-width: 768px) {
    .materials-hub-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
