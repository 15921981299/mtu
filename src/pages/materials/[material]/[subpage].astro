---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import BreadcrumbHero from '../../../components/BreadcrumbHero.astro';
import BlogCta from '../../../components/BlogCta.astro';
import DetailPageShell from '../../../components/DetailPageShell.astro';
import DetailRfqStrip from '../../../components/DetailRfqStrip.astro';
import FunnelPageView from '../../../components/FunnelPageView.astro';
import RelatedArticles from '../../../components/RelatedArticles.astro';
import RelatedComparisons from '../../../components/RelatedComparisons.astro';
import { getComparisonsForMaterialSubpage } from '../../../data/funnel-links';
import { materialSubpages } from '../../../data/material-subpages';
import { materials } from '../../../data/materials';
import { materialArticleMap } from '../../../data/related-content';
import { breadcrumbSchema, site } from '../../../data/site';
import '../../../styles/resource-page.css';

export function getStaticPaths() {
  return materialSubpages.map((sp) => ({ params: { material: sp.materialSlug, subpage: sp.slug }, props: { subpage: sp } }));
}

const { subpage } = Astro.props;
const parent = materials.find((m) => m.slug === subpage.materialSlug);
const parentTitle = parent?.title ?? subpage.materialSlug;
const pageUrl = `${site.url}/materials/${subpage.materialSlug}/${subpage.slug}/`;
const relatedComparisons = getComparisonsForMaterialSubpage(subpage.slug);
const funnelLabel = `material-sub-${subpage.slug}`;
const quoteHref = `/contact/?source=${funnelLabel}`;
const noindex = true;
---

<BaseLayout
  title={subpage.seoTitle}
  description={subpage.summary}
  currentPath="/materials"
  noindex={noindex}
  jsonLd={breadcrumbSchema([
    { name: 'Home', url: site.url },
    { name: 'Materials', url: `${site.url}/materials/` },
    { name: parentTitle, url: `${site.url}/materials/${subpage.materialSlug}/` },
    { name: subpage.title, url: pageUrl },
  ])}
>
  <FunnelPageView stage="comparison" label={funnelLabel} />
  <BreadcrumbHero
    title={subpage.h1Title}
    trail={[
      { label: 'Home', href: '/' },
      { label: 'Materials', href: '/materials/' },
      { label: parentTitle, href: `/materials/${subpage.materialSlug}/` },
      { label: subpage.title },
    ]}
    variant="2"
  />

  <DetailPageShell intro={subpage.summary}>
    <div class="resource-meta" aria-label="Material subpage facts">
      <span><strong>{parentTitle}</strong></span>
      <span><strong>Certs</strong> EN 10204 3.1 available</span>
      <span><strong>Compare</strong> Process options linked</span>
    </div>

    <DetailRfqStrip
      quoteHref={quoteHref}
      title={`Quote ${parentTitle.toLowerCase()} parts`}
      text="Send your part number with material grade and finish requirements — we confirm machinability and quote within 24 hours."
    />

    <div set:html={subpage.content.partOne} />
    <div set:html={subpage.content.partTwo} />
    <RelatedArticles slugs={materialArticleMap[subpage.materialSlug] ?? []} />
    <RelatedComparisons items={relatedComparisons} />
    <p class="resource-note detail-page-back">
      <a href={`/materials/${subpage.materialSlug}/`}>← {parentTitle}</a>
      ·
      <a href="/materials/">All materials</a>
      ·
      <a href="/compare/">Comparisons</a>
      ·
      <a href={quoteHref}>Request a quote</a>
    </p>
  </DetailPageShell>

  <BlogCta
    stage="comparison"
    topic={subpage.slug}
    title={`Quote ${parentTitle.toLowerCase()} machining`}
    text="Send your part number — we confirm material grade, part fit, and return a quote within 24 hours."
    primaryLabel="Request a Quote"
    primaryHref={quoteHref}
    primaryEvent={`material_sub_${subpage.slug}_rfq`}
    secondaryLabel="Material comparisons"
    secondaryHref="/compare/"
    secondaryEvent="material_sub_compare"
  />
</BaseLayout>
