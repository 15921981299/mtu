---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BreadcrumbHero from '../../components/BreadcrumbHero.astro';
import BlogCta from '../../components/BlogCta.astro';
import DetailPageShell from '../../components/DetailPageShell.astro';
import DetailRfqStrip from '../../components/DetailRfqStrip.astro';
import ExperienceProofNote from '../../components/ExperienceProofNote.astro';
import FunnelPageView from '../../components/FunnelPageView.astro';
import MaterialQuoteGuide from '../../components/MaterialQuoteGuide.astro';
import MaterialSidebar from '../../components/MaterialSidebar.astro';
import RelatedArticles from '../../components/RelatedArticles.astro';
import RelatedComparisons from '../../components/RelatedComparisons.astro';
import SubpageLinks from '../../components/SubpageLinks.astro';
import { getComparisonsForMaterial } from '../../data/funnel-links';
import { materials } from '../../data/materials';
import { materialSubpages } from '../../data/material-subpages';
import { isSubpageNoindex } from '../../data/subpage-quality';
import { materialArticleMap } from '../../data/related-content';
import { breadcrumbSchema, serviceSchema, site } from '../../data/site';
import '../../styles/resource-page.css';

export function getStaticPaths() {
  return materials.map((item) => ({ params: { slug: item.slug }, props: { item } }));
}

const { item } = Astro.props;
const pageUrl = `${site.url}/materials/${item.slug}/`;
const quoteHref = `/contact/?source=material-${item.slug}`;
const heroImage = item.image;
const secondaryImage = item.image;
const relatedComparisons = getComparisonsForMaterial(item.slug);
const subpages = materialSubpages
  .filter((sp) => sp.materialSlug === item.slug && !isSubpageNoindex(sp.materialSlug, sp.slug))
  .map((sp) => ({ href: `/materials/${item.slug}/${sp.slug}/`, title: sp.title, summary: sp.summary }));
---

<BaseLayout
  title={item.seoTitle}
  description={item.summary}
  currentPath="/materials"
  image={heroImage}
  jsonLd={[
    breadcrumbSchema([
      { name: 'Home', url: site.url },
      { name: 'Materials', url: `${site.url}/materials/` },
      { name: item.title, url: pageUrl },
    ]),
    serviceSchema({
      name: item.title,
      description: item.summary,
      url: pageUrl,
      image: `${site.url}${heroImage}`,
    }),
  ]}
>
  <FunnelPageView stage="selection" label={`material-${item.slug}`} />
  <BreadcrumbHero
    title={item.h1Title}
    trail={[
      { label: 'Home', href: '/' },
      { label: 'Materials', href: '/materials/' },
      { label: item.title },
    ]}
    variant="2"
  />

  <DetailPageShell intro={item.summary}>
    <img
      slot="hero"
      src={heroImage}
      alt={`CNC machined ${item.title}`}
      width="1400"
      height="692"
      loading="eager"
      fetchpriority="high"
      decoding="async"
    />
    <div class="resource-meta">
      <span><strong>Process</strong> In-house CNC</span>
      <span><strong>Inspection</strong> CMM on every order</span>
      <span><strong>MOQ</strong> No minimum</span>
    </div>

    <DetailRfqStrip
      quoteHref={quoteHref}
      title="Quote parts in this material"
      text="Upload your drawing for a free DFM review and material suitability check within 24 hours."
    />

    <ExperienceProofNote context="material" />

    <MaterialQuoteGuide materialName={item.title} grades={item.grades} />

    <div set:html={item.content.partOne} />
    <figure class="detail-page-figure">
      <img src={secondaryImage} alt={`${item.title} — machined examples`} width="1200" height="662" loading="lazy" decoding="async" />
    </figure>
    <div set:html={item.content.partTwo} />
    <SubpageLinks title={`${item.title.replace(/ Parts$/, '')} machining guides`} items={subpages} />
    <RelatedArticles slugs={materialArticleMap[item.slug] ?? []} title={`Guides for ${item.title.replace(/ Parts$/, '')}`} />
    <RelatedComparisons items={relatedComparisons} title={`Compare ${item.title.replace(/ Parts$/, '')} options`} />
    <p class="resource-note detail-page-back">
      <a href="/materials/">All materials</a>
      ·
      <a href="/compare/">Comparisons</a>
      ·
      <a href="/resources/material-certificates/">Material certs guide</a>
      ·
      <a href={quoteHref}>Request a quote</a>
    </p>
    <MaterialSidebar slot="sidebar" activeSlug={item.slug} quoteHref={quoteHref} />
  </DetailPageShell>

  <BlogCta
    stage="comparison"
    topic={item.slug}
    title={`Quote ${item.title.replace(/ Parts$/, '').toLowerCase()} parts`}
    text="Upload your drawing — we confirm material grade, process fit, and return a quote within 24 hours."
    primaryLabel="Request a Quote"
    primaryHref={quoteHref}
    primaryEvent={`material_${item.slug}_rfq`}
    secondaryLabel="Material certificates guide"
    secondaryHref="/resources/material-certificates/"
    secondaryEvent="material_certs_guide"
  />
</BaseLayout>
