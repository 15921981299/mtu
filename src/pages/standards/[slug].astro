---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BreadcrumbHero from '../../components/BreadcrumbHero.astro';
import BlogCta from '../../components/BlogCta.astro';
import DetailPageShell from '../../components/DetailPageShell.astro';
import DetailRfqStrip from '../../components/DetailRfqStrip.astro';
import FunnelPageView from '../../components/FunnelPageView.astro';
import StandardsSidebar from '../../components/StandardsSidebar.astro';
import { getCaseStudiesForStandard, getIndustryProof } from '../../data/industry-proof';
import { industries } from '../../data/industries';
import { materials } from '../../data/materials';
import { products } from '../../data/products';
import { standards } from '../../data/standards';
import { breadcrumbSchema, site } from '../../data/site';
import '../../styles/resource-page.css';

export function getStaticPaths() {
  return standards.map((s) => ({
    params: { slug: s.slug },
    props: { std: s },
  }));
}

const { std } = Astro.props;
const pageUrl = `${site.url}/standards/${std.slug}/`;
const quoteHref = `/contact/?source=standard-${std.slug}`;
const productSlugs = std.productSlugs as readonly string[];
const materialSlugs = std.materialSlugs as readonly string[];
const linkedProducts = products.filter((p) => productSlugs.includes(p.slug));
const linkedMaterials = materials.filter((m) => materialSlugs.includes(m.slug));

const linkedCaseStudies = getCaseStudiesForStandard(std.slug);
const industryProofEntry = getIndustryProof(std.slug);

const standardIndustryMap: Record<string, string[]> = {
  'food-grade-parts': ['food-beverage'],
  'medical-grade-parts': ['medical-devices'],
  'aerospace-grade-parts': ['aerospace', 'defense-military'],
  'automotive-ppap-parts': ['automotive'],
  'oil-gas-nace-parts': ['oil-gas'],
};
const relatedIndustries = (standardIndustryMap[std.slug] ?? [])
  .map((slug) => industries.find((i) => i.slug === slug))
  .filter((i): i is (typeof industries)[number] => Boolean(i));

const standardIcons: Record<string, string> = {
  'food-grade-parts': `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 002-2V2M7 2v20M21 15V2v0a5 5 0 00-5 5v6c0 1.1.9 2 2 2h3zm0 0v7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  'medical-grade-parts': `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 8v8M8 12h8M21 12a9 9 0 11-18 0 9 9 0 0118 0z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>`,
  'aerospace-grade-parts': `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  'automotive-ppap-parts': `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M14 16H9m10 0h1a1 1 0 001-1v-3.5a1 1 0 00-.684-.948l-4.493-1.498a1 1 0 00-1.316.948V15a1 1 0 001 1h1M6 16H5a1 1 0 01-1-1v-3.5a1 1 0 01.684-.948l4.493-1.498a1 1 0 011.316.948V15a1 1 0 01-1 1h-1M6 11l1.5-4h9L18 11M6 16v2m12-2v2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  'oil-gas-nace-parts': `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 2.69l5.66 5.66a8 8 0 11-11.32 0L12 2.69z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>`,
};

const defaultStandardIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8l-6-6z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M14 2v6h6M8 13h8M8 17h5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>`;

const standardThemes: Record<string, { badges: string[] }> = {
  'food-grade-parts': {
    badges: ['FDA compliant', '316 Stainless', 'Ra ≤ 0.8µm', '3-A sanitary'],
  },
  'medical-grade-parts': {
    badges: ['ISO 13485 aligned', 'DHF support', 'Lot traceability', 'EN 10204 3.1'],
  },
  'aerospace-grade-parts': {
    badges: ['AS9102 FAI', 'Heat-lot certs', 'FOD prevention', 'MIL specs'],
  },
  'automotive-ppap-parts': {
    badges: ['IATF 16949 aligned', 'PPAP Level 3', 'Cpk > 1.33', 'Gage R&R'],
  },
  'oil-gas-nace-parts': {
    badges: ['NACE MR0175', 'PMI testing', 'HRC control', 'NDE inspection'],
  },
};

const theme = standardThemes[std.slug] ?? {
  badges: ['Traceability', 'CMM inspection', 'Material certs'],
};
---

<BaseLayout
  title={std.seoTitle}
  description={std.summary}
  currentPath="/standards"
  jsonLd={breadcrumbSchema([
    { name: 'Home', url: site.url },
    { name: 'Parts by Standard', url: `${site.url}/standards/` },
    { name: std.title, url: pageUrl },
  ])}
>
  <FunnelPageView stage="selection" label={`standard-${std.slug}`} />
  <BreadcrumbHero
    title={std.h1Title}
    trail={[
      { label: 'Home', href: '/' },
      { label: 'Parts by Standard', href: '/standards/' },
      { label: std.title },
    ]}
    variant="5"
  />

  <DetailPageShell intro={std.summary}>
    <div class:list={['standard-hero', `standard-hero--${std.slug}`]}>
      <div class="standard-hero-icon" set:html={standardIcons[std.slug] ?? defaultStandardIcon} />
      <div class="standard-hero-text">
        <p class="standard-hero-kicker">Industry standard machining</p>
        <p class="standard-hero-summary">{std.summary}</p>
      </div>
    </div>

    <div class="resource-meta">
      <span><strong>{theme.badges.length}</strong> compliance checkpoints</span>
      <span><strong>{linkedCaseStudies.length}</strong> case {linkedCaseStudies.length === 1 ? 'study' : 'studies'}</span>
      <span>Docs · Traceability · FAI</span>
    </div>

    <DetailRfqStrip
      quoteHref={quoteHref}
      title="Request compliance quote"
      text="State your industry standard and documentation requirements — we confirm compliance scope in the quotation response."
      label="Confirm on RFQ"
    />

    <div class="standard-meta-bar">
      <div class="standard-badges">
        {theme.badges.map((badge) => (
          <span class="standard-badge">{badge}</span>
        ))}
      </div>
      <p class="standard-trust-links">
        <a href="/certifications/">Certifications</a>
        <span aria-hidden="true">·</span>
        <a href="/terms/payment/">Payment terms</a>
        <span aria-hidden="true">·</span>
        <a href="/terms/shipping/">Shipping</a>
        <span aria-hidden="true">·</span>
        <a href="/resources/material-certificates/">Material certs</a>
        {industryProofEntry?.auditBlogSlug && (
          <>
            <span aria-hidden="true">·</span>
            <a href={`/blog/${industryProofEntry.auditBlogSlug}/`}>Supplier audit guide</a>
          </>
        )}
      </p>
    </div>

    <div class="standard-content-card">
      <div set:html={std.content.partOne} />
    </div>
    <div class="standard-content-card">
      <div set:html={std.content.partTwo} />
    </div>

    {linkedCaseStudies.length > 0 && (
      <section class="standard-related" aria-labelledby="case-studies-heading">
        <h2 id="case-studies-heading" class="standard-related-title">Proof from Similar Projects</h2>
        <div class="standard-related-grid">
          {linkedCaseStudies.map((study) => (
            <a href={`/case-studies/${study.slug}/`} class="standard-related-card">
              <span class="standard-related-label">Case Study</span>
              <span class="standard-related-name">{study.title}</span>
              <span class="standard-related-desc">{study.summary.slice(0, 100)}…</span>
            </a>
          ))}
        </div>
      </section>
    )}

    {linkedMaterials.length > 0 && (
      <section class="standard-related" aria-labelledby="materials-heading">
        <h2 id="materials-heading" class="standard-related-title">Common Materials</h2>
        <div class="standard-related-grid">
          {linkedMaterials.map((m) => (
            <a href={`/materials/${m.slug}/`} class="standard-related-card">
              <span class="standard-related-label">Material</span>
              <span class="standard-related-name">{m.title}</span>
              <span class="standard-related-desc">{m.summary.slice(0, 100)}…</span>
            </a>
          ))}
        </div>
      </section>
    )}

    {linkedProducts.length > 0 && (
      <section class="standard-related" aria-labelledby="products-heading">
        <h2 id="products-heading" class="standard-related-title">Related Products</h2>
        <div class="standard-related-grid">
          {linkedProducts.map((p) => (
            <a href={`/products/${p.slug}/`} class="standard-related-card">
              <span class="standard-related-label">Product</span>
              <span class="standard-related-name">{p.title}</span>
              <span class="standard-related-desc">{p.summary.slice(0, 100)}…</span>
            </a>
          ))}
        </div>
      </section>
    )}

    {relatedIndustries.length > 0 && (
      <section class="standard-related" aria-labelledby="industries-heading">
        <h2 id="industries-heading" class="standard-related-title">Industries We Serve to This Standard</h2>
        <div class="standard-related-grid">
          {relatedIndustries.map((ind) => (
            <a href={`/industries/${ind.slug}/`} class="standard-related-card">
              <span class="standard-related-label">Industry</span>
              <span class="standard-related-name">{ind.title}</span>
              <span class="standard-related-desc">{ind.summary.slice(0, 100)}…</span>
            </a>
          ))}
        </div>
      </section>
    )}

    <p class="resource-note detail-page-back">
      <a href="/standards/">All standards</a>
      ·
      <a href="/certifications/">QC process</a>
      ·
      <a href="/resources/inspection-samples/">Inspection samples</a>
      ·
      <a href={quoteHref}>Request compliance quote</a>
    </p>

    <StandardsSidebar slot="sidebar" activeSlug={std.slug} />
  </DetailPageShell>

  <BlogCta
    stage="signing"
    topic={std.slug}
    title="Verify compliance before you quote"
    text="Review our quality certifications and case studies for regulated industries — then send your drawing when you are ready."
    primaryLabel="Request Compliance Quote"
    primaryHref={quoteHref}
    primaryEvent={`standard_${std.slug}_rfq`}
    secondaryLabel="View Certifications"
    secondaryHref="/certifications/"
    secondaryEvent="standard_certifications"
  />
</BaseLayout>

<style>
  .standard-hero {
    display: flex;
    align-items: center;
    gap: 28px;
    padding: 36px 40px;
    border-radius: 8px;
    margin-bottom: 0;
    box-shadow: 0 8px 32px rgba(8, 8, 8, 0.1);
    overflow: hidden;
    position: relative;
    color: #fff;
  }

  .standard-hero--food-grade-parts {
    background: linear-gradient(135deg, #064e3b 0%, #0d9488 55%, #134e4a 100%);
  }
  .standard-hero--medical-grade-parts {
    background: linear-gradient(135deg, #1e3a5f 0%, #2563eb 55%, #1d4ed8 100%);
  }
  .standard-hero--aerospace-grade-parts {
    background: linear-gradient(135deg, #0c4a6e 0%, #0284c7 50%, #1e40af 100%);
  }
  .standard-hero--automotive-ppap-parts {
    background: linear-gradient(135deg, #7c2d12 0%, #ea580c 55%, #c2410c 100%);
  }
  .standard-hero--oil-gas-nace-parts {
    background: linear-gradient(135deg, #422006 0%, #b45309 50%, #78350f 100%);
  }

  .standard-hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 85% 20%, rgba(255, 255, 255, 0.12) 0%, transparent 45%);
    pointer-events: none;
  }

  .standard-hero-icon {
    flex-shrink: 0;
    width: 72px;
    height: 72px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    background: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 14px;
    backdrop-filter: blur(4px);
    position: relative;
    z-index: 1;
  }

  .standard-hero-text {
    position: relative;
    z-index: 1;
    flex: 1;
  }

  .standard-hero-kicker {
    margin: 0 0 8px;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.75);
  }

  .standard-hero-summary {
    margin: 0;
    font-size: 17px;
    line-height: 1.65;
    color: #fff;
  }

  .standard-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 16px;
  }

  .standard-badge {
    padding: 8px 14px;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.03em;
    color: var(--color-primary);
    background: rgba(20, 110, 245, 0.08);
    border: 1px solid rgba(20, 110, 245, 0.2);
    border-radius: 999px;
  }

  .standard-trust-links {
    margin: 0;
    font-size: 14px;
    color: var(--color-body-text);
  }

  .standard-trust-links a {
    color: var(--color-primary);
    text-decoration: none;
    font-weight: 600;
    cursor: pointer;
  }

  .standard-trust-links a:hover {
    text-decoration: underline;
  }

  .standard-trust-links span {
    margin: 0 8px;
    opacity: 0.45;
  }

  .standard-meta-bar {
    padding: 0 0 24px;
    margin-bottom: 0;
    border-bottom: 1px solid var(--color-stroke);
  }

  .standard-content-card {
    padding: 28px 32px;
    background: var(--color-background);
    border: 1px solid var(--color-stroke);
    border-radius: 8px;
  }

  .standard-related {
    padding-top: 8px;
    scroll-margin-top: 100px;
  }

  .standard-related-title {
    margin: 0 0 16px;
    font-size: 22px;
    font-weight: 600;
    color: var(--color-title);
    text-transform: none;
  }

  .standard-related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 14px;
  }

  .standard-related-card {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 18px 20px;
    background: var(--color-background);
    border: 1px solid var(--color-stroke);
    border-radius: 8px;
    text-decoration: none;
    cursor: pointer;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .standard-related-card:hover {
    border-color: rgba(20, 110, 245, 0.4);
    box-shadow: 0 8px 24px rgba(20, 110, 245, 0.1);
  }

  .standard-related-label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-primary);
  }

  .standard-related-name {
    font-size: 16px;
    font-weight: 600;
    color: var(--color-title);
    line-height: 1.35;
  }

  .standard-related-desc {
    font-size: 13px;
    line-height: 1.5;
    color: #475569;
  }

  @media (prefers-reduced-motion: reduce) {
    .standard-related-card {
      transition: none;
    }
  }

  @media screen and (max-width: 991px) {
    .standard-hero {
      flex-direction: column;
      align-items: flex-start;
      padding: 28px 24px;
    }
    .standard-meta-bar {
      padding: 20px 0;
    }
    .standard-content-card {
      padding: 24px 20px;
    }
  }

  @media screen and (max-width: 767px) {
    .standard-hero {
      padding: 24px 20px;
      gap: 20px;
    }
    .standard-hero-icon {
      width: 60px;
      height: 60px;
    }
    .standard-hero-summary {
      font-size: 16px;
    }
  }

  @media screen and (max-width: 479px) {
    .standard-related-grid {
      grid-template-columns: 1fr;
    }
    .standard-trust-links {
      font-size: 13px;
      line-height: 1.6;
    }
  }
</style>
