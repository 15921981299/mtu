---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BreadcrumbHero from '../../components/BreadcrumbHero.astro';
import BlogCta from '../../components/BlogCta.astro';
import FunnelPageView from '../../components/FunnelPageView.astro';
import { standards } from '../../data/standards';
import { breadcrumbSchema, site } from '../../data/site';
import '../../styles/resource-page.css';

const standardIcons: Record<string, string> = {
  'food-grade-parts': `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 002-2V2M7 2v20M21 15V2v0a5 5 0 00-5 5v6c0 1.1.9 2 2 2h3zm0 0v7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  'medical-grade-parts': `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 8v8M8 12h8M21 12a9 9 0 11-18 0 9 9 0 0118 0z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>`,
  'aerospace-grade-parts': `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  'automotive-ppap-parts': `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M14 16H9m10 0h1a1 1 0 001-1v-3.5a1 1 0 00-.684-.948l-4.493-1.498a1 1 0 00-1.316.948V15a1 1 0 001 1h1M6 16H5a1 1 0 01-1-1v-3.5a1 1 0 01.684-.948l4.493-1.498a1 1 0 011.316.948V15a1 1 0 01-1 1h-1M6 11l1.5-4h9L18 11M6 16v2m12-2v2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  'oil-gas-nace-parts': `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 2.69l5.66 5.66a8 8 0 11-11.32 0L12 2.69z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>`,
};

const defaultStandardIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8l-6-6z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M14 2v6h6M8 13h8M8 17h5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>`;
---

<BaseLayout
  title="Engine Parts by Industry Standard — Marine, Power, Rail & Industrial | Engine Family"
  description="Browse diesel engine parts by industry standard: food-grade FDA, medical ISO 13485, aerospace AS9100, automotive IATF 16949 / PPAP, and oil & gas NACE MR0175."
  currentPath="/standards"
  jsonLd={breadcrumbSchema([
    { name: 'Home', url: site.url },
    { name: 'Parts by Standard', url: `${site.url}/standards/` },
  ])}
>
  <FunnelPageView stage="selection" label="standards-index" />
  <BreadcrumbHero
    title="Parts by<br>Industry Standard"
    trail={[
      { label: 'Home', href: '/' },
      { label: 'Standards' },
    ]}
    variant="3"
  />

  <section class="blog-details-section resource-page-section">
    <div class="section-gap bottom">
      <div class="container">
        <article class="blog-details-content-block resource-page fade-in">
          <nav class="resource-nav" aria-label="Standards navigation">
            <a href="/standards/" class="resource-nav-link active" aria-current="page">
              All standards
            </a>
            <a href="/industries/" class="resource-nav-link">Industries</a>
            <a href="/certifications/" class="resource-nav-link">QC process</a>
            <a href="/resources/material-certificates/" class="resource-nav-link">Material certs</a>
            <a href="/case-studies/" class="resource-nav-link resource-nav-all">Case studies</a>
          </nav>

          <p class="resource-intro">
            Compliance-oriented CNC paths — what buyers verify for food, medical, aerospace, automotive PPAP, and oil & gas sour service before releasing a production PO.
          </p>

          <div class="resource-meta">
            <span><strong>{standards.length}</strong> standard paths</span>
            <span>Docs · Traceability · FAI</span>
            <span>Linked to <strong>case proof</strong></span>
          </div>

          <div class="detail-rfq-strip">
            <p>State your industry standard and documentation requirements on the RFQ — we confirm compliance scope in the quote.</p>
            <a href="/contact/?source=standard" class="detail-rfq-link">Confirm on RFQ</a>
          </div>

          <div class="hub-grid">
            {standards.map((standard) => (
              <article class="hub-card">
                <span class="hub-card-icon" set:html={standardIcons[standard.slug] ?? defaultStandardIcon} />
                <div class="hub-card-body">
                  <h2 class="hub-card-title">
                    <a href={`/standards/${standard.slug}/`}>{standard.title}</a>
                  </h2>
                  <p class="hub-card-summary">{standard.summary}</p>
                  <a href={`/standards/${standard.slug}/`} class="hub-card-link">
                    View standard guide →
                  </a>
                </div>
              </article>
            ))}
          </div>

          <div class="resource-note">
            <strong>Quality path:</strong> Standards describe what to verify —
            <a href="/resources/inspection-samples/">see redacted report samples</a>
            and
            <a href="/certifications/">our QC workflow</a>
            before RFQ.
          </div>

          <p class="resource-related">
            <a href="/industries/">Industries</a>
            <span aria-hidden="true">·</span>
            <a href="/resources/by-role/quality/">Quality hub</a>
            <span aria-hidden="true">·</span>
            <a href="/compare/">Process comparisons</a>
            <span aria-hidden="true">·</span>
            <a href="/terms/samples/">Sample policy</a>
          </p>
        </article>
      </div>
    </div>
  </section>

  <BlogCta
    stage="signing"
    topic="standards-index"
    title="Confirm compliance scope on your quote"
    text="Send your part number and note industry standard, cert level, and FAI requirements — we confirm feasibility in the quotation response."
    primaryLabel="Request a Quote"
    primaryHref="/contact/?source=standard"
    primaryEvent="standards_index_rfq"
    secondaryLabel="QC process"
    secondaryHref="/certifications/"
    secondaryEvent="standards_index_cert"
  />
</BaseLayout>
