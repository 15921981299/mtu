---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeading from "../components/SectionHeading.astro";
import FunnelPageView from "../components/FunnelPageView.astro";
import { services } from "../data/services";
import { industries } from "../data/industries";
import { itemListSchema, site, videoSchema } from "../data/site";
import { mtuParts } from "../data/mtu-parts";

const homepageVideos = [
  videoSchema({
    name: "Diesel Part Source Parts Support Overview",
    description:
      "Overview of diesel engine parts identification, stock checking, packing, and global delivery support.",
    thumbnailUrl: "https://img.youtube.com/vi/M7uJEbDD-_8/hqdefault.jpg",
    embedUrl: "https://www.youtube.com/embed/M7uJEbDD-_8",
    uploadDate: "2023-06-01",
  }),
  videoSchema({
    name: "Diesel Engine Parts Verification Process",
    description:
      "Behind-the-scenes look at part-number review, inquiry handling, packing, and shipment coordination.",
    thumbnailUrl: `${site.url}/images/mtu-part-number-verification.webp`,
    contentUrl: `${site.url}/images/mtu-part-number-verification.webp`,
  }),
];

const workflowSteps = [
  {
    image: "/images/mtu-part-number-verification.webp",
    step: "01",
    title: "Send Engine & Part Details",
    summary:
      "Send engine brand, model, serial number, part number, quantity, destination, and any nameplate or old-part photos.",
  },
  {
    image: "/images/mtu-part-number-verification.webp",
    step: "02",
    title: "Part Verification & Quote",
    summary:
      "We verify fitment, check stock or sourcing options, and send pricing, lead time, and shipping route as quickly as possible.",
  },
  {
    image: "/images/global-engine-parts-delivery.webp",
    step: "03",
    title: "Packing & Export Prep",
    summary:
      "Your parts are prepared with export packing, documentation, and shipment tracking for maintenance teams worldwide.",
  },
  {
    image: "/images/global-engine-parts-delivery.webp",
    step: "04",
    title: "Fast Global Delivery",
    summary:
      "We ship by express courier, air freight, or sea freight depending on urgency, part size, and destination.",
  },
];

const catalogHubs = [
  {
    href: "/part-products/catalog/mtu-filters/",
    title: "MTU Filters",
    subtitle: "Oil, fuel & air filter cartridges",
    image: "/images/engine-parts-sensors-catalog.png",
  },
  {
    href: "/part-products/catalog/mtu-injectors/",
    title: "MTU Injectors",
    subtitle: "Fuel injectors & delivery components",
    image: "/images/engine-parts-hero.png",
  },
  {
    href: "/part-products/catalog/mtu-2000-series/",
    title: "MTU 2000 Parts",
    subtitle: "Full engine series coverage",
    image: "/images/mtu-2000-series-parts.webp",
  },
  {
    href: "/part-products/catalog/mtu-4000-series/",
    title: "MTU 4000 Parts",
    subtitle: "Overhaul & replacement parts",
    image: "/images/mtu-4000-series-overhaul-parts.webp",
  },
  {
    href: "/part-products/catalog/mtu-gasket-kits/",
    title: "MTU Gasket Kits",
    subtitle: "Cylinder head & seal kits",
    image: "/images/engine-parts-verification-desk.png",
  },
  {
    href: "/part-products/catalog/mtu-turbocharger-parts/",
    title: "MTU Turbocharger",
    subtitle: "Turbine wheels & turbo components",
    image: "/images/industrial-diesel-engine-parts.webp",
  },
  {
    href: "/part-products/catalog/mtu-4000-fuel-system-parts/",
    title: "MTU 4000 Fuel System",
    subtitle: "Injectors, pumps & fuel lines",
    image: "/images/engine-parts-hero.png",
  },
  {
    href: "/part-products/catalog/mtu-cooling-system/",
    title: "MTU Cooling Parts",
    subtitle: "Pumps, impellers & coolers",
    image: "/images/marine-diesel-engine-parts.webp",
  },
  {
    href: "/part-products/catalog/mtu-sensors/",
    title: "MTU Sensors",
    subtitle: "Speed, pressure & temperature",
    image: "/images/engine-parts-sensors-catalog.png",
  },
];

const engineBrands = [
  {
    href: "/products/mtu-spare-parts/",
    title: "MTU",
    summary: "183, 331, 396, 493, 538, 595, 956, 1163, 2000, 4000, and 8000 series parts.",
  },
  {
    href: "/part-products/catalog/mtu-2000-series/",
    title: "MTU 2000 Series",
    summary: "8V-18V configurations. Marine, generator, rail, and industrial parts.",
  },
  {
    href: "/part-products/catalog/mtu-4000-series/",
    title: "MTU 4000 Series",
    summary: "12V-20V configurations. High-output marine, locomotive, and power gen parts.",
  },
  {
    href: "/part-products/catalog/mtu-filters/",
    title: "MTU Filters",
    summary: "Oil, fuel, air, and coolant filter elements. Bulk fleet quantities available.",
  },
  {
    href: "/part-products/catalog/mtu-injectors/",
    title: "MTU Injectors & Fuel System",
    summary: "Injectors, HP pumps, nozzle holders. New and reman options.",
  },
  {
    href: "/part-products/catalog/mtu-turbocharger-parts/",
    title: "MTU Turbocharger Parts",
    summary: "Turbine wheels, bearing housings, seals. OEM and reman options.",
  },
  {
    href: "/contact/",
    title: "Part Identification",
    summary: "Send a nameplate photo, old-part marking, or serial number for verification.",
  },
];

const homepageHotPartNumbers = [
  '5240113410',
  'X53507500012',
  'EX52407500064',
  '5410160920',
  '5240161580',
  '5110804420',
  '5240530301',
  '0005358233',
  '0031845201',
  'X57508300091',
  '5502003201',
  '5240380471',
];

const homepageHotParts = homepageHotPartNumbers
  .map((partNumber) => mtuParts.find((part) => part.partNumber.toUpperCase() === partNumber.toUpperCase()))
  .filter((part): part is (typeof mtuParts)[number] => Boolean(part));

const getHomepagePartEngine = (part: (typeof mtuParts)[number]) =>
  part.engineType || part.series.join(', ') || 'Serial check';

const homepageHotSlugs = new Set(homepageHotParts.map((part) => part.slug));
const homepageFeaturedParts = [...mtuParts]
  .filter((part) => part.image.includes('/diesel-part-source-parts/') && part.weightKg && part.hsCode && !homepageHotSlugs.has(part.slug))
  .sort((a, b) => {
    const bScore =
      Number(Boolean(b.replacementFor?.length)) +
      Number(Boolean(b.applicableEngines)) +
      Number(Boolean(b.commonFailureScenarios?.length));
    const aScore =
      Number(Boolean(a.replacementFor?.length)) +
      Number(Boolean(a.applicableEngines)) +
      Number(Boolean(a.commonFailureScenarios?.length));
    return bScore - aScore || a.partNumber.localeCompare(b.partNumber);
  })
  .slice(0, 48);

---

<BaseLayout
  title="MTU Engine Parts Specialist | Diesel Part Source"
  description="MTU engine parts specialist — 800+ part numbers indexed by series and category. Part-number verification, Shanghai stock support, and global delivery for marine, industrial, rail, and power generation applications."
  currentPath="/"
  jsonLd={[
    ...homepageVideos,
    itemListSchema(
      homepageHotParts.map((part) => ({
        name: `${part.partNumber} ${part.name}`,
        url: `${site.url}/part-products/${part.slug}/`,
      }))
    ),
  ]}
>
  <FunnelPageView stage="selection" label="homepage" />
  <!-- ═══ HERO ═══ -->
  <section class="hero-section">
    <div class="container">
      <div class="hero-wrapper">
        <div class="hero-content-block">
          <div class="hero-subtitle-block fade-in">
            <img
              src="/images/precision-manufacturing-badge-icon.svg"
              alt="Precision manufacturing icon"
              class="hero-subtitle-icon"
              width="24"
              height="24"
              loading="eager"
              decoding="async"
            />
            <div class="hero-subtitle-text">
              {site.tagline}
            </div>
          </div>
          <div class="hero-title-block">
            <h1 class="hero-title fade-in">
              MTU Engine Parts Specialist<br />Genuine Parts, Fast Global Delivery
            </h1>
          </div>
          <div class="hero-bottom-content-block">
            <div class="hero-summary-block">
              <p class="hero-summary">
                MTU engine parts specialist — 800+ part numbers indexed by engine series
                and part category. Send your engine model, serial number, and part list
                for verification, stock check, and quotation within 24 hours.
              </p>
            </div>
            <div class="hero-button-block">
              <div class="hero-cta-row">
                <a href="/contact/?source=homepage" class="secondary-button hero">
                  <div class="button-content-block">
                    <div class="button-text">Request Parts</div>
                    <div class="button-text">Request Parts</div>
                  </div>
                </a>
                <a href="/products/mtu-spare-parts/" class="hero-secondary-cta">MTU Spare Parts</a>
              </div>
              <ul class="hero-trust-row" aria-label="Key service guarantees">
                <li>MTU full-series support</li>
                <li>Genuine OEM sourcing</li>
                <li>Worldwide shipping</li>
              </ul>
            </div>
          </div>
        </div>
        <div class="hero-image-block">
          <img
            src="/images/mtu-engine-parts-hero.webp"
            alt="MTU diesel engine spare parts including injectors, filters, turbocharger, pump, sensors, gaskets, and seals"
            class="hero-image"
            width="800"
            height="649"
            loading="eager"
            fetchpriority="high"
            decoding="async"
          />
          <div class="hero-image-overlay image-overlay fade-in"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ CAPABILITIES ═══ -->
  <section class="service-section">
    <div class="section-gap bottom">
      <div class="container">
        <div class="service-wrapper">
          <SectionHeading
            title="Engine Parts & Service Support"
            subtitle="What We Supply"
          />
          <div class="service-bottom-block fade-in">
            <p class="service-bottom-text service-bottom-hint">
              Not sure which part number fits your engine? <a
                href="/contact/"
                class="service-bottom-link"
                >send your engine details</a> and we will help verify the replacement before shipment.
            </p>
          </div>
          <div class="service-card-sticky-block fade-in">
            {
              services.map((service) => (
                <div class="service-card-item-block">
                  <a
                    href={`/capabilities/${service.slug}/`}
                    class="service-card-image-block"
                  >
                    <img
                      src={service.image}
                      alt={service.title}
                      class="service-card-image"
                      width="400"
                      height="441"
                      loading="lazy"
                      decoding="async"
                    />
                    <div class="service-card-image-overlay">
                      <div class="service-card-icon-block">
                        <div class="service-hover-icon">
                          <svg
                            width="24"
                            height="24"
                            viewBox="0 0 24 24"
                            fill="none"
                            xmlns="http://www.w3.org/2000/svg"
                          >
                            <path
                              d="M24 1.02211V16.5472C24 17.1117 23.5424 17.5693 22.9779 17.5693C22.4134 17.5693 21.9558 17.1117 21.9558 16.5472V3.48989L1.74492 23.7007C1.54528 23.9002 1.28377 24 1.02216 24C0.760547 24 0.499031 23.9002 0.299391 23.7007C-0.0997969 23.3015 -0.0997969 22.6543 0.299391 22.2551L20.5103 2.04422H7.4528C6.88833 2.04422 6.43069 1.58658 6.43069 1.02211C6.43069 0.457641 6.88833 0 7.4528 0H22.9779C23.5424 0 24 0.457641 24 1.02211Z"
                              fill="white"
                            />
                          </svg>
                        </div>
                      </div>
                    </div>
                  </a>
                  <div class="service-card-content-block">
                    <div class="service-card-text-block">
                      <a
                        href={`/capabilities/${service.slug}/`}
                        class="service-title-link-block"
                      >
                        <h3 class="service-card-title">{service.title}</h3>
                      </a>
                      <p class="service-card-summary">{service.summary}</p>
                    </div>
                  </div>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ WORKFLOW ═══ -->
  <section class="booking-steps-section">
    <div class="section-gap bottom">
      <div class="container">
        <div class="booking-steps-wrapper">
          <SectionHeading
            title="How It Works"
            subtitle="From Part Number to Delivery"
          />
          <div class="booking-steps-content-block fade-in">
            <div class="booking-steps-sticky-block">
              {
                workflowSteps.map((item, i) => (
                  <div class:list={["booking-step-card-block", `is-${i + 1}`]}>
                    <div class="booking-step-image-block">
                      <img
                        src={item.image}
                        alt={item.title}
                        class="booking-step-image"
                        width="400"
                        height="251"
                        loading="lazy"
                        decoding="async"
                      />
                    </div>
                    <div class="booking-step-card-text-block">
                      <span class="booking-step-number" aria-hidden="true">{item.step}</span>
                      <h3 class="booking-step-title">{item.title}</h3>
                      <p class="booking-step-summary">{item.summary}</p>
                    </div>
                  </div>
                ))
              }
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ MATERIALS ═══ -->
  <section class="pricing-section">
    <div class="section-gap bottom">
      <div class="container">
        <SectionHeading
          title="Engine Brands We Support"
          subtitle="Brand Coverage"
        />
        <div class="materials-grid fade-in">
          {
            engineBrands.map((m) => (
              <a
                href={m.href}
                class="material-card material-card-link"
              >
                <h3 class="material-name">{m.title}</h3>
                <p class="material-grades">{m.summary}</p>
              </a>
            ))
          }
        </div>
        <p class="materials-note">
          Need another engine family? <a href="/contact/">Send the model and part list</a>
          so we can check sourcing options and replacement availability.
        </p>
      </div>
    </div>
  </section>

  <!-- ═══ INDUSTRIES ═══ -->
  <section class="map-section">
    <div class="section-gap map map-section--flush">
      <div class="container">
        <SectionHeading title="Applications We Serve" subtitle="Your Sector" />
        <div class="industries-grid fade-in">
          {
            industries.map((ind) => (
              <a
                href={`/industries/${ind.slug}/`}
                class="industry-card industry-card-link"
              >
                <div class="industry-icon">
                  <img
                    src={ind.icon}
                    alt=""
                    aria-hidden="true"
                    class="industry-icon-image"
                    width="148"
                    height="148"
                    loading="lazy"
                    decoding="async"
                  />
                </div>
                <div class="industry-name">{ind.title}</div>
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ POPULAR MTU PART NUMBERS ═══ -->
  <section class="section-gap bottom" style="padding-top: 60px;">
    <div class="container">
      <SectionHeading
        title="Popular MTU Part Numbers"
        subtitle="Most Requested"
      />
      <p class="popular-parts-intro">
        <strong>{mtuParts.length}+ MTU part numbers</strong> indexed by engine series and part category. These high-request parts show the same fields buyers usually need before RFQ: engine type, weight, HS code, stock route, and replacement notes.
      </p>
      <div class="popular-parts-grid">
        {homepageHotParts.map((part) => (
          <article class="popular-part-card">
            <a href={`/part-products/${part.slug}/`} class="popular-part-main-link">
              <span class="popular-part-number">{part.partNumber}</span>
              <span class="popular-part-name">{part.name}</span>
            </a>
            <dl class="popular-part-specs">
              <div>
                <dt>Engine</dt>
                <dd>{getHomepagePartEngine(part)}</dd>
              </div>
              <div>
                <dt>Category</dt>
                <dd>{part.category}</dd>
              </div>
              <div>
                <dt>Weight</dt>
                <dd>{part.weightKg ?? 'Quote check'}</dd>
              </div>
              <div>
                <dt>HS Code</dt>
                <dd>{part.hsCode ?? 'Quote check'}</dd>
              </div>
              <div>
                <dt>NATO</dt>
                <dd>{part.natoNumber && part.natoNumber !== 'N/A' ? part.natoNumber : 'N/A'}</dd>
              </div>
              <div>
                <dt>Stock</dt>
                <dd>{part.stockStatus ?? part.availability}</dd>
              </div>
            </dl>
            {part.replacementFor && part.replacementFor.length > 0 && (
              <p class="popular-part-replacement">Alt: {part.replacementFor.slice(0, 2).join(', ')}</p>
            )}
            <a
              href={`/contact/?source=hot-part-${part.slug}`}
              class="popular-part-rfq"
              data-rfq-modal
              data-rfq-context={`${part.partNumber} ${part.name} - homepage hot part`}
              data-rfq-source={`hot-part-${part.slug}`}
            >Check price & availability</a>
          </article>
        ))}
      </div>
      <p class="popular-parts-cta">
        <a href="/part-products/">Browse all {mtuParts.length}+ MTU part numbers →</a>
        ·
        <a href="/part-products/catalog/mtu-2000-series/">MTU 2000 catalog</a>
        ·
        <a href="/part-products/catalog/mtu-4000-series/">MTU 4000 catalog</a>
      </p>

      <div class="featured-parts-block">
        <h3 class="featured-parts-title">Featured MTU Parts with Real Images</h3>
        <div class="featured-parts-grid">
          {homepageFeaturedParts.map((part) => (
            <a href={`/part-products/${part.slug}/`} class="featured-part-tile">
              <span class="featured-part-image">
                <img
                  src={part.image}
                  alt={part.imageAlt ?? `${part.partNumber} ${part.name}`}
                  width="120"
                  height="90"
                  loading="lazy"
                  decoding="async"
                />
              </span>
              <span class="featured-part-copy">
                <strong>{part.partNumber}</strong>
                <span>{part.name}</span>
                <small>{part.weightKg} · HS {part.hsCode}</small>
              </span>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="home-rfq-hub section-gap bottom" aria-labelledby="home-rfq-hub-heading">
    <div class="container">
      <div class="home-rfq-hub-card fade-in">
        <h2 id="home-rfq-hub-heading" class="home-rfq-hub-title">Have a part number or engine plate?</h2>
        <p class="home-rfq-hub-lead">
          Send your MTU part list with engine serial numbers. We verify fitment, check stock, and quote shipment from Shanghai to your destination.
        </p>
        <div class="home-rfq-hub-actions">
          <a
            href="/contact/?source=homepage-hub"
            class="secondary-button hero home-rfq-hub-primary"
            data-rfq-modal
            data-rfq-context="Homepage parts list inquiry"
            data-rfq-source="homepage-hub"
          >
            <div class="button-content-block">
              <div class="button-text">Request Parts</div>
              <div class="button-text">Request Parts</div>
            </div>
          </a>
          <a href="/products/mtu-spare-parts/" class="home-rfq-hub-secondary">MTU spare parts →</a>
        </div>
        <div class="home-rfq-hub-catalog">
          <div class="home-rfq-hub-catalog-label">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
            Browse Parts Catalog
          </div>
          <div class="home-rfq-hub-catalog-grid" role="list">
            {catalogHubs.map((hub) => (
              <a href={hub.href} class="catalog-hub-card" role="listitem">
                <div class="catalog-hub-card-media">
                  <img
                    src={hub.image}
                    alt=""
                    aria-hidden="true"
                    class="catalog-hub-card-img"
                    width="400"
                    height="240"
                    loading="lazy"
                    decoding="async"
                  />
                </div>
                <div class="catalog-hub-card-body">
                  <h3 class="catalog-hub-card-title">{hub.title}</h3>
                  <p class="catalog-hub-card-subtitle">{hub.subtitle}</p>
                </div>
                <span class="catalog-hub-card-arrow" aria-hidden="true">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>
                </span>
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<script>
  import "../scripts/hero-video.ts";
</script>

<!-- ═══ INLINE STYLES ═══ -->
<style>
  /* ── Hero trust row ── */
  .hero-cta-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 16px 20px;
  }
  .hero-secondary-cta {
    font-family: var(--font-title);
    font-size: 15px;
    font-weight: 600;
    color: var(--color-title);
    text-decoration: none;
    padding: 12px 4px;
    border-bottom: 2px solid transparent;
    transition: color 0.2s ease, border-color 0.2s ease;
  }
  .hero-secondary-cta:hover {
    color: var(--color-primary);
    border-bottom-color: var(--color-primary);
  }
  .hero-secondary-cta:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 3px;
    border-radius: 2px;
  }

  .hero-trust-row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 20px;
    margin-top: 16px;
    padding: 0;
    list-style: none;
  }
  .hero-trust-row li {
    position: relative;
    padding-left: 18px;
    font-size: 14px;
    line-height: 1.5;
    color: #475569;
  }
  .hero-trust-row li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-primary);
    transform: translateY(-50%);
  }

  /* ── Service hint ── */
  .service-bottom-hint {
    margin-top: -40px;
    margin-bottom: 20px;
    text-align: center;
    font-size: 14px;
    line-height: 1.6;
    color: #475569;
  }

  /* ── Section spacing overrides ── */
  .map-section--flush {
    padding-top: 0 !important;
  }
  .case-studies-home-section--compact {
    padding-bottom: 60px !important;
  }
  .testimonial-section--flush {
    padding-top: 0 !important;
    padding-bottom: 0 !important;
  }

  /* ── Key features polish ── */
  .key-feature-section .key-feature-block {
    border: 1px solid var(--color-stroke);
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }
  .key-feature-section .key-feature-block:hover {
    border-color: rgba(20, 110, 245, 0.25);
    box-shadow: 0 4px 16px rgba(20, 110, 245, 0.06);
  }

  /* ── Workflow cards ── */
  .booking-steps-section .booking-step-card-block {
    border: 1px solid var(--color-stroke);
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }
  .booking-steps-section .booking-step-card-block:hover {
