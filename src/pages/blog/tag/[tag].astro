---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import BlogTagNav from '../../../components/BlogTagNav.astro';
import BreadcrumbHero from '../../../components/BreadcrumbHero.astro';
import BlogCard from '../../../components/BlogCard.astro';
import BlogCta from '../../../components/BlogCta.astro';
import FunnelPageView from '../../../components/FunnelPageView.astro';
import { blogTagLabels, blogTags, getPostsByTag, getPostAuthorKey, type BlogTag } from '../../../data/blog';
import { blogTagMeta, getPillarForTag } from '../../../data/blog-tags';
import { breadcrumbSchema, itemListSchema, site } from '../../../data/site';
import '../../../styles/resource-page.css';

export function getStaticPaths() {
  return blogTags.map((tag) => ({ params: { tag }, props: { tag } }));
}

const { tag } = Astro.props as { tag: BlogTag };
const posts = getPostsByTag(tag);
const label = blogTagLabels[tag];
const meta = blogTagMeta[tag];
const pillar = getPillarForTag(tag);
const pageUrl = `${site.url}/blog/tag/${tag}/`;

const jsonLd = [
  breadcrumbSchema([
    { name: 'Home', url: site.url },
    { name: 'Blog', url: `${site.url}/blog/` },
    { name: label, url: pageUrl },
  ]),
  itemListSchema(
    posts.map((post) => ({
      name: post.title,
      url: `${site.url}/blog/${post.slug}/`,
    }))
  ),
];
---

<BaseLayout
  title={`${label} — CNC Machining Blog | Machining Supplier`}
  description={meta.description}
  currentPath={`/blog/tag/${tag}`}
  jsonLd={jsonLd}
  noindex
>
  <FunnelPageView stage="awareness" label={`blog-tag-${tag}`} />
  <BreadcrumbHero
    title={label}
    trail={[
      { label: 'Home', href: '/' },
      { label: 'Blog', href: '/blog/' },
      { label: label },
    ]}
    variant="3"
  />

  <BlogTagNav activeTag={tag} showAllPosts />

  <section class="blog-details-section blog-page-section">
    <div class="section-gap bottom">
      <div class="container">
        <article class="blog-details-content-block resource-page fade-in">
          <nav class="resource-nav" aria-label="Blog navigation">
            <a href="/blog/" class="resource-nav-link">All articles</a>
            <a href="/blog/guides/" class="resource-nav-link">Guide hubs</a>
            <a href="/compare/" class="resource-nav-link">Comparisons</a>
            <a href="/glossary/" class="resource-nav-link">Glossary</a>
            <a href="/resources/" class="resource-nav-link resource-nav-all">Resources</a>
          </nav>

          <p class="resource-intro">{meta.intro}</p>

          <div class="resource-meta">
            <span><strong>{posts.length}</strong> articles</span>
            <span>Topic: <strong>{label}</strong></span>
            <span>Free <strong>DFM review</strong> with every RFQ</span>
          </div>

          {pillar && (
            <aside class="tag-pillar-banner fade-in">
              <span class="tag-pillar-kicker">Start with the guide hub</span>
              <h2 class="tag-pillar-title">
                <a href={`/blog/${pillar.slug}/`}>{pillar.title}</a>
              </h2>
              <p class="tag-pillar-desc">{pillar.description}</p>
              <a href={`/blog/${pillar.slug}/`} class="tag-pillar-link">Read pillar guide →</a>
              <span class="tag-pillar-sep">·</span>
              <a href="/blog/guides/" class="tag-pillar-link">All guide hubs</a>
            </aside>
          )}

          <div class="blog-content-wrapper blog-index-grid">
            {posts.length > 0 ? (
              posts.map((post) => (
                <BlogCard
                  slug={post.slug}
                  title={post.title}
                  image={post.image}
                  authorKey={getPostAuthorKey(post.slug, post.author)}
                  excerpt={post.excerpt}
                />
              ))
            ) : (
              <p class="tag-empty">No indexable articles in this category yet. <a href="/blog/">Browse all posts</a>.</p>
            )}
          </div>

          <p class="resource-related">
            <a href="/blog/">All articles</a>
            <span aria-hidden="true">·</span>
            <a href="/case-studies/">Case studies</a>
            <span aria-hidden="true">·</span>
            <a href="/contact/?source=blog">Upload drawing for DFM review</a>
          </p>
        </article>
      </div>
    </div>
  </section>

  <BlogCta stage="awareness" topic={`tag-${tag}`} />
</BaseLayout>

<style>
  .tag-pillar-banner {
    margin-bottom: 28px;
    padding: 22px 24px;
    border: 1px solid rgba(20, 110, 245, 0.2);
    border-radius: 4px;
    background: rgba(20, 110, 245, 0.06);
    text-align: center;
  }
  .tag-pillar-kicker {
    display: block;
    margin-bottom: 6px;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-primary);
  }
  .tag-pillar-title {
    margin: 0 0 8px;
    font-size: 20px;
    font-weight: 600;
    text-transform: none;
  }
  .tag-pillar-title a {
    color: var(--color-title);
    text-decoration: none;
  }
  .tag-pillar-title a:hover {
    color: var(--color-primary);
  }
  .tag-pillar-desc {
    margin: 0 0 12px;
    font-size: 14px;
    line-height: 1.55;
    color: var(--color-body-text);
  }
  .tag-pillar-link {
    font-size: 14px;
    font-weight: 600;
    color: var(--color-primary);
    text-decoration: none;
  }
  .tag-pillar-link:hover {
    text-decoration: underline;
  }
  .tag-pillar-sep {
    margin: 0 8px;
    color: var(--color-body-text);
    opacity: 0.5;
  }
  .tag-empty {
    grid-column: 1 / -1;
    text-align: center;
    padding: 40px 20px;
    color: var(--color-body-text);
  }
  .tag-empty a {
    color: var(--color-primary);
  }
  .blog-index-grid {
    margin-bottom: 8px;
  }
</style>
