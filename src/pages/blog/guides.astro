---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BreadcrumbHero from '../../components/BreadcrumbHero.astro';
import BlogCta from '../../components/BlogCta.astro';
import BlogTagNav from '../../components/BlogTagNav.astro';
import FunnelPageView from '../../components/FunnelPageView.astro';
import { blogPillars, isBlogIndexWhitelisted } from '../../data/blog-quality';
import { blogPosts } from '../../data/blog';
import { breadcrumbSchema, site } from '../../data/site';
import '../../styles/hub-list-page.css';

const postBySlug = new Map(blogPosts.map((p) => [p.slug, p]));
const availablePillars = blogPillars.filter((pillar) => postBySlug.has(pillar.slug));
const hubCount = availablePillars.length;
const spokeCount = availablePillars.reduce(
  (sum, pillar) => sum + pillar.spokes.filter(isBlogIndexWhitelisted).length,
  0,
);

const hubLabels: Record<string, string> = {
  tolerances: 'Tolerances',
  sourcing: 'Sourcing',
  dfm: 'inquiry prep',
  materials: 'Materials',
  process: 'Process',
  'cost-leadtime': 'Cost',
  quality: 'Quality',
  finishes: 'Finishes',
  drawings: 'Drawings',
  'getting-started': 'Start',
};
---

<BaseLayout
  title="Engine Parts Guide Hubs — MTU Parts & Sourcing | Engine Family"
  description="MTU and diesel engine parts guide hubs covering part-number verification, engine series, genuine OEM sourcing, stock checks, and global delivery."
  currentPath="/blog"
  jsonLd={breadcrumbSchema([
    { name: 'Home', url: site.url },
    { name: 'Blog', url: `${site.url}/blog/` },
    { name: 'Guide Hubs', url: `${site.url}/blog/guides/` },
  ])}
>
  <FunnelPageView stage="awareness" label="guide-hubs" />
  <BreadcrumbHero
    title="Engine Parts<br>Guide Hubs"
    trail={[
      { label: 'Home', href: '/' },
      { label: 'Blog', href: '/blog/' },
      { label: 'Guide Hubs' },
    ]}
    variant="3"
  />

  <BlogTagNav activeHub />

  <section class="service-section">
    <div class="section-gap bottom">
      <div class="container">
        <p class="hub-list-intro fade-in">
          {hubCount} engine-parts guide hubs — each hub links focused subtopics for MTU identification, sourcing, and delivery decisions.
        </p>

        <p class="hub-list-proof-banner fade-in">
          <strong>{hubCount}</strong> hubs · <strong>{spokeCount}</strong> subtopics
          <span aria-hidden="true"> · </span>
          <a href="/products/mtu-spare-parts/mtu-part-number-lookup/">MTU lookup guide</a>
          <span aria-hidden="true"> · </span>
          <a href="/compare/">Comparison tables</a>
        </p>

        <nav class="hub-list-jump-nav fade-in" aria-label="Guide hub topics">
          {availablePillars.map((pillar) => (
            <a href={`#hub-${pillar.id}`} class="hub-list-jump-link">
              {hubLabels[pillar.id] ?? pillar.id}
              <span class="hub-list-jump-count">{pillar.spokes.length}</span>
            </a>
          ))}
        </nav>

        <div class="guides-grid">
          {availablePillars.map((pillar, index) => (
            <article id={`hub-${pillar.id}`} class="guide-card fade-in">
              <header class="guide-card-header">
                <span class="guide-card-kicker">Hub {String(index + 1).padStart(2, '0')}</span>
                <span class="guide-card-badge">{pillar.spokes.length} subtopics</span>
              </header>
              <h2 class="guide-card-title">
                <a href={`/blog/${pillar.slug}/`}>{pillar.title}</a>
              </h2>
              <p class="guide-card-desc">{pillar.description}</p>
              <ul class="guide-card-spokes">
                {pillar.spokes.filter(isBlogIndexWhitelisted).slice(0, 5).map((spoke) => {
                  const spokePost = postBySlug.get(spoke);
                  if (!spokePost) return null;
                  return (
                    <li>
                      <a href={`/blog/${spoke}/`}>{spokePost.title}</a>
                    </li>
                  );
                })}
                {pillar.spokes.filter(isBlogIndexWhitelisted).length > 5 && (
                  <li class="guide-card-more">
                    <a href={`/blog/${pillar.slug}/`}>+{pillar.spokes.filter(isBlogIndexWhitelisted).length - 5} more in hub →</a>
                  </li>
                )}
              </ul>
              <a href={`/blog/${pillar.slug}/`} class="guide-card-cta">Read pillar guide →</a>
            </article>
          ))}
        </div>

        <p class="hub-list-footer-links fade-in">
          <a href="/blog/">All blog articles</a>
          <span aria-hidden="true">·</span>
          <a href="/glossary/">Parts glossary</a>
          <span aria-hidden="true">·</span>
          <a href="/resources/">Engineering resources</a>
          <span aria-hidden="true">·</span>
          <a href="/case-studies/">Project proof</a>
          <span aria-hidden="true">·</span>
          <a href="/contact/?source=blog">Send part number for review</a>
        </p>
      </div>
    </div>
  </section>

  <BlogCta stage="awareness" topic="guide-hubs" />
</BaseLayout>

<style>
  .guides-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
    /* max-width: 1200px; */
    margin: 0 auto;
  }

  .guide-card {
    display: flex;
    flex-direction: column;
    padding: 22px 24px;
    background: var(--color-white);
    border: 1px solid var(--color-stroke);
    border-radius: 4px;
    scroll-margin-top: 120px;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .guide-card:hover {
    border-color: rgba(20, 110, 245, 0.35);
    box-shadow: 0 4px 16px rgba(20, 110, 245, 0.08);
  }

  .guide-card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    margin-bottom: 10px;
  }

  .guide-card-kicker {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-primary);
  }

  .guide-card-badge {
    font-size: 11px;
    font-weight: 600;
    color: var(--color-body-text);
    opacity: 0.7;
  }

  .guide-card-title {
    margin: 0 0 10px;
    font-size: 20px;
    font-weight: 600;
    line-height: 1.35;
    text-transform: none;
  }

  .guide-card-title a {
    color: var(--color-title);
    text-decoration: none;
  }

  .guide-card-title a:hover {
    color: var(--color-primary);
  }

  .guide-card-desc {
    margin: 0 0 14px;
    font-size: 14px;
    line-height: 1.55;
    color: var(--color-body-text);
  }

  .guide-card-spokes {
    margin: 0 0 16px;
    padding-left: 18px;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 6px;
    font-size: 13px;
    line-height: 1.55;
  }

  .guide-card-spokes a {
    color: var(--color-primary);
    font-weight: 600;
    text-decoration: none;
  }

  .guide-card-spokes a:hover {
    text-decoration: underline;
  }

  .guide-card-more {
    list-style: none;
    margin-left: -18px;
    font-weight: 600;
  }

  .guide-card-cta {
    margin-top: auto;
    font-size: 14px;
    font-weight: 600;
    color: var(--color-primary);
    text-decoration: none;
  }

  .guide-card-cta:hover {
    text-decoration: underline;
  }

  @media (max-width: 991px) {
    .guides-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
