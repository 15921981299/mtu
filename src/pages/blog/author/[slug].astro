---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import BreadcrumbHero from '../../../components/BreadcrumbHero.astro';
import BlogCard from '../../../components/BlogCard.astro';
import BlogCta from '../../../components/BlogCta.astro';
import BlogTagNav from '../../../components/BlogTagNav.astro';
import DetailRfqStrip from '../../../components/DetailRfqStrip.astro';
import FunnelPageView from '../../../components/FunnelPageView.astro';
import {
  authors,
  getIndexableBlogPosts,
  getPostAuthorKey,
  getAllAuthorSlugs,
  type AuthorSlug,
} from '../../../data/blog';
import { personProfileSchema, site as siteConfig } from '../../../data/site';
import '../../../styles/resource-page.css';

export function getStaticPaths() {
  return getAllAuthorSlugs().map((slug) => ({ params: { slug }, props: { slug } }));
}

const { slug } = Astro.props as { slug: AuthorSlug };
const author = authors[slug];
const posts = getIndexableBlogPosts().filter((p) => getPostAuthorKey(p.slug, p.author) === slug);
const pageUrl = `${siteConfig.url}/blog/author/${slug}/`;
const quoteHref = `/contact/?source=blog-author-${slug}`;

const profileSchema =
  author.type === 'person'
    ? personProfileSchema({
        name: author.name,
        jobTitle: author.jobTitle,
        description: author.bio,
        url: pageUrl,
        sameAs: author.sameAs ? [...author.sameAs] : undefined,
        knowsAbout: [...author.credentials].slice(0, 4),
      })
    : {
        '@context': 'https://schema.org',
        '@type': 'ProfilePage',
        name: author.name,
        description: author.bio,
        url: pageUrl,
        mainEntity: {
          '@type': 'Organization',
          name: siteConfig.name,
          url: siteConfig.url,
          description: author.bio,
          ...(author.sameAs?.length ? { sameAs: [...author.sameAs] } : {}),
        },
      };
---

<BaseLayout
  title={`${author.name} — CNC Machining Author | Machining Supplier`}
  description={author.bio}
  currentPath="/blog"
  jsonLd={profileSchema}
>
  <FunnelPageView stage="awareness" label={`blog-author-${slug}`} />
  <BreadcrumbHero
    title={author.name}
    trail={[
      { label: 'Home', href: '/' },
      { label: 'Blog', href: '/blog/' },
      { label: author.name },
    ]}
    variant="3"
  />

  <BlogTagNav showAllPosts />

  <section class="blog-details-section blog-page-section">
    <div class="section-gap bottom">
      <div class="container">
        <article class="blog-details-content-block resource-page fade-in">
          <nav class="resource-nav" aria-label="Blog navigation">
            <a href="/blog/" class="resource-nav-link">All articles</a>
            <a href="/blog/guides/" class="resource-nav-link">Guide hubs</a>
            <a href="/about/" class="resource-nav-link">About us</a>
            <a href="/certifications/" class="resource-nav-link resource-nav-all">Certifications</a>
          </nav>

          <div class="resource-meta" aria-label="Author profile">
            <span><strong>{posts.length}</strong> indexed articles</span>
            <span><strong>{author.yearsExperience}+</strong> years experience</span>
            <span><strong>DFM review</strong> Free with quote</span>
          </div>

          <DetailRfqStrip
            quoteHref={quoteHref}
            title="Ready to quote?"
            text="Upload your drawing — articles by this author reflect the same DFM and tolerance guidance we apply during review."
          />

          <div class="author-bio-block">
            <img src={author.avatarUrl} alt={`${author.name} — author photo`} class="author-bio-avatar" width="96" height="96" loading="eager" decoding="async" />
            <p class="author-bio-role">{author.role}</p>
            <p class="author-bio-text">{author.bio}</p>
            <p class="author-bio-experience">{author.yearsExperience}+ years experience</p>
            <ul class="author-credentials">
              {author.credentials.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
            <div class="author-bio-links">
              {author.type === 'person' ? (
                <>
                  <a href="/about/">About our team</a>
                  <a href="/certifications/">Quality & certifications</a>
                </>
              ) : (
                <>
                  <a href="/about/">About us</a>
                  <a href="/blog/guides/">Guide hubs</a>
                </>
              )}
              <a href={quoteHref}>Request a quote</a>
            </div>
            {author.type === 'person' && (
              <p class="author-bio-team">
                Written for <a href="/">{siteConfig.name}</a> — engineer-reviewed, not AI-only content.
              </p>
            )}
            <p class="author-bio-count">{posts.length} indexed articles by {author.name}</p>
          </div>

          {slug !== 'machining-supplier' && (
            <p class="author-team-links">
              Also read:{' '}
              {getAllAuthorSlugs()
                .filter((s) => s !== slug)
                .map((s) => authors[s])
                .map((a, i, arr) => (
                  <>
                    <a href={`/blog/author/${a.slug}/`}>{a.name}</a>
                    {i < arr.length - 1 ? ' · ' : ''}
                  </>
                ))}
            </p>
          )}

          <div class="blog-content-wrapper blog-index-grid">
            {posts.map((post) => (
              <BlogCard
                slug={post.slug}
                title={post.title}
                image={post.image}
                authorKey={getPostAuthorKey(post.slug, post.author)}
              />
            ))}
          </div>

          <p class="resource-related">
            <a href="/blog/">All articles</a>
            <span aria-hidden="true">·</span>
            <a href="/case-studies/">Case studies</a>
            <span aria-hidden="true">·</span>
            <a href={quoteHref}>Upload drawing for DFM review</a>
          </p>
        </article>
      </div>
    </div>
  </section>

  <BlogCta
    stage="awareness"
    topic={`author-${slug}`}
    title="Apply what you read on your next RFQ"
    text="Upload your drawing — we apply the same DFM and tolerance guidance from our blog during engineer-led review."
    primaryLabel="Request a Quote"
    primaryHref={quoteHref}
    primaryEvent={`blog_author_${slug}_rfq`}
    secondaryLabel="All articles"
    secondaryHref="/blog/"
    secondaryEvent="blog_author_index"
  />
</BaseLayout>

<style>
  .author-bio-block {
    margin-bottom: 28px;
    padding: 28px 24px;
    background: var(--color-background);
    border-radius: 4px;
    border: 1px solid var(--color-stroke);
    text-align: center;
  }
  .author-bio-avatar {
    width: 96px;
    height: 96px;
    border-radius: 50%;
    object-fit: cover;
    margin: 0 auto 16px;
    display: block;
  }
  .author-bio-role {
    color: var(--color-primary);
    font-weight: 600;
    font-size: 16px;
    margin-bottom: 12px;
  }
  .author-bio-text {
    color: var(--color-body-text);
    font-size: 16px;
    line-height: 1.7;
    margin-bottom: 12px;
    text-align: left;
  }
  .author-bio-experience {
    color: var(--color-title);
    font-weight: 600;
    font-size: 14px;
    margin-bottom: 16px;
  }
  .author-credentials {
    text-align: left;
    margin: 0 0 20px;
    padding-left: 20px;
    color: var(--color-body-text);
    font-size: 14px;
    line-height: 1.7;
  }
  .author-bio-links {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 16px;
    margin-bottom: 16px;
  }
  .author-bio-links a {
    color: var(--color-primary);
    font-size: 14px;
    font-weight: 500;
    text-decoration: none;
  }
  .author-bio-links a:hover {
    text-decoration: underline;
  }
  .author-bio-links a:focus-visible,
  .author-team-links a:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
    border-radius: 2px;
  }
  .author-bio-team {
    font-size: 13px;
    color: var(--color-body-text);
    margin: 0 0 12px;
  }
  .author-bio-team a {
    color: var(--color-primary);
    text-decoration: none;
  }
  .author-bio-count {
    color: var(--color-body-text);
    font-size: 13px;
    opacity: 0.6;
    margin: 0;
  }
  .author-team-links {
    text-align: center;
    margin: 0 0 24px;
    font-size: 14px;
    color: var(--color-body-text);
  }
  .author-team-links a {
    color: var(--color-primary);
    font-weight: 500;
    text-decoration: none;
  }
  .author-team-links a:hover {
    text-decoration: underline;
  }
  .blog-index-grid {
    margin-bottom: 8px;
  }
</style>
