---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BreadcrumbHero from '../../components/BreadcrumbHero.astro';
import BlogTagNav from '../../components/BlogTagNav.astro';
import BlogLatestCard from '../../components/BlogLatestCard.astro';
import BlogCta from '../../components/BlogCta.astro';
import DetailRfqStrip from '../../components/DetailRfqStrip.astro';
import ExperienceProofNote from '../../components/ExperienceProofNote.astro';
import FunnelNextSteps from '../../components/FunnelNextSteps.astro';
import BlogPostMeta from '../../components/BlogPostMeta.astro';
import FunnelPageView from '../../components/FunnelPageView.astro';
import BlogPillarBanner from '../../components/BlogPillarBanner.astro';
import BlogPillarProof from '../../components/BlogPillarProof.astro';
import { isBlogNoindex } from '../../data/blog-quality';
import { getComparisonByBlogSlug } from '../../data/comparisons';
import { getPostFunnelStage } from '../../data/funnel';
import { mergeBlogDates } from '../../data/blog-changelog';
import { authors, blogPosts, getRelatedPosts, getPostAuthorKey } from '../../data/blog';
import { articleSchema, breadcrumbSchema, site } from '../../data/site';
import '../../styles/resource-page.css';
import '../../styles/hub-list-page.css';
import '../../styles/blog-list-page.css';

export function getStaticPaths() {
  return blogPosts.map((post) => ({ params: { slug: post.slug }, props: { post } }));
}

const { post } = Astro.props;
const related = getRelatedPosts(post.slug, 3);
const pageUrl = `${site.url}/blog/${post.slug}/`;
const authorKey = getPostAuthorKey(post.slug, post.author);
const author = authors[authorKey];
const dates = mergeBlogDates(post.slug, post.publishedAt, 'updatedAt' in post ? post.updatedAt : undefined);
const funnelStage = getPostFunnelStage(post);
const comparison = getComparisonByBlogSlug(post.slug);
const noindex = isBlogNoindex(post.slug);
const quoteHref = `/contact/?source=blog-${post.slug}`;
const primaryTag = post.tags[0];
---

<BaseLayout
  title={'seoTitle' in post && post.seoTitle ? post.seoTitle : post.title}
  description={post.excerpt}
  currentPath="/blog"
  noindex={noindex}
  ogType="article"
  articlePublishedTime={post.publishedAt}
  image={post.mainImage}
  jsonLd={[
    breadcrumbSchema([
      { name: 'Home', url: site.url },
      { name: 'Blog', url: `${site.url}/blog/` },
      { name: post.title, url: pageUrl },
    ]),
    articleSchema({
      title: post.title,
      description: post.excerpt,
      url: pageUrl,
      image: `${site.url}${post.mainImage}`,
      datePublished: post.publishedAt,
      ...(dates.updatedAt ? { dateModified: dates.updatedAt } : {}),
      authorName: author.name,
      authorUrl: `${site.url}/blog/author/${author.slug}/`,
      authorJobTitle: author.type === 'person' ? author.jobTitle : undefined,
      authorSameAs: author.sameAs ? [...author.sameAs] : undefined,
      authorType: author.type === 'person' ? 'Person' : 'Organization',
    }),
  ]}
>
  <FunnelPageView stage={funnelStage} label={post.slug} />
  <BreadcrumbHero
    title={post.title}
    trail={[
      { label: 'Home', href: '/' },
      { label: 'Blog', href: '/blog/' },
      { label: post.title.length > 48 ? `${post.title.slice(0, 48)}…` : post.title },
    ]}
    variant="3"
  />

  <BlogTagNav activeTag={primaryTag} showAllPosts />

  <section class="blog-details-section blog-page-section">
    <div class="section-gap bottom">
      <div class="container">
        <article class="blog-details-content-block blog-index-page blog-article-page fade-in">
          <nav class="resource-nav blog-index-top-nav" aria-label="Blog navigation">
            <a href="/blog/" class="resource-nav-link">All articles</a>
            <a href="/blog/guides/" class="resource-nav-link">Guide hubs</a>
            <a href="/compare/" class="resource-nav-link">Comparisons</a>
            <a href="/glossary/" class="resource-nav-link">Glossary</a>
            <a href="/resources/" class="resource-nav-link resource-nav-all">Resources</a>
          </nav>

          <header class="blog-article-head">
            <BlogPostMeta
              authorKey={authorKey}
              publishedAt={post.publishedAt}
              updatedAt={dates.updatedAt}
              updateNote={dates.updateNote}
              tags={post.tags}
            />
            <p class="blog-article-dek">{post.excerpt}</p>
          </header>

          <div class="blog-article-hero">
            <img
              src={post.mainImage}
              alt={post.title}
              width="1200"
              height="593"
              loading="eager"
              fetchpriority="high"
              decoding="async"
            />
          </div>

          <BlogPillarBanner slug={post.slug} />
          {comparison && (
            <div class="blog-article-compare fade-in">
              <p>
                <strong>Structured comparison available:</strong>{' '}
                <a href={`/compare/${comparison.slug}/`}>View {comparison.title} decision table</a>
              </p>
            </div>
          )}

          <div class="resource-meta" aria-label="Buyer resources">
            <span><strong>Part check</strong> Free with quote</span>
            <span><strong>Response</strong> Within 24 hours</span>
            {comparison && <span><strong>Compare</strong> Decision table linked</span>}
          </div>

          <ExperienceProofNote context="blog" />

          <div class="blog-article-rfq">
            <DetailRfqStrip
              quoteHref={quoteHref}
              title="Ready to quote?"
              text="Send your part number and engine details — we apply the guidance from this article during review and return a parts quote."
            />
          </div>

          <div class="blog-article-prose" set:html={post.content.partOne} />
          <figure class="blog-article-figure">
            <img
              src={post.secondaryImage}
              alt={post.title}
              width="1200"
              height="581"
              loading="lazy"
              decoding="async"
            />
          </figure>
          <div class="blog-article-prose" set:html={post.content.partTwo} />

          <BlogPillarProof slug={post.slug} />

          <FunnelNextSteps stage={funnelStage} comparison={comparison} topic={post.slug} />

          <section class="blog-index-section blog-index-latest" aria-label="Related articles">
            <header class="blog-index-section-head">
              <div>
                <h2>Related articles</h2>
                <p>More engineer-reviewed guides for your RFQ and shop-floor decisions.</p>
              </div>
            </header>
            <ul class="blog-content-wrapper blog-index-latest-grid" role="list">
              {related.map((item, index) => (
                <li class="blog-index-latest-item">
                  <BlogLatestCard
                    slug={item.slug}
                    title={item.title}
                    excerpt={item.excerpt}
                    image={item.image}
                    publishedAt={item.publishedAt}
                    tags={item.tags}
                    authorKey={getPostAuthorKey(item.slug, item.author)}
                    index={index}
                  />
                </li>
              ))}
            </ul>
          </section>

          <footer class="hub-list-footer-links blog-index-footer">
            <a href="/blog/">All blog posts</a>
            <span aria-hidden="true">·</span>
            <a href="/compare/">Comparisons</a>
            <span aria-hidden="true">·</span>
            <a href={quoteHref}>Request a quote</a>
          </footer>
        </article>
      </div>
    </div>
  </section>

  <BlogCta
    post={post}
    title="Turn this guide into a scoped quote"
    text="Send your part number, engine model, serial number, quantity, and destination — we confirm fitment, stock route, and documentation scope in the quote."
    primaryLabel="Request a Quote"
    primaryHref={quoteHref}
    primaryEvent={`blog_${post.slug}_rfq`}
    secondaryLabel="Inquiry checklist"
    secondaryHref="/resources/dfm-checklist/"
    secondaryEvent={`blog_${post.slug}_inquiry`}
  />
</BaseLayout>
