---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BreadcrumbHero from '../../components/BreadcrumbHero.astro';
import BlogCta from '../../components/BlogCta.astro';
import CompareIndustryProof from '../../components/CompareIndustryProof.astro';
import CompareRelatedGrid from '../../components/CompareRelatedGrid.astro';
import DetailPageShell from '../../components/DetailPageShell.astro';
import DetailRfqStrip from '../../components/DetailRfqStrip.astro';
import ExperienceProofNote from '../../components/ExperienceProofNote.astro';
import FunnelPageView from '../../components/FunnelPageView.astro';
import { blogPosts } from '../../data/blog';
import { comparisons, getComparisonCategory, comparisonCategoryMeta, getRelatedIndexableComparisons } from '../../data/comparisons';
import { breadcrumbSchema, faqSchema, site } from '../../data/site';
import '../../styles/resource-page.css';

export function getStaticPaths() {
  return comparisons.map((item) => ({ params: { slug: item.slug }, props: { item } }));
}

const { item } = Astro.props;
const pageUrl = `${site.url}/compare/${item.slug}/`;
const quoteHref = `/contact/?source=compare-${item.slug}`;
const categoryId = getComparisonCategory(item);
const categoryLabel = comparisonCategoryMeta.find((c) => c.id === categoryId)?.label ?? 'Comparisons';
const noindex = true;
const hasRelatedComparisons = getRelatedIndexableComparisons(item.slug, 1).length > 0;
const hasBodySections = (item.bodySections?.length ?? 0) > 0;
const existingBlogSlugs = new Set(blogPosts.map((post) => post.slug));
const relatedLinks = item.relatedLinks.filter((link) => {
  const blogMatch = link.href.match(/^\/blog\/([^/]+)\/$/);
  return !blogMatch || existingBlogSlugs.has(blogMatch[1]);
});
const hasBlogArticle = item.blogSlug ? existingBlogSlugs.has(item.blogSlug) : false;
---

<BaseLayout
  title={item.seoTitle}
  description={item.summary}
  currentPath="/compare"
  noindex={noindex}
  jsonLd={[
    breadcrumbSchema([
      { name: 'Home', url: site.url },
      { name: 'Comparisons', url: `${site.url}/compare/` },
      { name: item.title, url: pageUrl },
    ]),
    faqSchema(item.faqs),
  ]}
>
  <FunnelPageView stage="comparison" label={item.slug} />
  <BreadcrumbHero
    title={item.title}
    trail={[
      { label: 'Home', href: '/' },
      { label: 'Comparisons', href: '/compare/' },
      { label: item.title },
    ]}
    variant="3"
  />

  <DetailPageShell intro={item.summary}>
    <p class="compare-category-back">
      <a href={`/compare/#compare-${categoryId}`}>← All comparisons: {categoryLabel}</a>
    </p>

    <div class="resource-meta">
      <span><strong>{item.rows.length}</strong> comparison dimensions</span>
      <span>{item.optionALabel} vs {item.optionBLabel}</span>
      <span><strong>{item.faqs.length}</strong> FAQs</span>
    </div>

    <ExperienceProofNote context="comparison" />

    <DetailRfqStrip
      quoteHref={quoteHref}
      title="Check parts after you decide"
      text="Send your part number, engine model, serial number, quantity, and destination — we confirm fitment and availability before quotation."
      secondaryHref={noindex ? undefined : '/part-products/'}
      secondaryLabel="MTU part numbers"
    />

    <nav class="resource-nav hub-jump-nav" aria-label="On this page">
      {hasBodySections && (
        <a href="#compare-deep-dive" class="resource-nav-link hub-jump-link">Deep dive</a>
      )}
      <a href="#comparison-table" class="resource-nav-link hub-jump-link">Comparison table</a>
      <a href="#decision-guide" class="resource-nav-link hub-jump-link">Decision guide</a>
      {hasRelatedComparisons && (
        <a href="#related-comparisons" class="resource-nav-link hub-jump-link">Related</a>
      )}
      <a href="#related-resources" class="resource-nav-link hub-jump-link">Resources</a>
      <a href="#faq" class="resource-nav-link hub-jump-link">FAQ</a>
    </nav>

    {item.editorialNote && (
      <div class="compare-editorial-note">
        <strong>How we decide on the shop floor:</strong> {item.editorialNote}
      </div>
    )}

    {hasBodySections && (
      <div id="compare-deep-dive" class="compare-body-stack">
        {item.bodySections!.map((section) => (
          <section class="compare-body-section">
            <h2>{section.heading}</h2>
            {section.paragraphs.map((paragraph) => (
              <p>{paragraph}</p>
            ))}
            {section.bullets && section.bullets.length > 0 && (
              <ul>
                {section.bullets.map((bullet) => (
                  <li>{bullet}</li>
                ))}
              </ul>
            )}
          </section>
        ))}
      </div>
    )}

    <div class="compare-quick-verdict" aria-label="Quick decision summary">
      <div class="compare-verdict-card">
        <span class="compare-verdict-label">{item.optionALabel}</span>
        <p>{item.chooseA[0]}</p>
      </div>
      <div class="compare-verdict-divider" aria-hidden="true">vs</div>
      <div class="compare-verdict-card">
        <span class="compare-verdict-label">{item.optionBLabel}</span>
        <p>{item.chooseB[0]}</p>
      </div>
    </div>

    <h2 id="comparison-table">Side-by-Side Comparison</h2>
    <div class="compare-table-wrap">
      <table class="compare-table">
        <caption class="resource-table-caption">{item.title} — decision dimensions</caption>
        <thead>
          <tr>
            <th scope="col">Dimension</th>
            <th scope="col">{item.optionALabel}</th>
            <th scope="col">{item.optionBLabel}</th>
          </tr>
        </thead>
        <tbody>
          {item.rows.map((row) => (
            <tr>
              <td>{row.dimension}</td>
              <td>{row.optionA}</td>
              <td>{row.optionB}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <div id="decision-guide" class="compare-decision-grid">
      <div class="compare-decision-card">
        <h3>Choose {item.optionALabel} when…</h3>
        <ul>
          {item.chooseA.map((point) => <li>{point}</li>)}
        </ul>
      </div>
      <div class="compare-decision-card">
        <h3>Choose {item.optionBLabel} when…</h3>
        <ul>
          {item.chooseB.map((point) => <li>{point}</li>)}
        </ul>
      </div>
    </div>

    {!noindex && (
      <DetailRfqStrip
        quoteHref={quoteHref}
        title="Ready to quote this path"
        text="Send your part number, engine model, serial number, quantity, and destination — parts verification included before quotation."
        label="Send parts inquiry"
        secondaryHref="/part-products/"
        secondaryLabel="Browse MTU part numbers"
      />
    )}

    <CompareIndustryProof compareSlug={item.slug} category={categoryId} />

    {!noindex && <CompareRelatedGrid slug={item.slug} />}

    <h2 id="related-resources">Related Resources</h2>
    <ul class="resource-list">
      {relatedLinks.map((link) => (
        <li><a href={link.href}>{link.label}</a></li>
      ))}
      {item.deepLink && (
        <li><a href={item.deepLink.href}>{item.deepLink.label} →</a></li>
      )}
      {hasBlogArticle && item.blogSlug && (
        <li><a href={`/blog/${item.blogSlug}/`}>Full in-depth article →</a></li>
      )}
      {!noindex && (
        <>
          <li><a href="/part-products/">MTU part number catalog</a></li>
          <li><a href={quoteHref}>Request parts support for this decision</a></li>
        </>
      )}
    </ul>

    <p class="resource-note detail-page-back">
      {!noindex && (
        <>
          <a href="/part-products/">MTU part numbers</a>
          ·
        </>
      )}
      <a href="/resources/process-selection/">Process selection guide</a>
      ·
      <a href="/compare/">All comparisons</a>
      ·
      <a href={quoteHref}>Request a quote</a>
    </p>

    <h2 id="faq" class="hub-faq-heading">FAQ</h2>
    <div class="hub-faq-list">
      {item.faqs.map((faq) => (
        <details class="hub-faq-item">
          <summary>{faq.question}</summary>
          <p>{faq.answer}</p>
        </details>
      ))}
    </div>
  </DetailPageShell>

  <BlogCta
    stage="comparison"
    topic={item.slug}
    title={`Check your ${item.optionALabel} or ${item.optionBLabel} path`}
    text="Send part numbers and engine details after comparing options — we confirm fitment, availability, and shipping scope in the quote."
    primaryLabel="Send Parts Inquiry"
    primaryHref={quoteHref}
    primaryEvent={`compare_${item.slug}_rfq`}
    secondaryLabel={noindex ? 'Part category guide' : 'MTU part numbers'}
    secondaryHref={noindex ? '/resources/process-selection/' : '/part-products/'}
    secondaryEvent={noindex ? 'compare_process_selection' : `compare_${item.slug}_online`}
  />
</BaseLayout>

<style>
  .compare-category-back {
    margin: 0 0 16px;
    font-size: 14px;
  }
  .compare-category-back a {
    color: var(--color-primary);
    font-weight: 600;
    text-decoration: none;
    cursor: pointer;
  }
  .compare-editorial-note {
    margin: 0 0 28px;
    padding: 16px 20px;
    background: rgba(20, 110, 245, 0.06);
    border: 1px solid rgba(20, 110, 245, 0.2);
    border-radius: 8px;
    font-size: 15px;
    line-height: 1.65;
    color: #475569;
  }
  .compare-body-stack {
    display: flex;
    flex-direction: column;
    gap: 28px;
    margin-bottom: 32px;
    scroll-margin-top: 100px;
  }
  .compare-body-section h2 {
    margin: 0 0 12px;
    font-size: clamp(20px, 2.2vw, 24px);
    line-height: 1.35;
    color: var(--color-title);
    text-transform: none;
  }
  .compare-body-section p {
    margin: 0 0 12px;
    font-size: 15px;
    line-height: 1.75;
    color: #475569;
  }
  .compare-body-section p:last-of-type {
    margin-bottom: 0;
  }
  .compare-body-section ul {
    margin: 12px 0 0;
    padding-left: 20px;
  }
  .compare-body-section li {
    margin-bottom: 8px;
    font-size: 15px;
    line-height: 1.65;
    color: var(--color-body-text);
  }
  .compare-quick-verdict {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 12px;
    align-items: stretch;
    margin-bottom: 28px;
  }
  .compare-verdict-card {
    padding: 16px 18px;
    background: var(--color-background);
    border: 1px solid var(--color-stroke);
    border-radius: 8px;
  }
  .compare-verdict-label {
    display: block;
    margin-bottom: 8px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-primary);
  }
  .compare-verdict-card p {
    margin: 0;
    font-size: 14px;
    line-height: 1.55;
    color: var(--color-body-text);
  }
  .compare-verdict-divider {
    display: flex;
    align-items: center;
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    color: #94a3b8;
  }
  .compare-table-wrap {
    overflow-x: auto;
    margin: 24px 0 32px;
    border: 1px solid var(--color-stroke);
    border-radius: 8px;
    background: var(--color-white);
  }
  .compare-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 15px;
  }
  .compare-table th,
  .compare-table td {
    padding: 14px 16px;
    border-bottom: 1px solid var(--color-stroke);
    text-align: left;
    vertical-align: top;
    color: var(--color-body-text);
    line-height: 1.55;
  }
  .compare-table tbody tr:last-child td {
    border-bottom: none;
  }
  .compare-table tbody tr:hover {
    background: rgba(20, 110, 245, 0.04);
  }
  .compare-table thead tr {
    background: var(--color-background);
  }
  .compare-table th {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-title);
  }
  .compare-decision-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin: 32px 0;
    scroll-margin-top: 100px;
  }
  .compare-decision-card {
    padding: 24px;
    border: 1px solid var(--color-stroke);
    border-radius: 8px;
    background: var(--color-background);
  }
  .compare-decision-card h3 {
    font-size: 18px;
    margin-bottom: 12px;
    color: var(--color-title);
    text-transform: none;
  }
  .compare-decision-card li {
    margin-bottom: 8px;
    line-height: 1.5;
    color: var(--color-body-text);
  }
  #faq,
  #comparison-table,
  #related-resources {
    scroll-margin-top: 100px;
  }
  @media (max-width: 768px) {
    .compare-decision-grid { grid-template-columns: 1fr; }
    .compare-quick-verdict {
      grid-template-columns: 1fr;
    }
    .compare-verdict-divider {
      justify-content: center;
      padding: 4px 0;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .compare-table tbody tr {
      transition: none;
    }
  }
</style>
