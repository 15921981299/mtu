---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BreadcrumbHero from '../../components/BreadcrumbHero.astro';
import DetailPageShell from '../../components/DetailPageShell.astro';
import DetailRfqStrip from '../../components/DetailRfqStrip.astro';
import FunnelPageView from '../../components/FunnelPageView.astro';
import ProductSidebar from '../../components/ProductSidebar.astro';
import { products } from '../../data/products';
import { services } from '../../data/services';
import { breadcrumbSchema, productSchema, serviceSchema, site } from '../../data/site';
import '../../styles/resource-page.css';

export function getStaticPaths() {
  return products.map((product) => ({ params: { slug: product.slug }, props: { product } }));
}

const { product } = Astro.props;
const pageUrl = `${site.url}/products/${product.slug}/`;
const quoteHref = `/contact/?source=product-${product.slug}`;
const capabilitySlugs = (product.capabilitySlugs ?? []) as readonly string[];
const linkedCapabilities = services.filter((s) => capabilitySlugs.includes(s.slug));
const productText = `${product.slug} ${product.title} ${product.summary} ${product.content.partOne}`.toLowerCase();
const productIdentityText = `${product.slug} ${product.title} ${product.h1Title}`.toLowerCase();
const isGeneratedModelPage = /is listed under .* inquiry support/i.test(product.content.partTwo);
const isCoreIndexProduct = new Set([
  'mtu-spare-parts',
  'mtu-2000-series-parts',
  'mtu-4000-series-parts',
  'detroit-diesel-parts',
  'cummins-parts',
  'deutz-parts',
]).has(product.slug);
const isMtuLongTail = /\bmtu\b|mtu-|2000|4000|1163|8000|396|183|538|595|956/.test(productIdentityText);
const shouldNoindex = isGeneratedModelPage && !isCoreIndexProduct && !isMtuLongTail;

const brand = productText.includes('cummins')
  ? 'Cummins'
  : productText.includes('deutz')
    ? 'DEUTZ'
    : productText.includes('detroit')
      ? 'Detroit Diesel'
      : 'MTU';
const applicationFocus = productText.includes('marine') || productText.includes('vessel') || productText.includes('ship')
  ? 'marine propulsion and shipyard maintenance'
  : productText.includes('g-drive') || productText.includes('generator') || productText.includes('genset') || productText.includes('power')
    ? 'generator sets and standby power maintenance'
    : productText.includes('industrial') || productText.includes('construction') || productText.includes('compressor') || productText.includes('pump')
      ? 'industrial equipment and field service'
      : 'fleet maintenance, repair, and spare-parts planning';
const seriesFocus = productText.includes('4000') || productText.includes('8000')
  ? 'large-bore overhaul, fuel, cooling, and control-system items'
  : productText.includes('2000')
    ? 'compact high-speed service parts, sensors, injectors, and maintenance kits'
    : productText.includes('g-drive')
      ? 'G-drive engine service parts for generator applications'
      : 'service, wear, and replacement components confirmed by engine reference';
const partFocus = productText.includes('overhaul') || productText.includes('piston') || productText.includes('liner') || productText.includes('bearing') || productText.includes('valve')
  ? ['piston, liner, bearing, valve-train, and cylinder-head items', 'turbocharging, fuel, cooling, and lubrication parts', 'consolidated overhaul lists with quantity and maintenance-window checks']
  : productText.includes('filter') || productText.includes('gasket') || productText.includes('seal')
    ? ['filters, gaskets, seals, O-rings, and scheduled service items', 'coolant, oil, and lubrication-related consumables', 'small parts that need photos or markings checked before shipment']
    : productText.includes('sensor') || productText.includes('injector') || productText.includes('pump')
      ? ['injectors, pumps, sensors, connectors, and control components', 'fuel-system items checked against rating and engine serial number', 'replacement references where superseded part numbers may exist']
      : ['filters, seals, gaskets, sensors, pumps, and service items', 'fuel, cooling, lubrication, turbocharging, and electrical components', 'overhaul or replacement assemblies checked before quotation'];
const verificationFocus = [
  `${brand} model, rating, and serial number`,
  'part number, old-part photo, or nameplate photo',
  `application details for ${applicationFocus}`,
  'quantity, destination, and required delivery date',
];
---

<BaseLayout
  title={product.seoTitle}
  description={product.summary}
  currentPath="/products"
  image={product.mainImage}
  noindex={shouldNoindex}
  jsonLd={[
    breadcrumbSchema([
      { name: 'Home', url: site.url },
      { name: 'Products', url: `${site.url}/products/` },
      { name: product.title, url: pageUrl },
    ]),
    serviceSchema({
      name: product.title,
      description: product.summary,
      url: pageUrl,
      image: `${site.url}${product.mainImage}`,
    }),
    productSchema({
      name: product.title,
      description: product.summary,
      url: pageUrl,
      image: `${site.url}${product.mainImage}`,
    }),
  ]}
>
  <FunnelPageView stage="selection" label={`product-${product.slug}`} />
  <BreadcrumbHero
    title={product.h1Title}
    trail={[
      { label: 'Home', href: '/' },
      { label: 'Products', href: '/products/' },
      { label: product.title },
    ]}
    variant="2"
  />

  <DetailPageShell intro={product.summary}>
    <img
      slot="hero"
      src={product.mainImage}
      alt={`${product.title} supply and identification support`}
      width="1400"
      height="692"
      loading="eager"
      fetchpriority="high"
      decoding="async"
    />
    <div class="resource-meta">
      <span><strong>Verification</strong> {product.tolerance}</span>
      <span><strong>Lead time</strong> {product.leadTime}</span>
      <span><strong>Inquiry</strong> Part number or nameplate</span>
      <span><strong>Delivery</strong> Global export shipping</span>
    </div>

    <DetailRfqStrip
      quoteHref={quoteHref}
      title={`Check ${product.title.toLowerCase()} availability`}
      text="Send the part number, engine model, serial number, quantity, and destination. We verify compatibility before quotation."
    />

    {linkedCapabilities.length > 0 && (
      <>
        <p class="detail-quick-label">Related support</p>
        <nav class="resource-nav detail-quick-nav" aria-label="Processes for this part">
          {linkedCapabilities.map((capability) => (
            <a href={`/capabilities/${capability.slug}/`} class="resource-nav-link">
              {capability.title}
            </a>
          ))}
        </nav>
      </>
    )}

    <div set:html={product.content.partOne} />
    <section class="detail-differentiation-block">
      <h2>{product.title} Buying Context</h2>
      <p>
        This page is focused on {brand} parts used in {applicationFocus}. For {product.title}, the practical sourcing
        question is not only whether a part name matches, but whether the requested item fits the exact engine build,
        rating, and service situation.
      </p>
      <h3>Typical fitment focus</h3>
      <p>{seriesFocus} are reviewed before quotation so the buyer can compare availability, replacement notes, and shipping route in one request.</p>
      <h3>Common inquiry lines</h3>
      <ul>
        {partFocus.map((item) => <li>{item}</li>)}
      </ul>
      <h3>Information that makes this page different</h3>
      <ul>
        {verificationFocus.map((item) => <li>{item}</li>)}
      </ul>
    </section>
    <figure class="detail-page-figure">
      <img
        src={product.secondImage}
        alt={`${product.title} identification and shipping support`}
        width="1200"
        height="662"
        loading="lazy"
        decoding="async"
      />
    </figure>
    <div set:html={product.content.partTwo} />

    <p class="resource-note detail-page-back">
      <a href="/products/">All products</a>
      ·
      <a href="/part-products/">MTU part numbers</a>
      ·
      <a href="/products/mtu-spare-parts/">MTU parts</a>
      ·
      <a href={quoteHref}>Request a quote</a>
    </p>

    <ProductSidebar
      slot="sidebar"
      activeSlug={product.slug}
      capabilitySlugs={capabilitySlugs}
      quoteHref={quoteHref}
    />
  </DetailPageShell>
</BaseLayout>
