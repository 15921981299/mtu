---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import BreadcrumbHero from '../../../components/BreadcrumbHero.astro';
import BlogCta from '../../../components/BlogCta.astro';
import DetailPageShell from '../../../components/DetailPageShell.astro';
import DetailRfqStrip from '../../../components/DetailRfqStrip.astro';
import FunnelPageView from '../../../components/FunnelPageView.astro';
import { productSubpages } from '../../../data/product-subpages';
import { isSubpageNoindex } from '../../../data/subpage-quality';
import { products } from '../../../data/products';
import { breadcrumbSchema, site } from '../../../data/site';
import '../../../styles/resource-page.css';

export function getStaticPaths() {
  return productSubpages.map((sp) => ({ params: { product: sp.productSlug, subpage: sp.slug }, props: { subpage: sp } }));
}

const { subpage } = Astro.props;
const parent = products.find((p) => p.slug === subpage.productSlug);
const parentTitle = parent?.title ?? subpage.productSlug;
const pageUrl = `${site.url}/products/${subpage.productSlug}/${subpage.slug}/`;
const funnelLabel = `product-sub-${subpage.slug}`;
const quoteHref = `/contact/?source=${funnelLabel}`;
const noindex = isSubpageNoindex(subpage.productSlug, subpage.slug);
---

<BaseLayout
  title={subpage.seoTitle}
  description={subpage.summary}
  currentPath="/products"
  noindex={noindex}
  jsonLd={breadcrumbSchema([
    { name: 'Home', url: site.url },
    { name: 'Products', url: `${site.url}/products/` },
    { name: parentTitle, url: `${site.url}/products/${subpage.productSlug}/` },
    { name: subpage.title, url: pageUrl },
  ])}
>
  <FunnelPageView stage="selection" label={funnelLabel} />
  <BreadcrumbHero
    title={subpage.h1Title}
    trail={[
      { label: 'Home', href: '/' },
      { label: 'Products', href: '/products/' },
      { label: parentTitle, href: `/products/${subpage.productSlug}/` },
      { label: subpage.title },
    ]}
    variant="2"
  />

  <DetailPageShell intro={subpage.summary}>
    <div class="resource-meta" aria-label="Product subpage facts">
      <span><strong>{parentTitle}</strong></span>
      <span><strong>Verification</strong> Part number and engine serial</span>
      <span><strong>Delivery</strong> Global shipping</span>
    </div>

    <DetailRfqStrip
      quoteHref={quoteHref}
      title={`Check ${parentTitle.toLowerCase()} availability`}
      text="Send the part number, engine model, serial number, quantity, and delivery country. We confirm compatibility before shipment."
    />

    <div set:html={subpage.content.partOne} />
    <div set:html={subpage.content.partTwo} />
    <p class="resource-note detail-page-back">
      <a href={`/products/${subpage.productSlug}/`}>← {parentTitle}</a>
      ·
      <a href="/products/">All products</a>
      ·
      <a href="/resources/">Parts guides</a>
      ·
      <a href={quoteHref}>Check availability</a>
    </p>
  </DetailPageShell>

  <BlogCta
    stage="selection"
    topic={subpage.slug}
    title={`Need ${parentTitle.toLowerCase()} support?`}
    text="Send your engine details and part list. We verify part numbers, replacements, and shipping options."
    primaryLabel="Check Parts"
    primaryHref={quoteHref}
    primaryEvent={`product_sub_${subpage.slug}_rfq`}
    secondaryLabel="Parts guides"
    secondaryHref="/resources/"
    secondaryEvent="product_sub_dfm"
  />
</BaseLayout>
