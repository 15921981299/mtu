---
import { getPillarForPost, getPillarBySlug } from '../data/blog-quality';
import { blogPosts } from '../data/blog';

interface Props {
  slug: string;
}

const { slug } = Astro.props;
const pillar = getPillarForPost(slug);
const isPillar = pillar?.slug === slug;
const pillarPost = pillar ? blogPosts.find((post) => post.slug === pillar.slug) : undefined;
const hub = isPillar ? getPillarBySlug(slug) : undefined;
const spokePosts = hub
  ? hub.spokes
      .map((s) => blogPosts.find((p) => p.slug === s))
      .filter((p): p is (typeof blogPosts)[number] => Boolean(p))
  : [];
---

{
  pillar && (isPillar || pillarPost) && (
    <div class="blog-pillar-banner fade-in">
      {isPillar ? (
        <>
          <p>
            <strong>Guide hub:</strong> Start here for this topic — explore focused subtopics below or browse all{' '}
            <a href="/blog/guides/">10 guide hubs</a>.
          </p>
          {spokePosts.length > 0 && (
            <ul class="blog-pillar-spokes">
              {spokePosts.map((post) => (
                <li>
                  <a href={`/blog/${post.slug}/`}>{post.title}</a>
                </li>
              ))}
            </ul>
          )}
        </>
      ) : (
        <p>
          <strong>Part of:</strong>{' '}
          <a href={`/blog/${pillar.slug}/`}>{pillar.title}</a>
          {' '}— read the full guide first, then return here for a focused subtopic.
        </p>
      )}
    </div>
  )
}

<style>
  .blog-pillar-banner {
    margin-bottom: 24px;
    padding: 16px 20px;
    background: #f0f5ff;
    border: 1px solid #c7d9f5;
    border-radius: 4px;
    font-size: 15px;
    line-height: 1.55;
    color: var(--color-body-text);
  }
  .blog-pillar-banner a {
    color: var(--color-primary);
    font-weight: 600;
    text-decoration: none;
  }
  .blog-pillar-banner a:hover {
    text-decoration: underline;
  }
  .blog-pillar-spokes {
    margin: 12px 0 0;
    padding-left: 20px;
    font-size: 14px;
    line-height: 1.55;
  }
  .blog-pillar-spokes a {
    font-weight: 500;
  }
</style>
