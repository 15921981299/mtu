---
import { getRelatedIndexableComparisons } from '../data/comparisons';

interface Props {
  slug: string;
  limit?: number;
}

const { slug, limit = 4 } = Astro.props;
const related = getRelatedIndexableComparisons(slug, limit);
---

{related.length > 0 && (
  <section id="related-comparisons" class="compare-related">
    <h2>Related comparisons</h2>
    <p class="compare-related-intro">
      Same decision stage — compare adjacent options before you upload your drawing for quote.
    </p>
    <div class="compare-related-grid">
      {related.map((item) => (
        <a href={`/compare/${item.slug}/`} class="compare-related-card">
          <span class="compare-related-title">{item.title}</span>
          <span class="compare-related-summary">{item.summary}</span>
          <span class="compare-related-cta">View comparison →</span>
        </a>
      ))}
    </div>
  </section>
)}

<style>
  .compare-related {
    margin: 36px 0;
    scroll-margin-top: 100px;
  }

  .compare-related-intro {
    margin: 0 0 16px;
    font-size: 15px;
    line-height: 1.6;
    color: #64748b;
  }

  .compare-related-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 14px;
  }

  .compare-related-card {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 18px 20px;
    background: var(--color-white);
    border: 1px solid var(--color-stroke);
    border-radius: 8px;
    text-decoration: none;
    cursor: pointer;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .compare-related-card:hover {
    border-color: rgba(20, 110, 245, 0.4);
    box-shadow: 0 4px 16px rgba(20, 110, 245, 0.08);
  }

  .compare-related-card:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 3px;
  }

  .compare-related-title {
    font-family: var(--font-title);
    font-size: 16px;
    font-weight: 600;
    line-height: 1.35;
    color: var(--color-title);
  }

  .compare-related-summary {
    font-size: 13px;
    line-height: 1.55;
    color: #64748b;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .compare-related-cta {
    margin-top: 4px;
    font-size: 13px;
    font-weight: 600;
    color: var(--color-primary);
  }

  @media (max-width: 640px) {
    .compare-related-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .compare-related-card:hover {
      box-shadow: none;
    }
  }
</style>
