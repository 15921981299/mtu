---
import { products } from '../data/products';
import { services } from '../data/services';
import { site } from '../data/site';

interface Props {
  activeSlug: string;
  capabilitySlugs?: readonly string[];
  quoteHref?: string;
}

const {
  activeSlug,
  capabilitySlugs = [],
  quoteHref = '/contact/?source=products',
} = Astro.props;

const linkedCapabilities = services.filter((s) => capabilitySlugs.includes(s.slug));
const arrow = `<svg width="20" height="14" viewBox="0 0 18 12" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M17 6H1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path><path d="M12 11C12 11 17 7.3176 17 6C17 4.6824 12 1 12 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path></svg>`;
---

<aside class="service-details-sidebar">
  <div class="service-category-block">
    <div class="service-category-flex"><h2 class="service-sidebar-title">Product Types</h2></div>
    <div class="service-category-cms-block">
      <div class="service-sidebar-collection-list">
        {products.map((product) => (
          <div class="service-sidebar-collection-items">
            <div class="service-title-block">
              <a
                href={`/products/${product.slug}/`}
                class:list={['service-title-link-block', 'is-2', { active: product.slug === activeSlug }]}
              >
                <div class="service-title">{product.title}</div>
                <div class="arrow-icon" set:html={arrow} />
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>

  {linkedCapabilities.length > 0 && (
    <div class="service-category-block">
      <div class="service-category-flex"><h2 class="service-sidebar-title">Related Capabilities</h2></div>
      <div class="service-category-cms-block">
        <div class="service-sidebar-collection-list">
          {linkedCapabilities.map((svc) => (
            <div class="service-sidebar-collection-items">
              <div class="service-title-block">
                <a href={`/capabilities/${svc.slug}/`} class="service-title-link-block is-2">
                  <div class="service-title">{svc.title}</div>
                  <div class="arrow-icon" set:html={arrow} />
                </a>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  )}

  <div class="service-sidebar-inner">
    <div class="service-contact-info-block">
      <a href={quoteHref} class="sidebar-rfq-link">Request quote for this part -&gt;</a>
      <div class="service-contact-info-title">Helpful references</div>
      <div class="service-contact-info-devider"></div>
      <div class="servoce-contact-link-block">
        <a href="/part-products/" class="service-cotact-info-link">MTU part numbers</a>
        <a href="/products/mtu-spare-parts/mtu-part-number-lookup/" class="service-cotact-email">Part-number lookup</a>
        <a href="/part-products/catalog/mtu-injectors/" class="service-cotact-email">Fuel system catalog</a>
        <a href="/part-products/catalog/mtu-filters/" class="service-cotact-email">Filter catalog</a>
        <a href="/part-products/catalog/mtu-gasket-kits/" class="service-cotact-email">Gasket kit catalog</a>
        <a href="/part-products/catalog/mtu-4000-series/" class="service-cotact-email">MTU 4000 catalog</a>
        <a href={`mailto:${site.email}`} class="service-cotact-email">{site.email}</a>
      </div>
    </div>
  </div>
</aside>
