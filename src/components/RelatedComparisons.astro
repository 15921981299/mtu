---
import type { ComparisonGuide } from '../data/comparisons';

interface Props {
  items: ComparisonGuide[];
  title?: string;
  id?: string;
}

const { items, title = 'Related comparisons', id } = Astro.props;

function editorialExcerpt(note: string, max = 155): string {
  if (note.length <= max) return note;
  const cut = note.slice(0, max);
  const lastSpace = cut.lastIndexOf(' ');
  return `${(lastSpace > 80 ? cut.slice(0, lastSpace) : cut).trim()}…`;
}
---

{items.length > 0 && (
  <aside class="related-comparisons fade-in" id={id}>
    <h2 class="related-comparisons-title">{title}</h2>
    <p class="related-comparisons-desc">
      See how options stack up before you quote — structured tables with clear recommendations.
    </p>
    <ul class="related-comparisons-list">
      {items.map((item) => (
        <li>
          <a href={`/compare/${item.slug}/`} class="related-comparisons-link">
            <span class="related-comparisons-link-title">{item.title}</span>
            <span class="related-comparisons-link-summary">{item.summary}</span>
            {item.editorialNote && (
              <span class="related-comparisons-link-note">
                <strong>Shop floor:</strong> {editorialExcerpt(item.editorialNote)}
              </span>
            )}
          </a>
        </li>
      ))}
    </ul>
    <a href="/compare/" class="related-comparisons-hub">View all comparisons →</a>
  </aside>
)}

<style>
  .related-comparisons {
    margin: 32px 0;
    padding: 24px 28px;
    border: 1px solid var(--color-stroke);
    border-radius: 4px;
    background: var(--color-background);
  }
  .related-comparisons-title {
    margin: 0 0 8px;
    font-size: 20px;
    color: var(--color-title);
    text-transform: none;
  }
  .related-comparisons-desc {
    margin: 0 0 16px;
    font-size: 14px;
    line-height: 1.5;
    color: var(--color-body-text);
  }
  .related-comparisons-list {
    list-style: none;
    margin: 0 0 16px;
    padding: 0;
    display: grid;
    gap: 10px;
  }
  .related-comparisons-link {
    display: block;
    padding: 12px 14px;
    border-radius: 4px;
    border: 1px solid var(--color-stroke);
    background: var(--color-white);
    text-decoration: none;
    transition: border-color 0.2s;
  }
  .related-comparisons-link:hover {
    border-color: rgba(20, 110, 245, 0.4);
  }
  .related-comparisons-link-title {
    display: block;
    font-size: 15px;
    font-weight: 600;
    color: var(--color-title);
    margin-bottom: 4px;
  }
  .related-comparisons-link-summary {
    display: block;
    font-size: 13px;
    line-height: 1.45;
    color: var(--color-body-text);
  }
  .related-comparisons-link-note {
    display: block;
    margin-top: 10px;
    padding-top: 10px;
    border-top: 1px solid var(--color-stroke);
    font-size: 12px;
    line-height: 1.5;
    color: var(--color-body-text);
    opacity: 0.92;
  }
  .related-comparisons-link-note strong {
    color: var(--color-primary);
    font-weight: 600;
  }
  .related-comparisons-hub {
    font-size: 14px;
    font-weight: 600;
    color: var(--color-primary);
    text-decoration: none;
  }
  .related-comparisons-hub:hover {
    text-decoration: underline;
  }
</style>
