---
import { materials } from '../data/materials';
import { site } from '../data/site';

interface Props {
  activeSlug: string;
  quoteHref?: string;
}

const { activeSlug, quoteHref = '/contact/?source=materials' } = Astro.props;
const arrow = `<svg width="20" height="14" viewBox="0 0 18 12" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M17 6H1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path><path d="M12 11C12 11 17 7.3176 17 6C17 4.6824 12 1 12 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path></svg>`;
---

<aside class="service-details-sidebar">
  <div class="service-category-block">
    <div class="service-category-flex"><h2 class="service-sidebar-title">Materials</h2></div>
    <div class="service-category-cms-block">
      <div class="service-sidebar-collection-list">
        {materials.map((material) => (
          <div class="service-sidebar-collection-items">
            <div class="service-title-block">
              <a href={`/materials/${material.slug}/`} class:list={['service-title-link-block', 'is-2', { active: material.slug === activeSlug }]}>
                <div class="service-title">{material.title}</div>
                <div class="arrow-icon" set:html={arrow} />
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
  <div class="service-sidebar-inner">
    <div class="service-contact-info-block">
      <a href={quoteHref} class="sidebar-rfq-link">Request quote for this material →</a>
      <div class="service-contact-info-title">Helpful references</div>
      <div class="service-contact-info-devider"></div>
      <div class="servoce-contact-link-block">
        <a href="/resources/material-certificates/" class="service-cotact-info-link">Material certificates</a>
        <a href="/compare/" class="service-cotact-email">Material comparisons</a>
        <a href={`mailto:${site.email}`} class="service-cotact-email">{site.email}</a>
      </div>
      <div class="service-button-block">
        <a href={quoteHref} class="service-form-button button-white">Request Quote</a>
      </div>
    </div>
  </div>
</aside>
