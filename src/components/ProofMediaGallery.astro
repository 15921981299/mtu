---
import { getProofMedia, type ProofMediaCategory } from '../data/proof-media';

interface Props {
  title?: string;
  intro?: string;
  categories?: ProofMediaCategory[];
  limit?: number;
  compact?: boolean;
}

const {
  title = 'Parts sourcing proof media',
  intro = 'Parts verification, packing, sample, and inquiry workflow visuals buyers can review before sending a part number.',
  categories,
  limit,
  compact = false,
} = Astro.props;

const media = getProofMedia(categories).slice(0, limit ?? undefined);
---

<section class:list={['proof-media', { 'proof-media--compact': compact }]}>
  <div class="proof-media__header">
    <p class="proof-media__kicker">Parts supplier proof</p>
    <h2>{title}</h2>
    <p>{intro}</p>
  </div>

  <div class="proof-media__grid">
    {media.map((item) => (
      <figure class="proof-media__card">
        <img src={item.image} alt={item.alt} width="640" height="426" loading="lazy" decoding="async" />
        <figcaption>
          <span>{item.category}</span>
          <strong>{item.title}</strong>
          <p>{item.caption}</p>
        </figcaption>
      </figure>
    ))}
  </div>
</section>

<style>
  .proof-media {
    margin: 32px 0;
  }

  .proof-media__header {
    max-width: 780px;
    margin-bottom: 18px;
  }

  .proof-media__kicker {
    margin: 0 0 6px;
    color: var(--color-primary);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .proof-media__header h2 {
    margin: 0 0 10px;
    color: var(--color-title);
    font-size: clamp(22px, 2.3vw, 30px);
    line-height: 1.25;
    text-transform: none;
  }

  .proof-media__header p {
    margin: 0;
    color: #475569;
    font-size: 15px;
    line-height: 1.65;
  }

  .proof-media__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
  }

  .proof-media__card {
    overflow: hidden;
    margin: 0;
    border: 1px solid var(--color-stroke);
    border-radius: 8px;
    background: var(--color-white);
  }

  .proof-media__card img {
    display: block;
    width: 100%;
    aspect-ratio: 4 / 3;
    height: auto;
    object-fit: cover;
    background: #e2e8f0;
  }

  .proof-media__card figcaption {
    padding: 14px 15px 16px;
  }

  .proof-media__card span {
    display: block;
    margin-bottom: 6px;
    color: var(--color-primary);
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .proof-media__card strong {
    display: block;
    margin-bottom: 6px;
    color: var(--color-title);
    font-size: 15px;
    line-height: 1.35;
  }

  .proof-media__card p {
    margin: 0;
    color: #475569;
    font-size: 13px;
    line-height: 1.55;
  }

  .proof-media--compact {
    margin: 24px 0;
  }

  .proof-media--compact .proof-media__grid {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .proof-media--compact .proof-media__header h2 {
    font-size: 22px;
  }

  @media (max-width: 860px) {
    .proof-media__grid,
    .proof-media--compact .proof-media__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 560px) {
    .proof-media__grid,
    .proof-media--compact .proof-media__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
