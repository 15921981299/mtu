---
import { getFeaturedCaseStudies } from '../data/industry-proof';
import { testimonials } from '../data/testimonials';

interface Props {
  heading?: string;
  limit?: number;
  showCaseStudies?: boolean;
  showTestimonial?: boolean;
  testimonialIndex?: number;
}

const {
  heading = 'Verified project proof',
  limit = 3,
  showCaseStudies = true,
  showTestimonial = false,
  testimonialIndex = 2,
} = Astro.props;

const studies = showCaseStudies ? getFeaturedCaseStudies().slice(0, limit) : [];
const testimonial = showTestimonial ? testimonials[testimonialIndex] : null;
---

<section class="social-proof-strip section-gap bottom" aria-labelledby="social-proof-heading">
  <div class="container">
    <div class="section-heading-block fade-in">
      <div class="section-title-block">
        <h2 id="social-proof-heading" class="section-title">{heading}</h2>
      </div>
      {showCaseStudies && (
        <p class="social-proof-intro">
          Real tolerance, material, and inspection scope from shipped projects —
          <a href="/certifications/">quality &amp; certifications</a>
          ·
          <a href="/resources/inspection-samples/">report samples</a>
        </p>
      )}
    </div>

    {showCaseStudies && (
      <>
        <div class="social-proof-grid fade-in">
          {studies.map((study) => (
            <a href={`/case-studies/${study.slug}/`} class="social-proof-card">
              <span class="social-proof-industry">{study.industry}</span>
              <span class="social-proof-title">{study.title}</span>
              <span class="social-proof-spec">{study.tolerance} · {study.quantity}</span>
            </a>
          ))}
        </div>

        <p class="social-proof-footer fade-in">
          <a href="/case-studies/">All case studies</a>
          <span aria-hidden="true">·</span>
          <a href="/certifications/">ISO 9001 &amp; inspection process</a>
        </p>
      </>
    )}

    {testimonial && (
      <blockquote class="social-proof-quote fade-in">
        <p class="social-proof-quote-text">"{testimonial.quote}"</p>
        <footer class="social-proof-quote-author">
          <strong>{testimonial.name}</strong>
          <span>{testimonial.role}</span>
        </footer>
      </blockquote>
    )}
  </div>
</section>

<style>
  .social-proof-intro {
    margin: 8px 0 0;
    font-size: 15px;
    line-height: 1.55;
    color: var(--color-body-text);
  }

  .social-proof-intro a {
    color: var(--color-primary);
    font-weight: 600;
    text-decoration: none;
  }

  .social-proof-intro a:hover {
    text-decoration: underline;
  }
  .social-proof-intro a:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
    border-radius: 2px;
  }

  .social-proof-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 14px;
    margin-top: 24px;
  }

  .social-proof-card {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 18px 20px;
    background: var(--color-white);
    border: 1px solid var(--color-stroke);
    border-radius: 8px;
    text-decoration: none;
    color: inherit;
    cursor: pointer;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .social-proof-card:hover {
    border-color: rgba(20, 110, 245, 0.4);
    box-shadow: 0 6px 20px rgba(20, 110, 245, 0.08);
  }

  .social-proof-card:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }

  .social-proof-industry {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-primary);
  }

  .social-proof-title {
    font-size: 16px;
    font-weight: 600;
    color: var(--color-title);
    line-height: 1.35;
  }

  .social-proof-spec {
    font-size: 13px;
    color: var(--color-body-text);
  }

  .social-proof-footer {
    margin: 18px 0 0;
    text-align: center;
    font-size: 14px;
    color: var(--color-body-text);
  }

  .social-proof-footer a {
    color: var(--color-primary);
    font-weight: 600;
    text-decoration: none;
  }

  .social-proof-footer a:hover {
    text-decoration: underline;
  }
  .social-proof-footer a:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
    border-radius: 2px;
  }

  .social-proof-footer span {
    margin: 0 10px;
    opacity: 0.45;
  }

  .social-proof-quote {
    margin: 28px auto 0;
    max-width: 720px;
    padding: 22px 24px;
    background: var(--color-white);
    border: 1px solid var(--color-stroke);
    border-left: 3px solid var(--color-primary);
    border-radius: 4px;
  }

  .social-proof-quote-text {
    margin: 0 0 12px;
    font-size: 15px;
    line-height: 1.65;
    color: var(--color-body-text);
    font-style: italic;
  }

  .social-proof-quote-author {
    display: flex;
    flex-direction: column;
    gap: 2px;
    font-size: 13px;
    color: var(--color-body-text);
  }

  .social-proof-quote-author strong {
    color: var(--color-title);
  }
</style>
