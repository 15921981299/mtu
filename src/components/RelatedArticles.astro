---
import { blogPosts } from '../data/blog';
import { isBlogNoindex } from '../data/blog-quality';
import { resolveHubArticles } from '../data/related-content';

interface Props {
  slugs: string[];
  title?: string;
}

const { slugs, title = 'Related Guides' } = Astro.props;

const posts = resolveHubArticles(slugs)
  .map((slug) => blogPosts.find((post) => post.slug === slug))
  .filter((post): post is (typeof blogPosts)[number] => Boolean(post))
  .filter((post) => !isBlogNoindex(post.slug))
  .slice(0, 3);

if (posts.length === 0) return null;
---

<div class="related-articles fade-in">
  <h3 class="related-articles-title">{title}</h3>
  <ul class="related-articles-list">
    {posts.map((post) => (
      <li>
        <a href={`/blog/${post.slug}/`} class="related-articles-link">{post.title}</a>
      </li>
    ))}
  </ul>
  <a href="/blog/" class="related-articles-more">View all articles →</a>
</div>

<style>
  .related-articles {
    margin-top: 48px;
    padding: 28px 24px;
    border: 1px solid var(--color-stroke);
    border-radius: 4px;
    background: var(--color-white);
  }
  .related-articles-title {
    font-size: 18px;
    color: var(--color-title);
    margin: 0 0 16px;
    text-transform: none;
  }
  .related-articles-list {
    list-style: none;
    margin: 0 0 16px;
    padding: 0;
    display: grid;
    gap: 10px;
  }
  .related-articles-link {
    display: block;
    font-size: 15px;
    font-weight: 500;
    color: var(--color-primary);
    text-decoration: none;
    line-height: 1.45;
  }
  .related-articles-link:hover {
    text-decoration: underline;
  }
  .related-articles-more {
    font-size: 14px;
    font-weight: 600;
    color: var(--color-primary);
    text-decoration: none;
  }
  .related-articles-more:hover {
    text-decoration: underline;
  }
</style>
