---
interface Props {
  materialName: string;
  grades?: string;
}

const { materialName, grades } = Astro.props;
const materialLabel = materialName.toLowerCase();
---

<section class="material-quote-guide" aria-labelledby={`material-quote-guide-${materialLabel.replace(/[^a-z0-9]+/g, '-')}`}>
  <div class="material-quote-guide__header">
    <p class="material-quote-guide__eyebrow">Parts inquiry guide</p>
    <h2 id={`material-quote-guide-${materialLabel.replace(/[^a-z0-9]+/g, '-')}`}>How to specify {materialLabel} parts for a clean quote</h2>
    <p>
      A reference page should not leave buyers guessing. Send these details with your part number and engine information so we can confirm fitment,
      sourcing route, documentation scope, and delivery risk before quoting.
    </p>
  </div>
  <div class="material-quote-guide__grid">
    <article>
      <h3>Part number and engine</h3>
      <p>Specify the exact part number, engine model, serial number, and application when it matters. Common reference group: {grades || 'standard engine part categories'}.</p>
    </article>
    <article>
      <h3>Photos and markings</h3>
      <p>Send nameplate photos, old-part markings, connector views, port orientation, and installed position when available.</p>
    </article>
    <article>
      <h3>Documents and shipment</h3>
      <p>Tell us if you need supplier documents, packing photos, invoice details, customs notes, or shipment photos.</p>
    </article>
  </div>
  <div class="material-quote-guide__footer">
    <strong>Best first email:</strong>
    Part number + engine model + serial number + quantity + target delivery date + destination country.
  </div>
</section>

<style>
  .material-quote-guide {
    margin: 32px 0;
    padding: 28px;
    border: 1px solid rgba(31, 41, 55, 0.12);
    border-radius: 8px;
    background: #ffffff;
    box-shadow: 0 18px 44px rgba(15, 23, 42, 0.06);
  }

  .material-quote-guide__header {
    max-width: 760px;
    margin-bottom: 22px;
  }

  .material-quote-guide__eyebrow {
    margin: 0 0 8px;
    color: #c2410c;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .material-quote-guide h2 {
    margin: 0 0 10px;
    color: #111827;
    font-size: 28px;
    line-height: 1.2;
  }

  .material-quote-guide p {
    margin: 0;
    color: #4b5563;
    line-height: 1.65;
  }

  .material-quote-guide__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
  }

  .material-quote-guide article {
    padding: 18px;
    border: 1px solid rgba(31, 41, 55, 0.1);
    border-radius: 8px;
    background: #f8fafc;
  }

  .material-quote-guide h3 {
    margin: 0 0 8px;
    color: #111827;
    font-size: 17px;
    line-height: 1.35;
  }

  .material-quote-guide__footer {
    margin-top: 18px;
    padding: 14px 16px;
    border-left: 3px solid #c2410c;
    background: #fff7ed;
    color: #374151;
    line-height: 1.6;
  }

  .material-quote-guide__footer strong {
    color: #111827;
  }

  @media (max-width: 991px) {
    .material-quote-guide {
      padding: 22px;
    }

    .material-quote-guide h2 {
      font-size: 24px;
    }

    .material-quote-guide__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
