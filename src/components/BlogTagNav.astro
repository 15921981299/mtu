---
import { blogTagLabels, blogTags } from '../data/blog';

interface Props {
  activeHub?: boolean;
  activeTag?: (typeof blogTags)[number];
  showAllPosts?: boolean;
  activeAllPosts?: boolean;
}

const { activeHub = false, activeTag, showAllPosts = false, activeAllPosts = false } = Astro.props;
---

<section class="blog-tags-section">
  <div class="container">
    <nav class="blog-tag-nav fade-in" aria-label="Blog topics">
      <a
        href="/blog/guides/"
        class:list={['blog-tag-link', 'blog-tag-link--hub', { 'blog-tag-link--active': activeHub }]}
        aria-current={activeHub ? 'page' : undefined}
      >
        Guide Hubs
      </a>
      {blogTags.map((tag) => (
        <a
          href={`/blog/tag/${tag}/`}
          class:list={['blog-tag-link', { 'blog-tag-link--active': tag === activeTag }]}
          aria-current={tag === activeTag ? 'page' : undefined}
        >
          {blogTagLabels[tag]}
        </a>
      ))}
      {(showAllPosts || activeAllPosts) && (
        <a
          href="/blog/"
          class:list={['blog-tag-link', { 'blog-tag-link--active': activeAllPosts }]}
          aria-current={activeAllPosts ? 'page' : undefined}
        >
          All Posts
        </a>
      )}
    </nav>
  </div>
</section>

<style>
  .blog-tags-section {
    padding-top: 8px;
  }

  .blog-tag-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    justify-content: center;
  }

  .blog-tag-link {
    padding: 8px 16px;
    border-radius: 999px;
    border: 1px solid var(--color-stroke);
    font-size: 13px;
    font-weight: 600;
    color: var(--color-body-text);
    background: var(--color-white);
    text-decoration: none;
    transition: border-color 0.2s, background 0.2s, color 0.2s;
  }

  .blog-tag-link:hover,
  .blog-tag-link--active {
    border-color: rgba(20, 110, 245, 0.45);
    background: rgba(20, 110, 245, 0.08);
    color: var(--color-primary);
  }

  .blog-tag-link--hub {
    border-color: rgba(20, 110, 245, 0.35);
    background: rgba(20, 110, 245, 0.1);
    color: var(--color-primary);
  }

  .blog-tag-link--hub.blog-tag-link--active {
    border-color: rgba(20, 110, 245, 0.55);
    background: rgba(20, 110, 245, 0.14);
  }
</style>
