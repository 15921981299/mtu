---
import { site } from '../data/site';

interface Props {
  currentPath?: string;
}

const { currentPath = '/' } = Astro.props;
const isActive = (path: string) => currentPath === path || (path !== '/' && currentPath.startsWith(path));
const productsActive = isActive('/products') || isActive('/part-products');
const supportActive = isActive('/capabilities') || isActive('/industries');
const companyActive = isActive('/about') || isActive('/certifications');
const resourcesActive = isActive('/resources') || isActive('/part-products/catalog');
---

<header class="header">
  <div class="container">
    <nav class="navbar" aria-label="main navigation">
      <div class="navbar-wrapper">
        <a href="/" class="navbar-brand" aria-label="Engine Family home">
          <img src={site.logo.default} alt="Engine Family logo" class="brand-logo is-1" width={site.logo.width} height={site.logo.height} loading="eager" fetchpriority="high" decoding="async" />
          <img src={site.logo.default} alt="Engine Family logo" class="brand-logo is-2" width={site.logo.width} height={site.logo.height} loading="eager" fetchpriority="high" decoding="async" />
        </a>

        <div class="nav-menu-block" id="nav-menu">
          <div class="nav-mobile-brand">
            <a href="/" class="navbar-brand" aria-label="Engine Family home">
              <img src={site.logo.default} alt="Engine Family logo" class="brand-logo" width={site.logo.width} height={site.logo.height} loading="eager" decoding="async" />
            </a>
            <button class="nav-close-btn" aria-label="close menu" id="nav-close">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M18 6L6 18M6 6l12 12" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
              </svg>
            </button>
          </div>

          <ul class="nav-menu">
            <li class="nav-menu-list nav-desktop-hide">
              <div class="nav-menu-link-wrapper">
                <a href="/" class:list={['nav-menu-link', { active: isActive('/') }]} aria-current={isActive('/') ? 'page' : undefined}>Home</a>
                <div class="nav-link-line-shape"></div>
              </div>
            </li>

            <li class="nav-menu-list">
              <div class="nav-dropdown">
                <button class="nav-dropdown-toggle" aria-expanded="false" aria-haspopup="true">
                  <span class="nav-menu-link" class:list={['nav-menu-link', { active: productsActive }]}>Parts</span>
                  <svg class="nav-dropdown-icon" width="14" height="8" viewBox="0 0 14 8" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M13 1C13 1 8.581 7 7 7C5.419 7 1 1 1 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
                  </svg>
                  <div class="nav-link-line-shape"></div>
                </button>
                <div class="nav-dropdown-list mega-menu">
                  <div class="nav-dropdown-flex">
                    <div class="nav-dropdown-column">
                      <div class="nav-heading">Engine Parts</div>
                      <a href="/products/mtu-spare-parts/" class="nav-dropdown-link-block"><div class="nav-dropdown-shape"></div><span class="nav-dropdown-link-text">MTU Spare Parts</span></a>
                      <a href="/products/mtu-2000-series-parts/" class="nav-dropdown-link-block"><div class="nav-dropdown-shape"></div><span class="nav-dropdown-link-text">MTU 2000 Series Parts</span></a>
                      <a href="/products/mtu-4000-series-parts/" class="nav-dropdown-link-block"><div class="nav-dropdown-shape"></div><span class="nav-dropdown-link-text">MTU 4000 Series Parts</span></a>
                      <a href="/part-products/" class="nav-dropdown-link-block"><div class="nav-dropdown-shape"></div><span class="nav-dropdown-link-text">MTU Part Numbers</span></a>
                      <a href="/products/detroit-diesel-parts/" class="nav-dropdown-link-block"><div class="nav-dropdown-shape"></div><span class="nav-dropdown-link-text">Detroit Diesel Parts</span></a>
                      <a href="/products/cummins-parts/" class="nav-dropdown-link-block"><div class="nav-dropdown-shape"></div><span class="nav-dropdown-link-text">Cummins Parts</span></a>
                      <a href="/products/deutz-parts/" class="nav-dropdown-link-block"><div class="nav-dropdown-shape"></div><span class="nav-dropdown-link-text">DEUTZ Parts</span></a>
                      <a href="/products/" class="nav-dropdown-link-block"><div class="nav-dropdown-shape"></div><span class="nav-dropdown-link-text">All Parts</span></a>
                    </div>
                    <div class="nav-dropdown-column">
                      <div class="nav-heading">Service & Support</div>
                      <a href="/capabilities/mtu-engine-parts/" class="nav-dropdown-link-block"><div class="nav-dropdown-shape"></div><span class="nav-dropdown-link-text">MTU Engine Parts</span></a>
                      <a href="/capabilities/cummins-engine-parts/" class="nav-dropdown-link-block"><div class="nav-dropdown-shape"></div><span class="nav-dropdown-link-text">Cummins Engine Parts</span></a>
                      <a href="/capabilities/deutz-engine-parts/" class="nav-dropdown-link-block"><div class="nav-dropdown-shape"></div><span class="nav-dropdown-link-text">DEUTZ Engine Parts</span></a>
                      <a href="/capabilities/genuine-oem-parts/" class="nav-dropdown-link-block"><div class="nav-dropdown-shape"></div><span class="nav-dropdown-link-text">Genuine OEM Parts</span></a>
                      <a href="/capabilities/" class="nav-dropdown-link-block"><div class="nav-dropdown-shape"></div><span class="nav-dropdown-link-text">All Support</span></a>
                    </div>
                    <div class="nav-dropdown-column">
                      <div class="nav-heading">Applications</div>
                      <a href="/industries/marine/" class="nav-dropdown-link-block"><div class="nav-dropdown-shape"></div><span class="nav-dropdown-link-text">Marine</span></a>
                      <a href="/industries/industrial-engines/" class="nav-dropdown-link-block"><div class="nav-dropdown-shape"></div><span class="nav-dropdown-link-text">Industrial Engines</span></a>
                      <a href="/industries/power-generation/" class="nav-dropdown-link-block"><div class="nav-dropdown-shape"></div><span class="nav-dropdown-link-text">Power Generation</span></a>
                      <a href="/industries/rail/" class="nav-dropdown-link-block"><div class="nav-dropdown-shape"></div><span class="nav-dropdown-link-text">Rail</span></a>
                      <a href="/industries/" class="nav-dropdown-link-block"><div class="nav-dropdown-shape"></div><span class="nav-dropdown-link-text">All Applications</span></a>
                    </div>
                  </div>
                </div>
              </div>
            </li>

            <li class="nav-menu-list mobile-none"><div class="dot"></div></li>
            <li class="nav-menu-list">
              <div class="nav-menu-link-wrapper">
                <a href="/capabilities/" class:list={['nav-menu-link', { active: supportActive }]}>Service & Support</a>
                <div class="nav-link-line-shape"></div>
              </div>
            </li>

            <li class="nav-menu-list mobile-none"><div class="dot"></div></li>
            <li class="nav-menu-list">
              <div class="nav-dropdown">
                <button class="nav-dropdown-toggle" aria-expanded="false" aria-haspopup="true">
                  <span class="nav-menu-link" class:list={['nav-menu-link', { active: resourcesActive }]}>Catalogs</span>
                  <svg class="nav-dropdown-icon" width="14" height="8" viewBox="0 0 14 8" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M13 1C13 1 8.581 7 7 7C5.419 7 1 1 1 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
                  </svg>
                  <div class="nav-link-line-shape"></div>
                </button>
                <div class="nav-dropdown-list nav-dropdown-list--grid">
                  <div class="nav-dropdown-panel">
                    <a href="/part-products/" class="nav-dropdown-link-block"><div class="nav-dropdown-shape"></div><span class="nav-dropdown-link-text">All MTU Part Numbers</span></a>
                    <a href="/part-products/catalog/mtu-2000-series/" class="nav-dropdown-link-block"><div class="nav-dropdown-shape"></div><span class="nav-dropdown-link-text">MTU 2000 Catalog</span></a>
                    <a href="/part-products/catalog/mtu-4000-series/" class="nav-dropdown-link-block"><div class="nav-dropdown-shape"></div><span class="nav-dropdown-link-text">MTU 4000 Catalog</span></a>
                    <a href="/part-products/catalog/mtu-injectors/" class="nav-dropdown-link-block"><div class="nav-dropdown-shape"></div><span class="nav-dropdown-link-text">Fuel System Parts</span></a>
                    <a href="/part-products/catalog/mtu-filters/" class="nav-dropdown-link-block"><div class="nav-dropdown-shape"></div><span class="nav-dropdown-link-text">Filters</span></a>
                    <a href="/part-products/catalog/mtu-sensors/" class="nav-dropdown-link-block"><div class="nav-dropdown-shape"></div><span class="nav-dropdown-link-text">Sensors</span></a>
                  </div>
                </div>
              </div>
            </li>

            <li class="nav-menu-list mobile-none"><div class="dot"></div></li>
            <li class="nav-menu-list">
              <div class="nav-dropdown">
                <button class="nav-dropdown-toggle" aria-expanded="false" aria-haspopup="true">
                  <span class="nav-menu-link" class:list={['nav-menu-link', { active: companyActive }]}>About Us</span>
                  <svg class="nav-dropdown-icon" width="14" height="8" viewBox="0 0 14 8" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M13 1C13 1 8.581 7 7 7C5.419 7 1 1 1 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
                  </svg>
                  <div class="nav-link-line-shape"></div>
                </button>
                <div class="nav-dropdown-list">
                  <div class="nav-dropdown-panel">
                    <a href="/about/" class="nav-dropdown-link-block"><div class="nav-dropdown-shape"></div><span class="nav-dropdown-link-text">Company</span></a>
                    <a href="/certifications/" class="nav-dropdown-link-block"><div class="nav-dropdown-shape"></div><span class="nav-dropdown-link-text">Quality Policy</span></a>
                    <a href="/contact/" class="nav-dropdown-link-block"><div class="nav-dropdown-shape"></div><span class="nav-dropdown-link-text">Parts Inquiry</span></a>
                  </div>
                </div>
              </div>
            </li>

            <li class="nav-menu-list mobile-none"><div class="dot"></div></li>
            <li class="nav-menu-list">
              <div class="nav-menu-link-wrapper">
                <a href="/contact/" class:list={['nav-menu-link', 'nav-menu-link--cta', { active: isActive('/contact') }]}>Contact</a>
                <div class="nav-link-line-shape"></div>
              </div>
            </li>
          </ul>
        </div>

        <a href="/contact/" class="contact-number-block contact-number-block--compact" aria-label="Contact us">
          <div class="contact-icon-block">
            <div class="contact-icon-circle-one"></div>
            <div class="contact-icon-circle-two"></div>
            <div class="contact-icon">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M6.158 2.712L5.756 1.806C5.492 1.214 5.361.918 5.164.691C4.917.407 4.595.198 4.236.088C3.949 0 3.624 0 2.976 0C2.028 0 1.554 0 1.156.182C.687.397.263.863.095 1.351C-.048 1.764.075 3.04.948 12.09C1.948 14.91 3.09 16.052 5.91 17.052C8.73 18.052 10.641 17.925 14.96 17.925C15.811 18.008 16.649 17.905 17.137 17.737C17.603 17.313 17.818 16.844 18 16.446V15.024C18 14.376 18 14.051 17.912 13.764C17.802 13.405 17.593 13.083 17.309 12.836C17.082 12.639 16.786 12.508 16.194 12.244L15.288 11.842C14.646 11.557 14.326 11.414 14 11.383C13.688 11.353 13.373 11.397 13.081 11.511C12.776 11.63 12.506 11.854 11.967 12.304C11.43 12.751 10.834 13.095 10.543 13.201C10.159 13.24 9.852 13.195 9.507 13.144C9.242 13.003 8.713 12.72 8.713 12.72C7.067 11.841 6.16 10.933 5.28 9.287C4.997 8.758 4.856 8.493 4.805 8.148C4.76 7.841 4.799 7.457 4.905 7.166C5.025 6.838 5.249 6.57 5.696 6.033C6.146 5.494 6.37 5.224 6.489 4.919C6.603 4.627 6.647 4.312 6.617 4C6.586 3.675 6.443 3.354 6.158 2.712Z" fill="currentColor"></path>
              </svg>
            </div>
          </div>
          <div class="contact-text-block contact-text-block--desktop">
            <p class="contact-text">Inquiry</p>
            <span class="contact-text hover">{site.email}</span>
          </div>
        </a>
        <button class="menu-button" aria-label="open menu" id="menu-toggle">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M3 12h18M3 6h18M3 18h18" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
          </svg>
        </button>
      </div>
    </nav>
  </div>
</header>

<script>
  import '../scripts/nav.ts';
</script>
