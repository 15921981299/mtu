---
interface Props {
  partType?: string;
}

const { partType = 'machined parts' } = Astro.props;

const requirements = [
  '2D drawing PDF with tolerances and revision number',
  'STEP/STP file for geometry review and CAM planning',
  'Material grade, condition, and any substitution limits',
  'Quantity, target lead time, and destination country',
  'Surface finish, heat treatment, coating, or plating needs',
  'Critical dimensions, inspection report, and material cert requirements',
];
---

<section class="quote-requirements" aria-labelledby="quote-requirements-title">
  <div class="quote-requirements-header">
    <p class="quote-requirements-kicker">RFQ checklist</p>
    <h2 id="quote-requirements-title">What to send for a reliable {partType} quote</h2>
    <p>
      Clear RFQ details help us quote the right process, tolerance plan, inspection scope, and lead time without extra clarification emails.
    </p>
  </div>
  <ul class="quote-requirements-list">
    {requirements.map((item) => (
      <li>{item}</li>
    ))}
  </ul>
</section>

<style>
  .quote-requirements {
    margin: 28px 0 32px;
    padding: 22px 24px;
    border: 1px solid rgba(20, 110, 245, 0.16);
    border-radius: 6px;
    background: linear-gradient(180deg, rgba(20, 110, 245, 0.06), rgba(15, 23, 42, 0.02));
  }

  .quote-requirements-header {
    max-width: 760px;
  }

  .quote-requirements-kicker {
    margin: 0 0 6px;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-primary);
  }

  .quote-requirements h2 {
    margin: 0 0 8px;
    font-size: 22px;
    line-height: 1.3;
    color: var(--color-title);
    text-transform: none;
  }

  .quote-requirements p {
    margin: 0;
    font-size: 15px;
    line-height: 1.65;
    color: var(--color-body-text);
  }

  .quote-requirements-list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px 18px;
    margin: 18px 0 0;
    padding: 0;
    list-style: none;
  }

  .quote-requirements-list li {
    position: relative;
    padding-left: 20px;
    font-size: 14px;
    line-height: 1.55;
    color: var(--color-body-text);
  }

  .quote-requirements-list li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.68em;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--color-primary);
  }

  @media (max-width: 720px) {
    .quote-requirements {
      padding: 20px 18px;
    }

    .quote-requirements-list {
      grid-template-columns: 1fr;
    }
  }
</style>
