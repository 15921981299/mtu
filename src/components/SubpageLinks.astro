---
interface SubpageItem {
  href: string;
  title: string;
  summary: string;
}

interface Props {
  title: string;
  items: SubpageItem[];
}

const { title, items } = Astro.props;
---

{items.length > 0 && (
  <section class="subpage-links" aria-label={title}>
    <h2 class="hub-faq-heading">{title}</h2>
    <div class="hub-grid">
      {items.map((it) => (
        <a href={it.href} class="hub-card subpage-link-card">
          <span class="hub-card-title">{it.title}</span>
          <span class="hub-card-summary">{it.summary}</span>
        </a>
      ))}
    </div>
  </section>
)}
