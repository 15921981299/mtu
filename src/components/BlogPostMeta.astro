---
import { authors, blogTagLabels, type AuthorSlug, type BlogTag } from '../data/blog';

interface Props {
  authorKey: AuthorSlug;
  publishedAt: string;
  updatedAt?: string;
  updateNote?: string;
  tags: readonly BlogTag[];
}

const { authorKey, publishedAt, updatedAt, updateNote, tags } = Astro.props;
const author = authors[authorKey];
const formatDate = (iso: string) =>
  new Date(iso).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
const formattedPublished = formatDate(publishedAt);
const showUpdated = updatedAt && updatedAt > publishedAt;
---

<div class="blog-post-meta fade-in">
  <div class="blog-post-meta-row">
    <img src={author.avatarUrl} alt={`${author.name} avatar`} class="blog-post-meta-avatar" width="32" height="32" loading="lazy" decoding="async" />
    <span>By <a href={`/blog/author/${author.slug}/`}>{author.name}</a></span>
    {author.type === 'person' && (
      <span class="blog-post-meta-role">({author.jobTitle})</span>
    )}
    <span class="blog-post-meta-dot" aria-hidden="true">·</span>
    <time datetime={publishedAt}>{formattedPublished}</time>
    {showUpdated && (
      <>
        <span class="blog-post-meta-dot" aria-hidden="true">·</span>
        <span>Updated <time datetime={updatedAt}>{formatDate(updatedAt!)}</time></span>
      </>
    )}
  </div>
  {updateNote && showUpdated && (
    <div class="blog-post-changelog">
      <strong>Revision note ({formatDate(updatedAt!)}):</strong> {updateNote}
    </div>
  )}
  <div class="blog-post-tags">
    {tags.map((tag) => (
      <a href={`/blog/tag/${tag}/`} class="blog-post-tag">{blogTagLabels[tag]}</a>
    ))}
  </div>
</div>

<style>
  .blog-post-meta {
    max-width: 900px;
    margin: 0 auto 28px;
    padding: 0 20px;
  }

  .blog-post-meta-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    color: #64748b;
    margin-bottom: 12px;
  }

  .blog-post-meta-avatar {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
  }

  .blog-post-meta-row a {
    color: var(--color-primary);
    font-weight: 600;
    text-decoration: none;
    cursor: pointer;
  }

  .blog-post-meta-row a:hover {
    text-decoration: underline;
  }

  .blog-post-meta-row a:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
    border-radius: 2px;
  }

  .blog-post-meta-dot {
    opacity: 0.5;
  }

  .blog-post-meta-role {
    font-size: 13px;
    color: #475569;
  }

  .blog-post-changelog {
    margin-bottom: 14px;
    padding: 12px 16px;
    background: rgba(20, 110, 245, 0.06);
    border: 1px solid rgba(20, 110, 245, 0.18);
    border-radius: 8px;
    font-size: 13px;
    line-height: 1.55;
    color: #475569;
  }

  .blog-post-changelog strong {
    color: var(--color-title);
  }

  .blog-post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .blog-post-tag {
    display: inline-block;
    padding: 4px 12px;
    border-radius: 999px;
    border: 1px solid var(--color-stroke);
    background: var(--color-white);
    font-size: 12px;
    font-weight: 600;
    color: var(--color-body-text);
    text-decoration: none;
    cursor: pointer;
    transition: border-color 0.2s ease, background 0.2s ease, color 0.2s ease;
  }

  .blog-post-tag:hover {
    border-color: rgba(20, 110, 245, 0.45);
    background: rgba(20, 110, 245, 0.08);
    color: var(--color-primary);
  }

  .blog-post-tag:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }
</style>
