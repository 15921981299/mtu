---
interface Props {
  active: 'payment' | 'shipping' | 'samples';
}

const { active } = Astro.props;

const items = [
  { id: 'payment', label: 'Payment', href: '/terms/payment/' },
  { id: 'shipping', label: 'Shipping', href: '/terms/shipping/' },
  { id: 'samples', label: 'Samples & FAI', href: '/terms/samples/' },
] as const;
---

<nav class="terms-nav" aria-label="Order terms">
  {items.map((item) => (
    <a
      href={item.href}
      class:list={['terms-nav-link', { active: item.id === active }]}
      aria-current={item.id === active ? 'page' : undefined}
    >
      {item.label}
    </a>
  ))}
</nav>
