---
import { site } from '../data/site';

interface Props {
  showYoutube?: boolean;
  compact?: boolean;
}

const { showYoutube = true, compact = false } = Astro.props;
const { inspectionMedia } = site.quality;
const youtubeId = inspectionMedia.youtubeVideoId;
const hasYoutube = showYoutube && Boolean(youtubeId);
---

<section class:list={['inspection-media', { 'inspection-media--compact': compact }]}>
  <div class="inspection-media-grid">
    <div class="inspection-media-video-wrap">
      <p class="inspection-media-kicker">Shop-floor process</p>
      <h2 class="inspection-media-title">How parts are machined &amp; inspected</h2>
      {!compact && (
        <p class="inspection-media-desc">
          See in-process checks, finishing, and final QC before pack-out. Pair this with our
          <a href="/resources/inspection-samples/">redacted report samples</a> to verify what you receive on PO release.
        </p>
      )}
      <video
        class="inspection-media-video"
        controls
        playsinline
        preload="metadata"
        poster={inspectionMedia.factoryVideoPoster}
      >
        <source src={inspectionMedia.factoryVideoMp4} type="video/mp4" />
        <source src={inspectionMedia.factoryVideoWebm} type="video/webm" />
      </video>
      {hasYoutube && (
        <div class="inspection-media-youtube">
          <p class="inspection-media-youtube-label">Extended factory tour</p>
          <div class="inspection-media-youtube-embed">
            <iframe
              src={`https://www.youtube.com/embed/${youtubeId}`}
              title="CNC machining factory process video"
              loading="lazy"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
            />
          </div>
        </div>
      )}
    </div>
    <div class="inspection-media-steps">
      <p class="inspection-media-kicker">QC workflow</p>
      <h3 class="inspection-media-steps-title">4 gates before shipment</h3>
      <ol class="inspection-media-step-list">
        <li>
          <strong>Incoming material</strong>
          <span>Mill cert matched to heat lot before machining starts.</span>
        </li>
        <li>
          <strong>In-process check</strong>
          <span>Critical features verified at operator-defined intervals.</span>
        </li>
        <li>
          <strong>Final CMM / gauge</strong>
          <span>Ballooned report on drawing-controlled characteristics.</span>
        </li>
        <li>
          <strong>Release package</strong>
          <span>CoC + inspection report + certs bundled per PO scope.</span>
        </li>
      </ol>
      <a href="/resources/inspection-samples/" class="inspection-media-samples-link">
        View redacted document samples →
      </a>
    </div>
  </div>
</section>

<style>
  .inspection-media {
    margin-top: 8px;
  }

  .inspection-media-grid {
    display: grid;
    grid-template-columns: 1.35fr 1fr;
    gap: 28px;
    align-items: start;
  }

  .inspection-media-kicker {
    margin: 0 0 6px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-primary);
  }

  .inspection-media-title {
    margin: 0 0 12px;
    font-size: 24px;
    font-weight: 600;
    color: var(--color-title);
    text-transform: none;
    line-height: 1.3;
  }

  .inspection-media-desc {
    margin: 0 0 16px;
    font-size: 15px;
    line-height: 1.6;
    color: var(--color-body-text);
  }

  .inspection-media-desc a {
    color: var(--color-primary);
    font-weight: 600;
    text-decoration: none;
  }

  .inspection-media-desc a:hover {
    text-decoration: underline;
  }

  .inspection-media-video {
    display: block;
    width: 100%;
    border-radius: 4px;
    border: 1px solid var(--color-stroke);
    background: #000;
    box-shadow: 0 4px 20px rgba(8, 8, 8, 0.08);
  }

  .inspection-media-youtube {
    margin-top: 16px;
  }

  .inspection-media-youtube-label {
    margin: 0 0 8px;
    font-size: 13px;
    font-weight: 600;
    color: var(--color-body-text);
  }

  .inspection-media-youtube-embed {
    position: relative;
    padding-bottom: 56.25%;
    height: 0;
    overflow: hidden;
    border-radius: 4px;
    border: 1px solid var(--color-stroke);
  }

  .inspection-media-youtube-embed iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }

  .inspection-media-steps {
    padding: 24px;
    background: var(--color-white);
    border: 1px solid var(--color-stroke);
    border-radius: 4px;
  }

  .inspection-media-steps-title {
    margin: 0 0 16px;
    font-size: 18px;
    font-weight: 600;
    color: var(--color-title);
    text-transform: none;
  }

  .inspection-media-step-list {
    margin: 0 0 18px;
    padding-left: 20px;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .inspection-media-step-list li {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .inspection-media-step-list strong {
    font-size: 14px;
    color: var(--color-title);
  }

  .inspection-media-step-list span {
    font-size: 14px;
    line-height: 1.5;
    color: var(--color-body-text);
  }

  .inspection-media-samples-link {
    display: inline-block;
    font-size: 14px;
    font-weight: 600;
    color: var(--color-primary);
    text-decoration: none;
  }

  .inspection-media-samples-link:hover {
    text-decoration: underline;
  }

  .inspection-media--compact .inspection-media-title {
    font-size: 20px;
  }

  .inspection-media--compact .inspection-media-grid {
    grid-template-columns: 1fr;
  }

  @media screen and (max-width: 991px) {
    .inspection-media-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
