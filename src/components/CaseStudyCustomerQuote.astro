---
import type { CaseStudyCustomerQuote } from '../data/case-study-shared';

interface Props {
  quote: CaseStudyCustomerQuote;
}

const { quote } = Astro.props;
---

<figure class="case-customer-quote">
  <blockquote cite={quote.testimonialSlug ? `#testimonial-${quote.testimonialSlug}` : undefined}>
    <p>&ldquo;{quote.text}&rdquo;</p>
  </blockquote>
  <figcaption>
    — {quote.attribution}
    {quote.testimonialSlug && (
      <>
        {' '}
        <a href={`/case-studies/#testimonial-${quote.testimonialSlug}`} class="case-quote-link">
          See buyer profile
        </a>
      </>
    )}
  </figcaption>
</figure>

<style>
  .case-customer-quote {
    margin: 0 0 28px;
    padding: 22px 24px;
    border-left: 4px solid var(--color-primary);
    border-radius: 0 4px 4px 0;
    background: rgba(20, 110, 245, 0.06);
  }

  .case-customer-quote blockquote {
    margin: 0;
  }

  .case-customer-quote blockquote p {
    margin: 0;
    font-size: 17px;
    line-height: 1.65;
    font-weight: 500;
    color: var(--color-title);
    font-style: italic;
  }

  .case-customer-quote figcaption {
    margin-top: 12px;
    font-size: 14px;
    font-weight: 600;
    color: var(--color-body-text);
  }

  .case-quote-link {
    color: var(--color-primary);
    text-decoration: none;
    font-weight: 600;
  }

  .case-quote-link:hover {
    text-decoration: underline;
  }
</style>
