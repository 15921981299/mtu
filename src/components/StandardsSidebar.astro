---
import { standards } from '../data/standards';
import { site } from '../data/site';

interface Props {
  activeSlug: string;
}

const { activeSlug } = Astro.props;
const arrow = `<svg width="20" height="14" viewBox="0 0 18 12" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M17 6H1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path><path d="M12 11C12 11 17 7.3176 17 6C17 4.6824 12 1 12 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path></svg>`;
---

<aside class="service-details-sidebar">
  <div class="service-category-block">
    <div class="service-category-flex"><h2 class="service-sidebar-title">By Standard</h2></div>
    <div class="service-category-cms-block">
      <div class="service-sidebar-collection-list">
        {standards.map((standard) => (
          <div class="service-sidebar-collection-items">
            <div class="service-title-block">
              <a
                href={`/standards/${standard.slug}/`}
                class:list={['service-title-link-block', 'is-2', { active: standard.slug === activeSlug }]}
              >
                <div class="service-title">{standard.title}</div>
                <div class="arrow-icon" set:html={arrow} />
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
  <div class="service-sidebar-inner">
    <div class="service-details-form-block">
      <h3 class="service-sidebar-title">Verify Parts Support</h3>
      <p class="standard-sidebar-note">
        Review part-number checks, documentation scope, and delivery support before sending your inquiry.
      </p>
      <div class="standard-sidebar-links">
        <a href="/certifications/">Certifications</a>
        <a href="/part-products/">MTU Part Numbers</a>
        <a href="/products/mtu-spare-parts/mtu-part-number-lookup/">MTU Lookup</a>
        <a href="/case-studies/">Case Studies</a>
      </div>
    </div>
    <div class="service-contact-info-block">
      <div class="service-contact-info-title">Parts questions?</div>
      <div class="service-contact-info-devider"></div>
      <div class="servoce-contact-link-block">
        <a href={`tel:${site.phone.replace(/\s/g, '')}`} class="service-cotact-info-link">{site.phone}</a>
        <a href={`mailto:${site.email}`} class="service-cotact-email">{site.email}</a>
      </div>
    </div>
  </div>
</aside>

<style>
  .standard-sidebar-note {
    margin: 0 0 16px;
    font-size: 14px;
    line-height: 1.55;
    color: var(--color-body-text);
  }

  .standard-sidebar-links {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .standard-sidebar-links a {
    display: block;
    padding: 12px 16px;
    font-size: 14px;
    font-weight: 600;
    color: var(--color-title);
    text-decoration: none;
    background: var(--color-background);
    border: 1px solid var(--color-stroke);
    border-radius: 4px;
    transition: border-color 0.2s, color 0.2s;
  }

  .standard-sidebar-links a:hover {
    border-color: rgba(20, 110, 245, 0.4);
    color: var(--color-primary);
  }
</style>
