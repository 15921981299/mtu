---
import { getPillarProofCaseStudies, hasBlogProofChain } from '../data/blog-pillar-proof';

interface Props {
  slug: string;
}

const { slug } = Astro.props;
const proofStudies = hasBlogProofChain(slug) ? getPillarProofCaseStudies(slug) : [];
---

{
  proofStudies.length > 0 && (
    <aside class="blog-pillar-proof fade-in" aria-label="Verified parts sourcing examples">
      <h2 class="blog-pillar-proof-title">See related sourcing examples</h2>
      <p class="blog-pillar-proof-lead">
        These case studies show part-number checks, delivery scope, and outcomes from real engine parts inquiries.
      </p>
      <ul class="blog-pillar-proof-list">
        {proofStudies.map((study) => (
          <li>
            <a href={`/case-studies/${study.slug}/`}>{study.title}</a>
            {study.summary && <span class="blog-pillar-proof-summary">{study.summary}</span>}
          </li>
        ))}
      </ul>
      <p class="blog-pillar-proof-more">
        <a href="/case-studies/">Browse all case studies →</a>
      </p>
    </aside>
  )
}

<style>
  .blog-pillar-proof {
    margin: 32px 0 8px;
    padding: 20px 22px;
    background: #faf5ff;
    border-left: 4px solid #8b5cf6;
    border-radius: 0 4px 4px 0;
  }
  .blog-pillar-proof-title {
    margin: 0 0 8px;
    font-size: 18px;
    color: #7c3aed;
  }
  .blog-pillar-proof-lead {
    margin: 0 0 14px;
    font-size: 15px;
    line-height: 1.55;
    color: var(--color-body-text);
  }
  .blog-pillar-proof-list {
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .blog-pillar-proof-list li {
    margin-bottom: 12px;
    padding-bottom: 12px;
    border-bottom: 1px solid rgba(139, 92, 246, 0.15);
  }
  .blog-pillar-proof-list li:last-child {
    margin-bottom: 0;
    padding-bottom: 0;
    border-bottom: none;
  }
  .blog-pillar-proof-list a {
    display: block;
    font-weight: 600;
    color: var(--color-primary);
    text-decoration: none;
    margin-bottom: 4px;
  }
  .blog-pillar-proof-list a:hover {
    text-decoration: underline;
  }
  .blog-pillar-proof-summary {
    display: block;
    font-size: 14px;
    line-height: 1.5;
    color: #64748b;
  }
  .blog-pillar-proof-more {
    margin: 14px 0 0;
    font-size: 14px;
  }
  .blog-pillar-proof-more a {
    color: var(--color-primary);
    font-weight: 600;
    text-decoration: none;
  }
  .blog-pillar-proof-more a:hover {
    text-decoration: underline;
  }
</style>
