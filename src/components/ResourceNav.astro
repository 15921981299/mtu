---
type ResourceNavActive =
  | 'resources-index'
  | 'by-role'
  | 'dfm-checklist'
  | 'cnc-tolerance-guide'
  | 'surface-finish-converter'
  | 'tolerance-fits-calculator'
  | 'tap-drill-chart'
  | 'hardness-conversion-chart'
  | 'metal-weight-calculator'
  | 'feeds-and-speeds-calculator'
  | 'bolt-circle-calculator'
  | 'material-certificates'
  | 'inspection-samples'
  | 'cnc-pricing-guide'
  | 'cnc-cost-calculator'
  | 'process-selection';

interface Props {
  active?: ResourceNavActive;
}

const { active } = Astro.props;

const guides = [
  { id: 'by-role', label: 'By Role', href: '/resources/by-role/' },
  { id: 'dfm-checklist', label: 'Inquiry Checklist', href: '/resources/dfm-checklist/' },
  { id: 'cnc-tolerance-guide', label: 'Part Fitment', href: '/resources/cnc-tolerance-guide/' },
  { id: 'material-certificates', label: 'MTU Lookup', href: '/resources/material-certificates/' },
  { id: 'inspection-samples', label: 'Series Guide', href: '/resources/inspection-samples/' },
  { id: 'cnc-pricing-guide', label: 'Lead Time', href: '/resources/cnc-pricing-guide/' },
  { id: 'process-selection', label: 'Part Category', href: '/resources/process-selection/' },
] as const;

const tools = [
  { id: 'surface-finish-converter', label: 'Gasket Notes', href: '/resources/surface-finish-converter/' },
  { id: 'tolerance-fits-calculator', label: 'Sensor Notes', href: '/resources/tolerance-fits-calculator/' },
  { id: 'tap-drill-chart', label: 'Fuel Parts', href: '/resources/tap-drill-chart/' },
  { id: 'hardness-conversion-chart', label: 'Overhaul Parts', href: '/resources/hardness-conversion-chart/' },
  { id: 'metal-weight-calculator', label: 'Freight Planning', href: '/resources/metal-weight-calculator/' },
  { id: 'feeds-and-speeds-calculator', label: 'Stock Check', href: '/resources/feeds-and-speeds-calculator/' },
  { id: 'bolt-circle-calculator', label: 'Pump Fitment', href: '/resources/bolt-circle-calculator/' },
  { id: 'cnc-cost-calculator', label: 'Parts Cost', href: '/resources/cnc-cost-calculator/' },
] as const;
---

<div class="resource-nav-groups">
  <div class="resource-nav-group">
    <span class="resource-nav-group-label">Guides</span>
    <nav class="resource-nav" aria-label="Engineering guides">
      {guides.map((item) => (
        <a
          href={item.href}
          class:list={['resource-nav-link', { active: item.id === active }]}
          aria-current={item.id === active ? 'page' : undefined}
        >
          {item.label}
        </a>
      ))}
    </nav>
  </div>

  <div class="resource-nav-group">
    <span class="resource-nav-group-label">Reference Topics</span>
    <nav class="resource-nav" aria-label="Engine parts reference topics">
      {tools.map((item) => (
        <a
          href={item.href}
          class:list={['resource-nav-link', { active: item.id === active }]}
          aria-current={item.id === active ? 'page' : undefined}
        >
          {item.label}
        </a>
      ))}
      <a
        href="/resources/"
        class:list={['resource-nav-link', 'resource-nav-all', { active: active === 'resources-index' }]}
        aria-current={active === 'resources-index' ? 'page' : undefined}
      >
        All resources
      </a>
    </nav>
  </div>
</div>
