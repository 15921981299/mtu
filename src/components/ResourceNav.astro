---
type ResourceNavActive =
  | 'resources-index'
  | 'by-role'
  | 'dfm-checklist'
  | 'material-certificates'
  | 'inspection-samples'
  | 'process-selection';

interface Props {
  active?: ResourceNavActive;
}

const { active } = Astro.props;

const guides = [
  { id: 'by-role', label: 'By Role', href: '/resources/by-role/' },
  { id: 'dfm-checklist', label: 'Inquiry Checklist', href: '/resources/dfm-checklist/' },
  { id: 'material-certificates', label: 'Certificates', href: '/resources/material-certificates/' },
  { id: 'inspection-samples', label: 'Inspection Samples', href: '/resources/inspection-samples/' },
  { id: 'process-selection', label: 'Part Categories', href: '/resources/process-selection/' },
] as const;
---

<div class="resource-nav-groups">
  <div class="resource-nav-group">
    <span class="resource-nav-group-label">Guides</span>
    <nav class="resource-nav" aria-label="Parts guides">
      {guides.map((item) => (
        <a
          href={item.href}
          class:list={['resource-nav-link', { active: item.id === active }]}
          aria-current={item.id === active ? 'page' : undefined}
        >
          {item.label}
        </a>
      ))}
    </nav>
  </div>

  <div class="resource-nav-group">
    <span class="resource-nav-group-label">Quick Links</span>
    <nav class="resource-nav" aria-label="Quick links">
      <a href="/products/" class="resource-nav-link">Engine Parts Catalog</a>
      <a href="/part-products/" class="resource-nav-link">MTU Part Numbers</a>
      <a href="/contact/" class="resource-nav-link">Request Parts</a>
      <a
        href="/resources/"
        class:list={['resource-nav-link', 'resource-nav-all', { active: active === 'resources-index' }]}
        aria-current={active === 'resources-index' ? 'page' : undefined}
      >
        All resources
      </a>
    </nav>
  </div>
</div>
