---
import { authors, type AuthorSlug } from '../data/blog';

interface Props {
  slug: string;
  title: string;
  image: string;
  authorKey: AuthorSlug;
  featured?: boolean;
  excerpt?: string;
}

const { slug, title, image, authorKey, featured = false, excerpt } = Astro.props;
const author = authors[authorKey];
---

<div class:list={['blog-single-item-block', 'fade-in', { featured }]}>
  {featured ? (
    <>
      <a href={`/blog/${slug}/`} class="blog-item-image-link-block">
        <div class="blog-item-image-block">
          <div class="blog-item-image-inner-block">
            <img src={image} alt={title} class="blog-item-image featured" width="1200" height="920" loading="eager" decoding="async" />
            <div class="blog-image-cursor"><div class="blog-cursor-text">/Read</div></div>
          </div>
        </div>
      </a>
      <div class="blog-item-title-block featured">
        <a href={`/blog/${slug}/`} class="blog-item-title-link-block"><h3 class="blog-item-title">{title}</h3></a>
        <div class="blog-author-block">
          <span class="blog-author-name">By</span>
          <a href={`/blog/author/${author.slug}/`} class="blog-author-name hover-two">{author.name}</a>
        </div>
      </div>
    </>
  ) : (
    <>
      <div class="blog-card-item-inner-block">
        <div class="blog-item-image-block">
          <div class="blog-author-block">
            <span class="blog-author-name">By</span>
            <a href={`/blog/author/${author.slug}/`} class="blog-author-name hover">{author.name}</a>
          </div>
          <a href={`/blog/${slug}/`} class="blog-item-image-link-block">
            <img src={image} alt={title} class="blog-item-image" width="400" height="307" loading="lazy" decoding="async" />
            <div class="blog-image-cursor"><div class="blog-cursor-text">/Read</div></div>
          </a>
        </div>
      </div>
      <div class="blog-item-title-block">
        <a href={`/blog/${slug}/`} class="blog-item-title-link-block"><h3 class="blog-item-title">{title}</h3></a>
        {excerpt && <p class="blog-item-excerpt">{excerpt}</p>}
      </div>
    </>
  )}
</div>

<style>
  .blog-item-excerpt {
    margin: 8px 0 0;
    font-size: 14px;
    line-height: 1.5;
    color: var(--color-body-text);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
