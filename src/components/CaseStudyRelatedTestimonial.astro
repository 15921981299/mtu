---
import type { Testimonial } from '../data/testimonials';

interface Props {
  testimonial: Testimonial;
}

const { testimonial } = Astro.props;
---

<aside class="case-related-testimonial" id={`testimonial-${testimonial.slug}`}>
  <p class="case-related-kicker">Related buyer feedback</p>
  <blockquote>
    <p>&ldquo;{testimonial.quote}&rdquo;</p>
  </blockquote>
  <p class="case-related-attribution">
    — {testimonial.name}, {testimonial.role}
  </p>
  <a href={`/case-studies/${testimonial.caseStudySlug}/`} class="case-related-link">
    Read full case study →
  </a>
</aside>

<style>
  .case-related-testimonial {
    margin: 0 0 28px;
    padding: 20px 22px;
    border: 1px solid var(--color-stroke);
    border-radius: 4px;
    background: var(--color-white);
  }

  .case-related-kicker {
    margin: 0 0 10px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-primary);
  }

  .case-related-testimonial blockquote {
    margin: 0;
  }

  .case-related-testimonial blockquote p {
    margin: 0;
    font-size: 15px;
    line-height: 1.65;
    color: var(--color-body-text);
    font-style: italic;
  }

  .case-related-attribution {
    margin: 10px 0 12px;
    font-size: 14px;
    font-weight: 600;
    color: var(--color-title);
  }

  .case-related-link {
    font-size: 14px;
    font-weight: 600;
    color: var(--color-primary);
    text-decoration: none;
  }

  .case-related-link:hover {
    text-decoration: underline;
  }
</style>
