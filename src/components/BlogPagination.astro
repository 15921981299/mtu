---
import { getBlogTotalPages } from '../data/blog';

interface Props {
  currentPage: number;
}

const { currentPage } = Astro.props;
const totalPages = getBlogTotalPages();

if (totalPages <= 1) return null;

const pages = Array.from({ length: totalPages }, (_, i) => i + 1);
const pageHref = (page: number) => (page === 1 ? '/blog/' : `/blog/page/${page}/`);
---

<nav class="blog-pagination fade-in" aria-label="Blog pagination">
  {currentPage > 1 ? (
    <a href={pageHref(currentPage - 1)} class="blog-pagination-link">← Previous</a>
  ) : (
    <span class="blog-pagination-link is-disabled">← Previous</span>
  )}
  <div class="blog-pagination-pages">
    {pages.map((page) => (
      <a
        href={pageHref(page)}
        class:list={['blog-pagination-page', { active: page === currentPage }]}
        aria-current={page === currentPage ? 'page' : undefined}
      >
        {page}
      </a>
    ))}
  </div>
  {currentPage < totalPages ? (
    <a href={pageHref(currentPage + 1)} class="blog-pagination-link">Next →</a>
  ) : (
    <span class="blog-pagination-link is-disabled">Next →</span>
  )}
</nav>

<style>
  .blog-pagination {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    flex-wrap: wrap;
    margin-top: 40px;
  }
  .blog-pagination-link {
    font-size: 14px;
    font-weight: 600;
    color: #6ab0ff;
    text-decoration: none;
  }
  .blog-pagination-link.is-disabled {
    color: #5a6478;
    pointer-events: none;
  }
  .blog-pagination-pages {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    justify-content: center;
  }
  .blog-pagination-page {
    min-width: 36px;
    height: 36px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    border: 1px solid rgba(255, 255, 255, 0.12);
    font-size: 14px;
    font-weight: 600;
    color: #c5cad6;
    text-decoration: none;
  }
  .blog-pagination-page.active,
  .blog-pagination-page:hover {
    border-color: rgba(20, 110, 245, 0.5);
    background: rgba(20, 110, 245, 0.12);
    color: #fff;
  }
</style>
