---
import type { CaseStudyClientProfile } from '../data/case-study-shared';

interface Props {
  profile: CaseStudyClientProfile;
}

const { profile } = Astro.props;
---

<section class="case-client-profile" aria-labelledby="client-profile-heading">
  <h2 id="client-profile-heading" class="case-section-title">Customer Background</h2>
  <p class="case-client-lead">{profile.description}</p>
  <dl class="case-client-grid">
    <div>
      <dt>Region</dt>
      <dd>{profile.region}</dd>
    </div>
    <div>
      <dt>Scale</dt>
      <dd>{profile.scale}</dd>
    </div>
    <div>
      <dt>Scenario</dt>
      <dd>{profile.scenario}</dd>
    </div>
  </dl>
</section>

<style>
  .case-client-profile {
    margin-bottom: 28px;
    padding: 22px;
    border: 1px solid var(--color-stroke);
    border-radius: 4px;
    background: var(--color-white);
  }

  .case-section-title {
    margin: 0 0 10px;
    font-size: 20px;
    font-weight: 600;
    color: var(--color-title);
    text-transform: none;
  }

  .case-client-lead {
    margin: 0 0 16px;
    font-size: 15px;
    line-height: 1.65;
    color: var(--color-body-text);
  }

  .case-client-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
    margin: 0;
  }

  .case-client-grid div {
    padding: 12px;
    border: 1px solid var(--color-stroke);
    border-radius: 4px;
    background: var(--color-background);
  }

  .case-client-grid dt {
    margin: 0 0 6px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-primary);
  }

  .case-client-grid dd {
    margin: 0;
    font-size: 14px;
    line-height: 1.5;
    font-weight: 600;
    color: var(--color-title);
  }

  @media (max-width: 640px) {
    .case-client-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
