---
import { services } from '../data/services';
import { additionalServices } from '../data/additional-services';
import { site } from '../data/site';

interface Props {
  activeSlug: string;
  quoteHref?: string;
}

const { activeSlug, quoteHref = '/contact/?source=capabilities' } = Astro.props;
const arrow = `<svg width="20" height="14" viewBox="0 0 18 12" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M17 6H1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path><path d="M12 11C12 11 17 7.3176 17 6C17 4.6824 12 1 12 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path></svg>`;
const additionalLinks: Record<(typeof additionalServices)[number]['title'], string> = {
  'Parts Identification': '/products/mtu-spare-parts/mtu-part-number-lookup/',
  'Stock Check': '/contact/?source=stock-check',
  'Export Packing': '/terms/shipping/',
  'Global Shipping': '/terms/shipping/',
};
---

<aside class="service-details-sidebar">
  <div class="service-category-block">
    <div class="service-category-flex"><h2 class="service-sidebar-title">Parts Support</h2></div>
    <div class="service-category-cms-block">
      <div class="service-sidebar-collection-list">
        {services.map((service) => (
          <div class="service-sidebar-collection-items">
            <div class="service-title-block">
              <a href={`/capabilities/${service.slug}/`} class:list={['service-title-link-block', 'is-2', { active: service.slug === activeSlug }]}>
                <div class="service-title">{service.title}</div>
                <div class="arrow-icon" set:html={arrow} />
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
  <div class="service-category-block">
    <div class="service-category-flex"><h2 class="service-sidebar-title">Additional Services</h2></div>
    <div class="service-category-cms-block">
      <div class="service-sidebar-collection-list">
        {additionalServices.map((item) => (
          <div class="service-sidebar-collection-items">
            <div class="service-title-block">
              <a href={additionalLinks[item.title]} class="service-title-link-block is-2">
                <div class="service-title">{item.title}</div>
                <div class="arrow-icon" set:html={arrow} />
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
  <div class="service-sidebar-inner">
    <div class="service-contact-info-block">
      <a href={quoteHref} class="sidebar-rfq-link">Send parts inquiry →</a>
      <div class="service-contact-info-title">Helpful references</div>
      <div class="service-contact-info-devider"></div>
      <div class="servoce-contact-link-block">
        <a href="/products/mtu-spare-parts/mtu-part-number-lookup/" class="service-cotact-info-link">MTU part lookup</a>
        <a href="/resources/" class="service-cotact-email">Parts guides</a>
        <a href={`mailto:${site.email}`} class="service-cotact-email">{site.email}</a>
      </div>
    </div>
  </div>
</aside>
