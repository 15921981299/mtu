---
interface ProofCopy {
  eyebrow: string;
  title: string;
  text: string;
}

const proofCopy: Record<string, ProofCopy> = {
  blog: {
    eyebrow: 'Editorial review',
    title: 'Engineer-reviewed before publishing',
    text:
      'Our technical pages are checked against CNC machining, sourcing, and inspection practice before publication. AI assistance does not replace drawing-level DFM review; send your STEP or PDF for project-specific feedback.',
  },
  comparison: {
    eyebrow: 'Shop-floor judgment',
    title: 'Decision guidance from real RFQ review',
    text:
      'Each comparison is written for buyers choosing a process, material, or finish before quoting. We still confirm the final choice against your drawing, tolerance stack, quantity, and inspection requirement.',
  },
  product: {
    eyebrow: 'Supplier capability check',
    title: 'Quoted with CNC, sourcing, and QC review',
    text:
      'Product pages describe the information we verify during RFQ review: geometry, material, tolerance, finish, inspection method, and lead time risk. Your drawing receives a project-specific DFM response.',
  },
  material: {
    eyebrow: 'Material review',
    title: 'Material guidance tied to machining and inspection',
    text:
      'Material pages are reviewed from machining, purchasing, and quality-control angles. We confirm grade, certificate needs, finish compatibility, and dimensional risk before quoting production parts.',
  },
};

const { context = 'blog' } = Astro.props;
const copy = proofCopy[context] ?? proofCopy.blog;
---

<section class="experience-proof-note" aria-label={copy.eyebrow}>
  <div class="experience-proof-note__copy">
    <p class="experience-proof-note__eyebrow">{copy.eyebrow}</p>
    <h2>{copy.title}</h2>
    <p>{copy.text}</p>
  </div>
  <nav class="experience-proof-note__links" aria-label="Trust resources">
    <a href="/about/">About our team</a>
    <a href="/certifications/">Quality system</a>
    <a href="/resources/inspection-samples/">Inspection samples</a>
  </nav>
</section>

<style>
  .experience-proof-note {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 20px;
    align-items: center;
    margin: 0 0 24px;
    padding: 18px 20px;
    border: 1px solid rgba(15, 23, 42, 0.1);
    border-left: 4px solid var(--color-primary);
    border-radius: 8px;
    background: #f8fafc;
  }

  .experience-proof-note__copy {
    min-width: 0;
  }

  .experience-proof-note__eyebrow {
    margin: 0 0 6px;
    color: var(--color-primary);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .experience-proof-note h2 {
    margin: 0 0 8px;
    color: var(--color-title);
    font-size: 18px;
    line-height: 1.35;
    text-transform: none;
  }

  .experience-proof-note p {
    margin: 0;
    color: #475569;
    font-size: 14px;
    line-height: 1.65;
  }

  .experience-proof-note__links {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 10px;
    min-width: 220px;
  }

  .experience-proof-note__links a {
    color: var(--color-primary);
    font-size: 13px;
    font-weight: 700;
    text-decoration: none;
    white-space: nowrap;
  }

  .experience-proof-note__links a:hover {
    text-decoration: underline;
  }

  .experience-proof-note__links a:focus-visible {
    border-radius: 2px;
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }

  @media (max-width: 720px) {
    .experience-proof-note {
      grid-template-columns: 1fr;
      align-items: start;
    }

    .experience-proof-note__links {
      justify-content: flex-start;
      min-width: 0;
    }
  }
</style>
