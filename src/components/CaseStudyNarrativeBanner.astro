---
import type { CaseStudyNarrative } from '../data/case-study-shared';

interface Props {
  narrative: CaseStudyNarrative;
}

const { narrative } = Astro.props;

const copy: Record<CaseStudyNarrative, { label: string; text: string } | null> = {
  standard: null,
  iteration: {
    label: 'Iteration story',
    text: 'This project included design revisions after first article — a common path for prototypes and trade-show hardware.',
  },
  turnaround: {
    label: 'Turnaround story',
    text: 'This customer switched suppliers after quality or lead-time failures elsewhere — outcomes reflect a recovery project, not a first-time perfect run.',
  },
};

const banner = copy[narrative];
---

{banner && (
  <aside class="case-narrative-banner" role="note">
    <span class="case-narrative-label">{banner.label}</span>
    <p>{banner.text}</p>
  </aside>
)}

<style>
  .case-narrative-banner {
    margin-bottom: 24px;
    padding: 14px 16px;
    border: 1px solid rgba(20, 110, 245, 0.25);
    border-radius: 4px;
    background: rgba(20, 110, 245, 0.06);
  }

  .case-narrative-label {
    display: block;
    margin-bottom: 6px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-primary);
  }

  .case-narrative-banner p {
    margin: 0;
    font-size: 14px;
    line-height: 1.55;
    color: var(--color-body-text);
  }
</style>
