---
---

<a
  href="/contact/?source=floating"
  class="floating-quote"
  id="floating-quote"
  aria-label="Request engine parts"
  data-rfq-modal
  data-rfq-context="Floating Check Parts inquiry"
  data-rfq-source="floating"
>
  <span class="floating-quote-icon" aria-hidden="true">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M21 15V19C21 19.5304 20.7893 20.0391 20.4142 20.4142C20.0391 20.7893 19.5304 21 19 21H5C4.46957 21 3.96086 20.7893 3.58579 20.4142C3.21071 20.0391 3 19.5304 3 19V15" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
      <path d="M17 8L12 3L7 8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
      <path d="M12 3V15" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
    </svg>
  </span>
  <span class="floating-quote-text">Check Parts</span>
</a>

<style>
  .floating-quote {
    position: fixed;
    right: 24px;
    bottom: 24px;
    z-index: 90;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 20px;
    border-radius: 999px;
    background: #146ef5;
    color: #fff;
    font-size: 14px;
    font-weight: 700;
    text-decoration: none;
    box-shadow: 0 8px 24px rgba(20, 110, 245, 0.35);
    opacity: 0;
    transform: translateY(16px);
    pointer-events: none;
    transition: opacity 0.3s, transform 0.3s, background 0.2s;
  }
  .floating-quote.is-visible {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }
  .floating-quote:hover {
    background: #0f5ad0;
  }
  .floating-quote-icon {
    display: flex;
  }
  @media (max-width: 640px) {
    .floating-quote-text { display: none; }
    .floating-quote {
      right: 16px;
      bottom: 16px;
      padding: 14px;
      border-radius: 50%;
    }
  }
</style>

<script>
  const floatingQuote = document.getElementById('floating-quote');
  if (floatingQuote) {
    const toggle = () => {
      floatingQuote.classList.toggle('is-visible', window.scrollY > 480);
    };
    toggle();
    window.addEventListener('scroll', toggle, { passive: true });

    floatingQuote.addEventListener('click', () => {
      if (typeof window.gtag !== 'function') return;
      window.gtag('event', 'rfq_cta_click', {
        event_category: 'Funnel',
        event_label: 'floating_quote',
        funnel_stage: 'quote',
      });
    });
  }
</script>
